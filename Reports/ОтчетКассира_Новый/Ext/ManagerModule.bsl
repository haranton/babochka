
Функция ОсновнаяЧастьОтчета(ТабДок,Макет,НачалоПериода, КонецПериода, Знач Подразделение, рисунокБ = ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	         
	со = ?(подразделение.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("СО оплата"),"Свойство")=неопределено, ложь, 
	подразделение.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("СО оплата"),"Свойство").значение);
	ПС = ?(подразделение.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("ПС"),"Свойство")=неопределено, ложь,
	подразделение.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("ПС"),"Свойство").значение);
	Предоплата = ?(подразделение.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Предоплата"),"Свойство")=неопределено, ложь, 
	подразделение.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Предоплата"),"Свойство").значение);
	Постоплата = ?(подразделение.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Постоплата"),"Свойство")=неопределено, ложь, 
	подразделение.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Постоплата"),"Свойство").значение);
	Банк = ?(подразделение.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Банк"),"Свойство")=неопределено, ложь, 
	подразделение.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Банк"),"Свойство").значение);
	БанкИМ = ?(подразделение.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Банк ИМ"),"Свойство")=неопределено, ложь, 
	подразделение.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Банк ИМ"),"Свойство").значение);
	
	ВидЗаказаМТМ = перечисления.ВидыЗаказов.МТМ;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктураПредприятия.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
	|ГДЕ
	|	СтруктураПредприятия.Ссылка В ИЕРАРХИИ(&Подразделение)";
	
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	
	ВсеГруппы = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	//ВсеГруппы.Добавить(Подразделение);
	
	Подразделение = ВсеГруппы;	
	
	КассыККМСО = новый СписокЗначений();
	КассыККМ = новый СписокЗначений();
	КассыСО = новый списокзначений();
	КассыККМСО = новый СписокЗначений();
	КассыККМ = новый СписокЗначений();
	запросК = Новый ЗАпрос();
	запроск.Текст = "ВЫБРАТЬ разрешенные
	                |	КассыККМ.Ссылка
	                |ИЗ
	                |	Справочник.КассыККМ КАК КассыККМ
	                |ГДЕ
	                |	КассыККМ.Подразделение в (&Подразделение)
	                |	И НЕ КассыККМ.Ссылка В (&Ссылка)";
	ЗАпроск.УстановитьПараметр("Подразделение", подразделение);
	ЗАпроск.УстановитьПараметр("Ссылка", КассыККМСО);
	выбк = запроск.Выполнить().Выбрать();
	пока выбк.Следующий() цикл
		КассыККМ.Добавить(выбк.Ссылка);	
	конеццикла;

    запросК = Новый ЗАпрос();
    запроск.Текст = "ВЫБРАТЬ
                    |	ДополнительныеСведения.Объект КАК Объект
                    |ИЗ
                    |	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
                    |ГДЕ
                    |	ДополнительныеСведения.Свойство = &Свойство
                    |	И ДополнительныеСведения.Значение = истина
                    |	";
    ЗАпроск.УстановитьПараметр("Подразделение", подразделение);
    ЗАпроск.УстановитьПараметр("Свойство", планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Касса СО"));
    выбк = запроск.Выполнить().Выбрать();
    пока выбк.Следующий() цикл
    	КассыСО.Добавить(выбк.объект);	
    конеццикла;
    
    Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КассыККМ.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.КассыККМ КАК КассыККМ
		|ГДЕ
		|	НЕ КассыККМ.СО
		|	И КассыККМ.Подразделение В ИЕРАРХИИ(&Подразделение)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КассыККМ.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.КассыККМ КАК КассыККМ
		|ГДЕ
		|	КассыККМ.СО
		|	И КассыККМ.Подразделение В ИЕРАРХИИ(&Подразделение)";
	
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	Пакет = Запрос.ВыполнитьПакет();
	
	Если Пакет.Количество() > 0 Тогда
		КассыККМ.ЗагрузитьЗначения(Пакет[0].Выгрузить().ВыгрузитьКолонку("Ссылка"));
		КассыККМСО.ЗагрузитьЗначения(Пакет[1].Выгрузить().ВыгрузитьКолонку("Ссылка"));
	КонецЕсли;

	если ПС тогда
		Шапка1 = Макет.ПолучитьОбласть("Шапка1|пс");
		Табдок.Присоединить(Шапка1);
	конецесли;

	если со тогда	
		Шапка1 = Макет.ПолучитьОбласть("Шапка1|со");
		Табдок.Присоединить(Шапка1);
	конецесли;
		если Предоплата тогда
		Шапка1 = Макет.ПолучитьОбласть("Шапка1|пред");
		Табдок.Присоединить(Шапка1);
	конецесли;
	если Постоплата тогда
		Шапка1 = Макет.ПолучитьОбласть("Шапка1|пост");
		Табдок.Присоединить(Шапка1);
	конецесли;
	если банк тогда
		Шапка1 = Макет.ПолучитьОбласть("Шапка1|банк");
		Табдок.Присоединить(Шапка1);
	конецесли;
	если банким тогда
		Шапка1 = Макет.ПолучитьОбласть("Шапка1|банким");
		Табдок.Присоединить(Шапка1);
	конецесли;
	
	СтрокаДокументУвсех = Макет.ПолучитьОбласть("СтрокаДокумент|Увсех");
	СтрокаДокументсо = Макет.ПолучитьОбласть("СтрокаДокумент|со");
	СтрокаДокументпс = Макет.ПолучитьОбласть("СтрокаДокумент|пс");
	СтрокаДокументпред = Макет.ПолучитьОбласть("СтрокаДокумент|пред");
	СтрокаДокументпост = Макет.ПолучитьОбласть("СтрокаДокумент|пост");
	СтрокаДокументбанк = Макет.ПолучитьОбласть("СтрокаДокумент|банк");
	СтрокаДокументбанким = Макет.ПолучитьОбласть("СтрокаДокумент|банким");
	СтрокаДетали = Макет.ПолучитьОбласть("СтрокаДетали|Увсех");	
	продажи = Макет.получитьобласть("Продажи|Увсех");
	Возвраты1 = Макет.получитьобласть("Возвраты|Увсех");
	Заказы1 = Макет.получитьобласть("Заказы|Увсех");
	предоплаты = Макет.получитьобласть("предоплаты|Увсех");
	постоплаты= Макет.получитьобласть("постоплаты|Увсех");
	реализации = Макет.получитьобласть("реализации|Увсех");
	возвратысумма = Макет.получитьобласть("ВозвратыОплат|Увсех");
	Сертификаты = Макет.получитьобласть("Сертификаты|Увсех");
	ЗаказыМТМ = Макет.получитьобласть("ЗаказыМТМ|Увсех");
	предоплатыМТМ = Макет.получитьобласть("предоплатыМТМ|Увсех");
	реализацииМТМ = Макет.получитьобласть("реализацииМТМ|Увсех");
	ВозвратПС = Макет.получитьобласть("ВозвратПС|Увсех");
	
	Итогувсех = Макет.ПолучитьОбласть("Итого|Увсех");
	Итогсо = Макет.ПолучитьОбласть("Итого|со");
	Итогпс = Макет.ПолучитьОбласть("Итого|пс");
	Итогпред = Макет.ПолучитьОбласть("Итого|пред");
	Итогпост = Макет.ПолучитьОбласть("Итого|пост");	
	Итогбанк = Макет.ПолучитьОбласть("Итого|банк");
	Итогбанким = Макет.ПолучитьОбласть("Итого|банким");
	
	ИтогПодрувсех = Макет.ПолучитьОбласть("ИтогоПодр|Увсех");
	ИтогПодрсо = Макет.ПолучитьОбласть("ИтогоПодр|со");
	ИтогПодрпс = Макет.ПолучитьОбласть("ИтогоПодр|пс");
	ИтогПодрпред = Макет.ПолучитьОбласть("ИтогоПодр|пред");
	ИтогПодрпост = Макет.ПолучитьОбласть("ИтогоПодр|пост");	
	ИтогПодрбанк = Макет.ПолучитьОбласть("ИтогоПодр|банк");
	ИтогПодрбанким = Макет.ПолучитьОбласть("ИтогоПодр|банким");
	
	ИтогПодрувсех.параметры.итогколво = 0;
	ИтогПодрувсех.параметры.итогсумма = 0;
	ИтогПодрувсех.параметры.итогскидка = 0;
	ИтогПодрувсех.параметры.итогккм = 0;
	ИтогПодрувсех.параметры.итогкк = 0;
	ИтогПодрсо.параметры.итогсо = 0;
	ИтогПодрсо.параметры.итогсоруб = 0;
	ИтогПодрсо.параметры.итогсоевро = 0;
	ИтогПодрсо.параметры.итогсодоллар = 0;
	ИтогПодрпс.параметры.итогпс = 0;
	ИтогПодрпред.параметры.итогпред = 0;
	ИтогПодрпост.параметры.итогпост = 0;
	ИтогПодрувсех.параметры.итогколво = 0;
	ИтогПодрбанк.параметры.итогбанк1 = 0;
	ИтогПодрбанкИМ.параметры.итогбанк= 0;
	ИтогПодрбанкИМ.параметры.итогбанксчет= 0;
	ИтогПодрбанкИМ.параметры.итогбанконлайн= 0;
	ИтогПодрбанкИМ.параметры.итогбанкпони= 0;
	ИтогПодрбанкИМ.параметры.итогбанкпп= 0;
	ИтогПодрувсех.параметры.итогбонус = 0;
	
	
	#Область Чеки
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЧекККМ.Ссылка КАК Ссылка,
	|	ЧекККМ.Партнер КАК Партнер,
	|	ЧекККМ.СуммаДокумента КАК СуммаДокумента,
	|	0 КАК ПостОплата,
	|	ЧекККМ.ПолученоНаличными КАК ПолученоНаличными,
	|	ЧекККМ.Дата КАК Дата,
	|	ЧекККМ.Ссылка КАК ЧекККМОплата
	|ПОМЕСТИТЬ ЧекККМ
	|ИЗ
	|	Документ.ЧекККМ КАК ЧекККМ
	|ГДЕ
	|	ЧекККМ.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ЧекККМ.КассаККМ В(&КассаККМ)
	|	И ЧекККМ.Статус = &Статус
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМВозврат.Ссылка,
	|	ЧекККМВозврат.Партнер,
	|	-ЧекККМВозврат.СуммаДокумента,
	|	0,
	|	-ЧекККМВозврат.ВыданоНаличными,
	|	ЧекККМВозврат.Дата,
	|	ЧекККМВозврат.ЧекККМ
	|ИЗ
	|	Документ.ЧекККМВозврат КАК ЧекККМВозврат
	|ГДЕ
	|	ЧекККМВозврат.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ЧекККМВозврат.КассаККМ В(&КассаККМ)
	|	И ЧекККМВозврат.Статус = &Статус
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Дата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЧекККМТовары.Ссылка КАК Ссылка,
	|	СУММА(ЧекККМТовары.ПроцентРучнойСкидки + ЧекККМТовары.ПроцентАвтоматическойСкидки) КАК скидка,
	|	СУММА(ЧекККМТовары.Количество) КАК Количество,
	|	СУММА(ЧекККМТовары.СуммаБонусныхБалловКСписаниюВВалюте) КАК СуммаБонусныхБалловКСписанию
	|ПОМЕСТИТЬ Тов
	|ИЗ
	|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЧекККМ КАК ЧекККМ
	|		ПО ЧекККМТовары.Ссылка = ЧекККМ.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЧекККМТовары.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМВозвратТовары.Ссылка,
	|	0,
	|	СУММА(-ЧекККМВозвратТовары.Количество),
	|	СУММА(-ЧекККМВозвратТовары.СуммаБонусныхБалловКСписаниюВВалюте)
	|ИЗ
	|	Документ.ЧекККМВозврат.Товары КАК ЧекККМВозвратТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЧекККМ КАК ЧекККМ
	|		ПО ЧекККМВозвратТовары.Ссылка = ЧекККМ.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЧекККМВозвратТовары.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЧекККМПодарочныеСертификаты.Ссылка КАК Ссылка,
	|	СУММА(ЧекККМПодарочныеСертификаты.Сумма) КАК Сумма
	|ПОМЕСТИТЬ ПС
	|ИЗ
	|	Документ.ЧекККМ.ПодарочныеСертификаты КАК ЧекККМПодарочныеСертификаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЧекККМ КАК ЧекККМ
	|		ПО ЧекККМПодарочныеСертификаты.Ссылка = ЧекККМ.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЧекККМПодарочныеСертификаты.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМВозвратПодарочныеСертификаты.Ссылка,
	|	СУММА(-ЧекККМВозвратПодарочныеСертификаты.Сумма)
	|ИЗ
	|	Документ.ЧекККМВозврат.ПодарочныеСертификаты КАК ЧекККМВозвратПодарочныеСертификаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЧекККМ КАК ЧекККМ
	|		ПО ЧекККМВозвратПодарочныеСертификаты.Ссылка = ЧекККМ.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЧекККМВозвратПодарочныеСертификаты.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЧекККМОплатаПлатежнымиКартами.Ссылка КАК Ссылка,
	|	СУММА(ЧекККМОплатаПлатежнымиКартами.Сумма) КАК Сумма
	|ПОМЕСТИТЬ КК
	|ИЗ
	|	Документ.ЧекККМ.ОплатаПлатежнымиКартами КАК ЧекККМОплатаПлатежнымиКартами
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЧекККМ КАК ЧекККМ
	|		ПО ЧекККМОплатаПлатежнымиКартами.Ссылка = ЧекККМ.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЧекККМОплатаПлатежнымиКартами.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМВозвратПодарочныеСертификаты.Ссылка,
	|	СУММА(-ЧекККМВозвратПодарочныеСертификаты.Сумма)
	|ИЗ
	|	Документ.ЧекККМВозврат.ОплатаПлатежнымиКартами КАК ЧекККМВозвратПодарочныеСертификаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЧекККМ КАК ЧекККМ
	|		ПО ЧекККМВозвратПодарочныеСертификаты.Ссылка = ЧекККМ.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЧекККМВозвратПодарочныеСертификаты.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЧекККМВалютнаяОплата.Ссылка КАК Ссылка,
	|	СУММА(ЧекККМВалютнаяОплата.СуммаРуб) КАК СуммаРуб
