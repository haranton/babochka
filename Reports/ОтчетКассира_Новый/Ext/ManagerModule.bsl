КонецФункции

Функция ПолучитьЗапросВозвратПС(КассаККМ, КассыККМСО, НачалоПериода, КонецПериода, Подразделение)
	
	Запрос = Новый Запрос;
#Область ТекстЗапроса

    Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВозвратПодарочныхСертификатов.Ссылка КАК Ссылка,
		|	ВозвратПодарочныхСертификатов.Партнер КАК Партнер,
		|	ВозвратПодарочныхСертификатов.СуммаДокумента КАК СуммаДокумента,
		|	ВозвратПодарочныхСертификатов.Дата КАК Дата,
		|	ВозвратПодарочныхСертификатов.Валюта КАК Валюта,
		|	ЕСТЬNULL(СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Сумма, 0) КАК СуммаБезнал,
		|	СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка.ДатаПроведенияБанком КАК ДатаПроведенияБанком
		|ПОМЕСТИТЬ СписокВозвратов_БезналВУчетномПериоде
		|ИЗ
		|	Документ.ВозвратПодарочныхСертификатов КАК ВозвратПодарочныхСертификатов
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СписаниеБезналичныхДенежныхСредств.РасшифровкаПлатежа КАК СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа
		|		ПО ВозвратПодарочныхСертификатов.Ссылка = СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Заказ
		|			И (СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка.ДатаПроведенияБанком <= &КонецПериода)
		|			И (СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка.ДатаПроведенияБанком >= &НачалоПериода)
		|ГДЕ
		|	ВозвратПодарочныхСертификатов.Дата МЕЖДУ &НачалоПериода И &КонецПериода
		|	И ВозвратПодарочныхСертификатов.Подразделение В ИЕРАРХИИ(&Подразделение)
		|	И ВозвратПодарочныхСертификатов.Проведен
		|	И ВозвратПодарочныхСертификатов.Статус = &СтатусПробит
		|	И ВозвратПодарочныхСертификатов.КассаККМ В(&КассаККМ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Заказ КАК Заказ,
		|	СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Заказ.Партнер КАК ЗаказПартнер,
		|	0 КАК СуммаДокумента,
		|	СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Заказ.Дата КАК ЗаказДата,
		|	СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Заказ.Валюта КАК ЗаказВалюта,
		|	СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка.СуммаДокумента КАК СуммаБезнал,
		|	СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка.ДатаПроведенияБанком КАК ДатаПроведенияБанком
		|ПОМЕСТИТЬ СписокВозвратов_БезналНеВУчетномПериоде
		|ИЗ
		|	Документ.СписаниеБезналичныхДенежныхСредств.РасшифровкаПлатежа КАК СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа
		|		ЛЕВОЕ СОЕДИНЕНИЕ СписокВозвратов_БезналВУчетномПериоде КАК СписокРеализиций_БезналВУчетномПериоде
		|		ПО СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Заказ = СписокРеализиций_БезналВУчетномПериоде.Ссылка
		|ГДЕ
		|	СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка.ДатаПроведенияБанком МЕЖДУ &НачалоПериода И &КонецПериода
		|	И СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Заказ.КассаККМ.Подразделение В ИЕРАРХИИ(&Подразделение)
		|	И СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен
		|	И СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Заказ ССЫЛКА Документ.ВозвратПодарочныхСертификатов
		|	И СписаниеБезналичныхДенежныхСредствРасшифровкаПлатежа.Заказ.КассаККМ В(&КассаККМ)
		|	И СписокРеализиций_БезналВУчетномПериоде.Ссылка ЕСТЬ NULL
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СписокВозвратов_БезналВУчетномПериоде.Ссылка КАК Ссылка,
		|	СписокВозвратов_БезналВУчетномПериоде.Партнер КАК Партнер,
		|	СписокВозвратов_БезналВУчетномПериоде.СуммаДокумента КАК СуммаДокумента,
		|	СписокВозвратов_БезналВУчетномПериоде.Дата КАК Дата,
		|	СписокВозвратов_БезналВУчетномПериоде.Валюта КАК Валюта,
		|	СписокВозвратов_БезналВУчетномПериоде.СуммаБезнал КАК СуммаБезнал,
		|	СписокВозвратов_БезналВУчетномПериоде.ДатаПроведенияБанком КАК ДатаПроведенияБанком
		|ПОМЕСТИТЬ СписокВозвратов
		|ИЗ
		|	СписокВозвратов_БезналВУчетномПериоде КАК СписокВозвратов_БезналВУчетномПериоде
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СписокВозвратов_БезналНеВУчетномПериоде.Заказ,
		|	СписокВозвратов_БезналНеВУчетномПериоде.ЗаказПартнер,
		|	0,
		|	СписокВозвратов_БезналНеВУчетномПериоде.ЗаказДата,
		|	СписокВозвратов_БезналНеВУчетномПериоде.ЗаказВалюта,
		|	СписокВозвратов_БезналНеВУчетномПериоде.СуммаБезнал,
		|	СписокВозвратов_БезналНеВУчетномПериоде.ДатаПроведенияБанком
		|ИЗ
		|	СписокВозвратов_БезналНеВУчетномПериоде КАК СписокВозвратов_БезналНеВУчетномПериоде
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВозвратПодарочныхСертификатовПодарочныеСертификаты.ПодарочныйСертификат.Наименование КАК ПодарочныйСертификатНаименование,
		|	ВозвратПодарочныхСертификатовПодарочныеСертификаты.ПодарочныйСертификат КАК ПодарочныйСертификат,
		|	ВозвратПодарочныхСертификатовПодарочныеСертификаты.Сумма КАК Сумма,
		|	СписокВозвратов.Ссылка КАК Ссылка
		|ИЗ
		|	СписокВозвратов КАК СписокВозвратов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВозвратПодарочныхСертификатов.ПодарочныеСертификаты КАК ВозвратПодарочныхСертификатовПодарочныеСертификаты
		|		ПО СписокВозвратов.Ссылка = ВозвратПодарочныхСертификатовПодарочныеСертификаты.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СписокВозвратов.Ссылка КАК Ссылка,
		|	СписокВозвратов.Партнер КАК Партнер,
		|	СписокВозвратов.СуммаДокумента КАК СуммаДокумента,
		|	СписокВозвратов.Дата КАК Дата,
		|	СписокВозвратов.Валюта КАК Валюта,
		|	СписокВозвратов.СуммаБезнал КАК СуммаБезнал,
		|	СписокВозвратов.Ссылка.ВыданоНаличными КАК ВыданоНаличными,
		|	СписокВозвратов.ДатаПроведенияБанком КАК ДатаПроведенияБанком
		|ИЗ
		|	СписокВозвратов КАК СписокВозвратов";
#КонецОбласти	

    Запрос.УстановитьПараметр("КассаККМ", 			КассаККМ);
	Запрос.УстановитьПараметр("КассыККМСО", 		КассыККМСО);
	Запрос.УстановитьПараметр("КонецПериода", 		КонецДня(КонецПериода));
	Запрос.УстановитьПараметр("НачалоПериода", 		НачалоПериода);
	Запрос.УстановитьПараметр("Подразделение", 		Подразделение);
	Запрос.УстановитьПараметр("ТипОплатыPayPal", 	Перечисления.ТипОплатыИМ.ОнлайнPayPal);
	Запрос.УстановитьПараметр("ТипОплатыПони", 		Перечисления.ТипОплатыИМ.Пони);
	Запрос.УстановитьПараметр("ТипОплатыСчет", 		Перечисления.ТипОплатыИМ.Счет);
	Запрос.УстановитьПараметр("СтатусПробит", 		Перечисления.СтатусыЧековККМ.Пробит);
	ЭквайринговыйТерминал = Новый Массив;
	ЭквайринговыйТерминал.Добавить(Справочники.ЭквайринговыеТерминалы.НайтиПоКоду("online"));
	ЭквайринговыйТерминал.Добавить(Справочники.ЭквайринговыеТерминалы.НайтиПоКоду("babochka.ru"));
	ЭквайринговыйТерминал.Добавить(Справочники.ЭквайринговыеТерминалы.НайтиПоКоду("ИМБарниус"));
	
	Запрос.УстановитьПараметр("ЭквайринговыйТерминалOnline", ЭквайринговыйТерминал);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Возврат РезультатЗапроса;
		
КонецФункции
