		|	ИтогОплаты.ПС КАК ПС,
		|	ИтогОплаты.ККОнлайн КАК ККОнлайн,
		|	ИтогОплаты.КК КАК КК,
		|	ИтогОплаты.ККМ КАК ККМ,
		|	ИтогОплаты.СОруб КАК СОруб,
		|	ИтогОплаты.СОевро КАК СОевро,
		|	ИтогОплаты.СОдоллар КАК СОдоллар,
		|	ИтогОплаты.Банк КАК Банк,
		|	ИтогОплаты.БанкСчет КАК БанкСчет,
		|	ИтогОплаты.БанкПони КАК БанкПони,
		|	ИтогОплаты.БанкПП КАК БанкПП,
		|	ИтогОплаты.Клиент КАК Клиент,
		|	ИтогОплаты.Партнер КАК Партнер,
		|	ИтогОплаты.Дата КАК Дата,
		|	ИтогОплаты.РеализацияСсылка КАК РеализацияСсылка
		|ИЗ
		|	ИтогОплаты КАК ИтогОплаты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ИтогОплаты.СуммаДокумента) КАК СуммаДокумента,
		|	СУММА(ИтогОплаты.СуммаДокументаРубли) КАК ИтогСумма,
		|	СУММА(ИтогОплаты.СуммаИтого) КАК СуммаИтого,
		|	СУММА(ИтогОплаты.СуммаОплат) КАК СуммаОплат,
		|	СУММА(ИтогОплаты.КоличествоИтого) КАК ИтогКолво,
		|	СУММА(ИтогОплаты.Пред) КАК ИтогПред,
		|	СУММА(ИтогОплаты.Пост) КАК ИтогПост,
		|	СУММА(ИтогОплаты.ПС) КАК ИтогПС,
		|	СУММА(ИтогОплаты.ККОнлайн) КАК ИтогККОнлайн,
		|	СУММА(ИтогОплаты.КК) КАК ИтогКК,
		|	СУММА(ИтогОплаты.ККМ) КАК ИтогКкм,
		|	СУММА(ИтогОплаты.СОруб) КАК ИтогСОруб,
		|	СУММА(ИтогОплаты.СОевро) КАК ИтогСОевро,
		|	СУММА(ИтогОплаты.СОдоллар) КАК ИтогСОдоллар,
		|	СУММА(ИтогОплаты.Банк) КАК ИтогБанк,
		|	СУММА(ИтогОплаты.БанкСчет) КАК ИтогБанкСчет,
		|	СУММА(ИтогОплаты.БанкПони) КАК ИтогБанкПони,
		|	СУММА(ИтогОплаты.БанкПП) КАК ИтогБанкПП,
		|	0 КАК ИтогСкидка,
		|	СУММА(ИтогОплаты.СОВРуб) КАК СОВРуб,
		|	СУММА(ИтогОплаты.СОруб + ИтогОплаты.СОВРуб) КАК ИтогСО
		|ИЗ
		|	ИтогОплаты КАК ИтогОплаты";
#КонецОбласти	

    ВалютаEUR = Справочники.Валюты.НайтиПоКоду("978");
	ВалютаUSD = Справочники.Валюты.НайтиПоКоду("840");
	ВалютаРуб = Справочники.Валюты.НайтиПоКоду("643");
	
