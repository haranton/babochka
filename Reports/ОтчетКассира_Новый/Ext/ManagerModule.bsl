	|	Дата";
	
	//ЗАпрос.УстановитьПараметр("Склад", Подразделение);
	Запрос.УстановитьПараметр("КассаККМ", КассыККМ);
	Запрос.УстановитьПараметр("НачалоПериода", началодня(НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода", конецдня(конецпериода));
	Запрос.УстановитьПараметр("Статус", перечисления.СтатусыЧековККМ.Пробит);
	Запрос.УстановитьПараметр("ВалютаДоллар", справочники.Валюты.НайтиПоКоду("840"));
	Запрос.УстановитьПараметр("Валютаевро", справочники.Валюты.НайтиПоКоду("978"));
	Запрос.УстановитьПараметр("Валютаруб", справочники.Валюты.НайтиПоКоду("643"));
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	чеки 		= ПакетЗапросов[ПакетЗапросов.ВГраница()].Выбрать();
	детали  	= ПакетЗапросов[ПакетЗапросов.ВГраница()-1].Выбрать();
	чекисуммы  	= ПакетЗапросов[ПакетЗапросов.ВГраница()-2].Выбрать();
	
	Табдок.Вывести(Продажи,1);
	Итогувсех.параметры.итогколво = 0;
	Итогувсех.параметры.итогсумма = 0;
	Итогувсех.параметры.итогскидка = 0;
	Итогувсех.параметры.итогккм = 0;
	Итогувсех.параметры.итогкк = 0;
	Итогсо.параметры.итогсо = 0;
	Итогсо.параметры.итогсоруб = 0;
	Итогсо.параметры.итогсоевро = 0;
	Итогсо.параметры.итогсодоллар = 0;
	Итогпс.параметры.итогпс = 0;
	Итогпред.параметры.итогпред = 0;
	Итогпост.параметры.итогпост = 0;
	Итогувсех.параметры.итогколво = 0;
	Итогбанк.параметры.итогбанк1 = 0;
	ИтогбанкИМ.параметры.итогбанк= 0;
	ИтогбанкИМ.параметры.итогбанксчет= 0;
	ИтогбанкИМ.параметры.итогбанконлайн= 0;
	ИтогбанкИМ.параметры.итогбанкпони= 0;
	ИтогбанкИМ.параметры.итогбанкпп= 0;
	Итогувсех.параметры.итогбонус = 0;
	
	пока чеки.Следующий() цикл
		СтрокаДокументувсех.параметры.документ = чеки.ссылка;//чеки.ссылка;
		СтрокаДокументувсех.параметры.Расшифровка1 = чеки.ссылка;
		СтрокаДокументувсех.параметры.Клиент = чеки.Партнер;
		СтрокаДокументувсех.параметры.сумма = чеки.суммадокумента;
		    сдачасо = ?(чеки.ПолученоНаличными = 0,чеки.ссылка.СуммаДокумента - чеки.ссылка.ВалютнаяОплата.Итог("СуммаРуб")-чеки.ссылка.ОплатаПлатежнымиКартами.Итог("Сумма")-чеки.ссылка.ПодарочныеСертификаты.Итог("Сумма"),0);
			СтрокаДокументувсех.параметры.ккм = чеки.ПолученоНаличными - (чеки.ссылка.ОплатаПлатежнымиКартами.Итог("Сумма") + чеки.ссылка.ПодарочныеСертификаты.Итог("Сумма") 
				+ ?(чеки.ПолученоНаличными < 0, -чеки.ПолученоНаличными, чеки.ПолученоНаличными) + чеки.ссылка.ВалютнаяОплата.Итог("СуммаРуб") - чеки.ссылка.СуммаДокумента)-сдачаСО;
						
		
		Итогувсех.параметры.итогсумма = Итогувсех.параметры.итогсумма + чеки.суммадокумента;
		Итогувсех.параметры.итогккм = Итогувсех.параметры.итогккм + СтрокаДокументувсех.параметры.ккм;
		
		чекисуммы.Сбросить();
		Если чекисуммы.НайтиСледующий(Новый Структура("Ссылка", чеки.ссылка)) тогда
			
			СтрокаДокументувсех.параметры.колво = чекисуммы.количество;
			СтрокаДокументувсех.параметры.кк = чекисуммы.СуммаЭТ;
			СтрокаДокументувсех.параметры.бонус = чекисуммы.СуммаБонусныхБалловКСписанию;
			СтрокаДокументсо.параметры.соруб = ?(сдачасо <>0, строка(чекисуммы.СуммаСОруб+сдачасо) +" (сдача "+ строка(сдачасо)+")", чекисуммы.СуммаСОруб);
			СтрокаДокументсо.параметры.соевро = чекисуммы.СуммаВалЕвро;
			СтрокаДокументсо.параметры.содоллар = чекисуммы.СуммаВалДоллар;
			
			СтрокаДокументпс.параметры.пс = чекисуммы.СуммаПС;
			СтрокаДокументпред.параметры.пред = 0;
			
			СтрокаДокументбанк.параметры.банк1 = 0;
			СтрокаДокументбанким.параметры.банксчет = 0;
			СтрокаДокументбанким.параметры.банконлайн = 0;
			СтрокаДокументбанким.параметры.банкпони = 0;
			СтрокаДокументбанким.параметры.банкпп = 0;
		
			Итогувсех.параметры.итогбонус = Итогувсех.параметры.итогбонус + СтрокаДокументувсех.параметры.бонус;
			Итогувсех.параметры.итогкк = Итогувсех.параметры.итогкк + СтрокаДокументувсех.параметры.кк;
			Итогсо.параметры.итогсоруб = Итогсо.параметры.итогсоруб + чекисуммы.СуммаСОруб+сдачасо;
			Итогсо.параметры.итогсоевро = Итогсо.параметры.итогсоевро + СтрокаДокументсо.параметры.соевро;
			Итогсо.параметры.итогсодоллар = Итогсо.параметры.итогсодоллар + СтрокаДокументсо.параметры.содоллар;
			Итогсо.параметры.итогсо = Итогсо.параметры.итогсо + чекисуммы.СуммаСОруб+сдачасо + чекисуммы.СуммаСОевро + чекисуммы.СуммаСОдоллар;
			Итогпс.параметры.итогпс = Итогпс.параметры.итогпс + СтрокаДокументпс.параметры.пс;
			Итогпред.параметры.итогпред = Итогпред.параметры.итогпред + СтрокаДокументпред.параметры.пред;
			Итогувсех.параметры.итогколво = Итогувсех.параметры.итогколво + чекисуммы.количество;
		конецесли;
		Табдок.Вывести(СтрокаДокументувсех,2);
		если ПС тогда
			Табдок.Присоединить(СтрокаДокументпс);
		конецесли;
		если со тогда	
			Табдок.Присоединить(СтрокаДокументсо);
		конецесли;
		если Предоплата тогда
			Табдок.Присоединить(СтрокаДокументпред);
		конецесли;
		если Постоплата тогда
			Табдок.Присоединить(СтрокаДокументпост);
		конецесли;
		если банк тогда
			Табдок.Присоединить(СтрокаДокументбанк);
		конецесли;
		если банким тогда
			Табдок.Присоединить(СтрокаДокументбанким);
		конецесли;
		детали.Сбросить();
		пока детали.НайтиСледующий(Новый Структура("Ссылка", чеки.ссылка)) цикл
