 
Функция ЗаполнитьХарактеристики(ХарактеристикиДанныеДляСоздания, ИндексНачала, РазмерПорции, Характеристики, ЗагружатьТолькоНовыеОбъекты) Экспорт 
	
	Для Сч = 1 По РазмерПорции Цикл
		
		Индекс = ?(Сч=1,ИндексНачала,Индекс+1);
		
		НоменклатураСсылка = НайтиОбъектПоGUID(ХарактеристикиДанныеДляСоздания[Индекс].НоменклатураСсылка, "Номенклатура");
		Если НЕ ЗначениеЗаполнено(НоменклатураСсылка) Тогда 
			Возврат Неопределено;
		КонецЕсли;
		
		НовыйGUID = Новый УникальныйИдентификатор(ХарактеристикиДанныеДляСоздания[Индекс].Ссылка); 	
		ЭлементСсылка = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(НовыйGUID);
		
		Отбор = Новый Структура("Ссылка", ХарактеристикиДанныеДляСоздания[Индекс].Ссылка); 
		СтрСсылочныхДанных = Характеристики.НайтиСтроки(Отбор); 
		
		Если ЗначениеЗаполнено(ЭлементСсылка.ВерсияДанных) И ЗагружатьТолькоНовыеОбъекты Тогда 
			Продолжить;
		ИначеЕсли ЗначениеЗаполнено(ЭлементСсылка.ВерсияДанных) Тогда
			ЭлементОбъект = ЭлементСсылка.ПолучитьОбъект();
		Иначе                                                     		
			ЭлементОбъект = Справочники.ХарактеристикиНоменклатуры.СоздатьЭлемент();
			ЭлементОбъект.УстановитьСсылкуНового(ЭлементСсылка);  	
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ЭлементОбъект, ХарактеристикиДанныеДляСоздания[Индекс], "ПометкаУдаления,Код,ШтрихкодПроизводителя,
		|Наименование,НаименованиеПолное,ГуидИз10,ID_MarketPlace,ВыгружатьВИМ_MarketPlace,Предзаказ,
		|КоличествоДнейНаИзготовление,ДопХарактеристика"); 
		
		Если ЗначениеЗаполнено(ХарактеристикиДанныеДляСоздания[Индекс].ЦветКод) Тогда
			Если ЗначениеЗаполнено(СтрСсылочныхДанных[0].ЦветКод_ссылка) Тогда
				ЭлементОбъект.Цвет = СтрСсылочныхДанных[0].ЦветКод_ссылка;
			Иначе
				СообщитьНеНайденСсылочныйТип("ЦветКод", ХарактеристикиДанныеДляСоздания[Индекс].ЦветКод);
			КонецЕсли; 
		КонецЕсли;  
		Если ЗначениеЗаполнено(ХарактеристикиДанныеДляСоздания[Индекс].КодТНВЭД) Тогда  
			Если ЗначениеЗаполнено(СтрСсылочныхДанных[0].КодТНВЭД_ссылка) Тогда
				ЭлементОбъект.КодТНВЭД = СтрСсылочныхДанных[0].КодТНВЭД_ссылка;
			Иначе
				СообщитьНеНайденСсылочныйТип("КодТНВЭД", ХарактеристикиДанныеДляСоздания[Индекс].КодТНВЭД);
			КонецЕсли; 
		КонецЕсли;
		ЭлементОбъект.Владелец = НоменклатураСсылка;
		ЭлементОбъект.Размер = НайтиОбъектПоGUID(ХарактеристикиДанныеДляСоздания[Индекс].Размер, "РазмернаяСеткаБабочка");	
		ЭлементОбъект.КодЦвета = НайтиОбъектПоGUID(ХарактеристикиДанныеДляСоздания[Индекс].КодЦвета, "КодыЦветовБабочка");	
		
		ЭлементОбъект.Записать();   		
		
		Если ХарактеристикиДанныеДляСоздания[Индекс].Штрихкоды <> Неопределено Тогда 
			
			Если ТипЗнч(ХарактеристикиДанныеДляСоздания[Индекс].Штрихкоды) = Тип("Массив") Тогда
				Для каждого Штрихкод Из ХарактеристикиДанныеДляСоздания[Индекс].Штрихкоды Цикл
					ЗаполнитьШтрихкод(Штрихкод, НоменклатураСсылка, ЭлементОбъект.Ссылка);		
				КонецЦикла;	
				
			Иначе
				ЗаполнитьШтрихкод(ХарактеристикиДанныеДляСоздания[Индекс].Штрихкоды, НоменклатураСсылка, ЭлементОбъект.Ссылка);	
			КонецЕсли;
			
		КонецЕсли;  
		
	КонецЦикла;
	
КонецФункции  


Функция НайтиОбъектПоGUID(GUID, ТипМетаданных)
	
	Если GUID = ""
		ИЛИ GUID = "00000000-0000-0000-0000-000000000000" 
		ИЛИ GUID = Неопределено ИЛИ СтрДлина(GUID) <> 36  Тогда
		
		Возврат Справочники[ТипМетаданных].ПустаяСсылка();	
		
	КонецЕсли;
	
	НовыйGUID = Новый УникальныйИдентификатор(GUID); 	
	ОбъектСсылка = Справочники[ТипМетаданных].ПолучитьСсылку(НовыйGUID);
	
	Если ЗначениеЗаполнено(ОбъектСсылка.ВерсияДанных) Тогда
		Возврат ОбъектСсылка;
	Иначе
		Сообщить(СтрШаблон("Не найден тип объекта %1 с гуидом %2", ТипМетаданных, GUID));
		Возврат Справочники[ТипМетаданных].ПустаяСсылка();	
	КонецЕсли;
	
КонецФункции 

Функция ЗаполнитьШтрихкод(Штрихкод, Номенклатура, Характеристика)
	
	Если НЕ ЗначениеЗаполнено(Штрихкод) Тогда
		Возврат 0;	
	КонецЕсли; 
	
	//используем Набор, чтобы не регистрировать к обмену
	Набор = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьНаборЗаписей();
	Набор.Отбор.Штрихкод.Установить(Штрихкод);  
	Набор.Прочитать();
	
	Если Набор.Количество() Тогда
		Для каждого СтрокаРС Из Набор Цикл
			СтрокаРС.Номенклатура = Номенклатура; 
			СтрокаРС.Характеристика = Характеристика;
		КонецЦикла;
	Иначе
		Запись = Набор.Добавить();
		Запись.Номенклатура = Номенклатура; 
		Запись.Характеристика = Характеристика;
		Запись.Штрихкод = Штрихкод; 
	КонецЕсли;  
	
	Набор.ОбменДанными.Получатели.АвтоЗаполнение = Ложь;
	Набор.Записать();
	
КонецФункции  

Процедура СообщитьНеНайденСсылочныйТип(ТипДанных, гуид) 
	Сообщить(СтрШаблон("Не найден объект с типо данных %1 по наименованию %2", ТипДанных, гуид));
КонецПроцедуры



