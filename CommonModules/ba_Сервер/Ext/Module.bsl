Процедура ЗагрузитьПорциюЦенВРегистр(ТаблицаЦен, ИндексНачала, РазмерПорции, ДатаПериода, ДокСсылка) Экспорт
	
	НаборЗаписей = РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Регистратор.Установить(ДокСсылка);
	
	Для Сч = 1 По РазмерПорции Цикл

        Индекс = ?(Сч=1, ИндексНачала, Индекс+1);
		
		Запись = НаборЗаписей.Добавить();
		Запись.Период = ДатаПериода;
		ЗаполнитьЗначенияСвойств(Запись, ТаблицаЦен[Индекс], "Номенклатура, Характеристика, ВидЦены, Цена, Валюта, Упаковка");
	КонецЦикла;  
	
	ИмяСобытия = "Загрузка цен в потоке";
	Попытка
		НаборЗаписей.Записать(Ложь);
	Исключение  
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(ИмяСобытия,
		УровеньЖурналаРегистрации.Ошибка, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()),,Истина);
		ВызватьИсключение
		"Ошибка в потоке. ИндексНачала=" + ИндексНачала
		+ ", РазмерПорции=" + РазмерПорции
		+ ", Текст=" + ОписаниеОшибки();	
	КонецПопытки;
	
КонецПроцедуры




