Процедура ПереписатьДокументыПоSS18ПриЗаписи(Источник, Отказ) Экспорт
	
	Попытка
		ИспользоватьОбработкуПоПерезаписиПредЗаказовПоSS18 = Бабочка.ПолучитьЗначениеДинамическихНастроек("ИспользоватьОбработкуПоПерезаписиПредЗаказовПоSS18", Истина);
		Если ВРег(Источник.Коллекция) = "SS18" 
			И ВРег(Источник.Партнер) <> ВРег("Поставщик для 10.3") 
			И ИспользоватьОбработкуПоПерезаписиПредЗаказовПоSS18 Тогда
			
			НовыеПараметры = Новый Структура("ВалютаВзаиморасчетов, Партнер, Контрагент, Соглашение, Договор, Организация, Валюта, ПорядокРасчетов", Источник.Валюта);
			
			ЗаполнитьЗначенияСвойств(НовыеПараметры, Источник);
			
			МассивСсылок = КритерииОтбора.СвязанныеДокументы.Найти(Источник.Ссылка);
			
			Если ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.ЗаказПоставщику") 
				И ЗначениеЗаполнено(Источник.ПредварительныйЗаказ) Тогда
				МассивСсылок.Добавить(Источник.ПредварительныйЗаказ);
			Конецесли;
			
			Для Каждого Документссылка ИЗ МассивСсылок Цикл
				
				Если ТипЗнч(Документссылка) = Тип("ДокументСсылка.ЗаказПоставщику")  Тогда
					
					МассивСсылок2 = КритерииОтбора.СвязанныеДокументы.Найти(Документссылка);
					
					Для Каждого ПоступлениеСсылка ИЗ МассивСсылок2 Цикл
						МассивСсылок.Добавить(ПоступлениеСсылка);
					КонецЦикла;
					
				Конецесли;
				
			КонецЦикла;				
			
			Для Каждого Документссылка ИЗ МассивСсылок Цикл
				
				ПартнерДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Документссылка, "Партнер");
				
				Если ПартнерДокумента = Источник.Партнер Тогда
					Продолжить;
				КонецЕсли;
				
				ДокументОбъект = Документссылка.ПолучитьОбъект();
				
				ЗаполнитьЗначенияСвойств(ДокументОбъект, НовыеПараметры);
				
				Если ДокументОбъект.Проведен Тогда
					ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
				Иначе
					ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	Исключение
		Отказ = Истина;
	КонецПопытки;
	
КонецПроцедуры


Процедура ПересчитатьСуммуДокументаОтмененоПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос("
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.СуммаСНДС КАК СуммаСНДС,
	|	Товары.Отменено КАК Отменено
	|ПОМЕСТИТЬ
	|	Товары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(Товары.СуммаСНДС),0) КАК СуммаСНДС
	|ИЗ
	|	Товары КАК Товары
	|ГДЕ
	|	Товары.Отменено
	|");
	
	Запрос.УстановитьПараметр("Товары", Источник.Товары.Выгрузить(,"Номенклатура,СуммаСНДС,Отменено"));
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	СуммаЗаказанныхСтрокОтменено = Выгрузка[0].СуммаСНДС;
	Источник.СуммаДокументаОтменено = СуммаЗаказанныхСтрокОтменено;
	
КонецПроцедуры

Функция УчетПоТоварнымКатегориям(Партнер, Соглашение, ХозяйственнаяОперация=Неопределено) Экспорт
	
	УчетПоТоварнымКатегориям = Ложь;
	
	Попытка
	
		Если ЗначениеЗаполнено(Соглашение) Тогда
			УчетПоТоварнымКатегориям = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Соглашение, "УчетПоТоварнымКатегориям")=Истина;
		Иначе
			УчетПоТоварнымКатегориям = Строка(Партнер) = "Поставщик для 10.3"
										И ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаПоИмпорту;
		КонецЕсли;
		
	Исключение
		Возврат Ложь;
	Конецпопытки;
	
	Возврат УчетПоТоварнымКатегориям=Истина;
	
КонецФункции

Процедура ЗаписатьСостояниеЗаявкиПриЗаписи(Источник, Отказ) Экспорт
	
	МассивЗаявок 	= Новый Массив;
	УдалятьДвижения = Ложь;
	
	Если ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.ЗаявкаНаРасходованиеДенежныхСредств") Тогда
		УдалятьДвижения = НЕ Источник.Проведен;
		МассивЗаявок.Добавить(Источник.Ссылка);
	КонецЕсли;
	
	Если ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") 
		И ЗначениеЗаполнено(Источник.ЗаявкаНаРасходованиеДенежныхСредств) Тогда
		МассивЗаявок.Добавить(Источник.ЗаявкаНаРасходованиеДенежныхСредств);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Попытка
		РегистрыСведений.СостоянияЗаявокНаРасходованиеСредств.ОтразитьСостояниеЗаявки(МассивЗаявок, Отказ, УдалятьДвижения);
	Исключение
		Отказ = Истина;
	КонецПопытки;
	
КонецПроцедуры

Функция РазложитьТоварыПоКатегориямЗаказПоставщику(Товары, ЧастьКоллекции=Неопределено)
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	Товары.Отменено КАК Отменено,
	|	ВЫРАЗИТЬ(Товары.ЗаказПоставщику КАК Документ.ЗаказПоставщику) КАК ЗаказПоставщику,
	|	ВЫРАЗИТЬ(Товары.ПредварительныйЗаказ КАК Документ.ПредварительныйЗаказ) КАК ПредварительныйЗаказ,
	|	Товары.Сумма КАК Сумма,
	|	Товары.Количество КАК Количество,
	|	Товары.СуммаИнвойс КАК СуммаИнвойс
	|ПОМЕСТИТЬ Товары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура.ТоварнаяКатегория КАК ТоварнаяКатегория,
	|	Товары.ПредварительныйЗаказ КАК ПредварительныйЗаказ,
	|	СУММА(Товары.Сумма) КАК Сумма,
	|	СУММА(Товары.Количество) КАК КоличествоТоваров,
	|	СУММА(Товары.СуммаИнвойс) КАК СуммаИнвойсТовары
	|ИЗ
	|	Товары КАК Товары
	|ГДЕ
	|	НЕ Товары.Отменено
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура.ТоварнаяКатегория,
	|	Товары.ПредварительныйЗаказ
	|ИТОГИ
	|	СУММА(Сумма),
	|	СУММА(КоличествоТоваров),
	|	СУММА(СуммаИнвойсТовары)
	|ПО
	|	ПредварительныйЗаказ,
	|	ТоварнаяКатегория ИЕРАРХИЯ";
	
	ТаблицаТоваров = Товары.Выгрузить();
	
	Если ТаблицаТоваров.Колонки.Найти("Отменено")=Неопределено Тогда
		ТаблицаТоваров.Колонки.Добавить("Отменено", Новый ОписаниеТипов("Булево"));
	КонецЕсли;
	
	Если ТаблицаТоваров.Колонки.Найти("ЗаказПоставщику")=Неопределено Тогда
		ТаблицаТоваров.Колонки.Добавить("ЗаказПоставщику", Новый ОписаниеТипов("ДокументСсылка.ЗаказПоставщику"));
	КонецЕсли;
	
	Если ТаблицаТоваров.Колонки.Найти("ПредварительныйЗаказ")=Неопределено Тогда
		ТаблицаТоваров.Колонки.Добавить("ПредварительныйЗаказ", Новый ОписаниеТипов("ДокументСсылка.ПредварительныйЗаказ"));
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ЧастьКоллекции", ?(ЧастьКоллекции=Неопределено, Перечисления.ЧастьКоллекции.ПустаяСсылка(), ЧастьКоллекции));
	Запрос.УстановитьПараметр("Товары", ТаблицаТоваров);
	
	ТаблицаКатегорий = Запрос.Выполнить().Выгрузить(); //для колонок
	ТаблицаКатегорий.Очистить();
	
	ВыборкаТоварнаяКатегория = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаТоварнаяКатегория.Следующий() Цикл
		
		ВыборкаПредварительныйЗаказ = ВыборкаТоварнаяКатегория.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
		Пока ВыборкаПредварительныйЗаказ.Следующий() Цикл
			строкаТЗ = ТаблицаКатегорий.Добавить();
			ЗаполнитьЗначенияСвойств(строкаТЗ,ВыборкаПредварительныйЗаказ);		
		КонецЦикла; 
		
	КонецЦикла;


	Если ЧастьКоллекции<>Неопределено Тогда
		ТаблицаКатегорий.Колонки.Добавить("ЧастьКоллекции", Новый ОписаниеТипов("ПеречислениеСсылка.ЧастьКоллекции"));
		ТаблицаКатегорий.ЗаполнитьЗначения(ЧастьКоллекции, "ЧастьКоллекции");
	КонецЕсли;
	
	
	Возврат ТаблицаКатегорий;
	
КонецФункции

#Область Проведение

Функция ПараметрыДляПроведенияДокумента(Документ, Свойства) Экспорт

	Параметры = ПроведениеДокументов.ПараметрыУчетногоМеханизма();

	Если Свойства.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		Параметры.ПодчиненныеРегистры.Добавить(Метаданные.РегистрыНакопления.ПреварительныеЗаказы);
		Параметры.ПодчиненныеРегистры.Добавить(Метаданные.РегистрыНакопления.ЗаказыПоставщикамТоварныеКатегории);
		Параметры.ПодчиненныеРегистры.Добавить(Метаданные.РегистрыНакопления.ПреварительныеЗаказыТоварныеКатегории);

	КонецЕсли;

	Возврат Параметры;

КонецФункции

Функция ТекстыЗапросовСторнирования(МетаданныеДокумента) Экспорт

	ТекстыЗапросов = Новый Соответствие();
	ДвиженияДокумента = МетаданныеДокумента.Движения;

	МетаданныеРегистра = Метаданные.РегистрыНакопления.ПреварительныеЗаказы;
	Если ДвиженияДокумента.Содержит(МетаданныеРегистра) Тогда
		ТекстыЗапросов.Вставить(МетаданныеРегистра.ПолноеИмя(),
			ПроведениеДокументов.ТекстСторнирующегоЗапроса(МетаданныеРегистра, МетаданныеДокумента));
	КонецЕсли;

	МетаданныеРегистра = Метаданные.РегистрыНакопления.ПреварительныеЗаказыТоварныеКатегории;
	Если ДвиженияДокумента.Содержит(МетаданныеРегистра) Тогда
		ТекстыЗапросов.Вставить(МетаданныеРегистра.ПолноеИмя(),
			ПроведениеДокументов.ТекстСторнирующегоЗапроса(МетаданныеРегистра, МетаданныеДокумента));
		КонецЕсли;
		
	МетаданныеРегистра = Метаданные.РегистрыНакопления.ЗаказыПоставщикамТоварныеКатегории;
	Если ДвиженияДокумента.Содержит(МетаданныеРегистра) Тогда
		ТекстыЗапросов.Вставить(МетаданныеРегистра.ПолноеИмя(),
			ПроведениеДокументов.ТекстСторнирующегоЗапроса(МетаданныеРегистра, МетаданныеДокумента));
	КонецЕсли;


	Возврат ТекстыЗапросов;

КонецФункции

Процедура ОтразитьДвижения(ТаблицыДляДвижений, Движения, Отказ) Экспорт

	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	ПроведениеДокументов.ОтразитьДвижения(ТаблицыДляДвижений, Движения, "ПреварительныеЗаказы");
	ПроведениеДокументов.ОтразитьДвижения(ТаблицыДляДвижений, Движения, "ЗаказыПоставщикамТоварныеКатегории");
	ПроведениеДокументов.ОтразитьДвижения(ТаблицыДляДвижений, Движения, "ПреварительныеЗаказыТоварныеКатегории");

КонецПроцедуры 

Функция ТекстыЗапросовКонтрольДатыЗапретаПоТаблицеИзменений(Запрос) Экспорт

	СоответствиеТекстовЗапросов = Новый Соответствие();
	Возврат СоответствиеТекстовЗапросов;
	
КонецФункции


#КонецОбласти
