Процедура СоздатьПоступлениеПоПроформеОбработкаЗаполнения(Источник, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка) Экспорт
	
	Если ТипЗнч(ДанныеЗаполнения)=Тип("ДокументСсылка.ЗаявкаНаРасходованиеДенежныхСредств") Тогда
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = 
		
		"ВЫБРАТЬ
		|	ЗаказПоставщику.Ссылка КАК Ссылка,
		|	ЗаказПоставщику.Дата КАК Дата,
		|	ЗаказПоставщику.ЧастьКоллекции КАК ЧастьКоллекции
		|ПОМЕСТИТЬ ЗаказПоставщику
		|ИЗ
		|	Документ.ЗаявкаНаРасходованиеДенежныхСредств.РасшифровкаПлатежа КАК ЗаказПоставщикуТоварныеКатегории
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику КАК ЗаказПоставщику
		|		ПО ЗаказПоставщикуТоварныеКатегории.Заказ = ЗаказПоставщику.Договор
		|ГДЕ
		|	ЗаказПоставщикуТоварныеКатегории.Ссылка = &ДанныеЗаполнения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказПоставщикуТоварныеКатегории.ТоварнаяКатегория КАК ТоварнаяКатегория,
		|	ЗаказПоставщику.ЧастьКоллекции КАК ЧастьКоллекции,
		|	ЗаказПоставщикуТоварныеКатегории.Пол КАК Пол,
		|	ЗаказПоставщикуТоварныеКатегории.Ссылка КАК Ссылка,
		|	ЗаказПоставщику.Дата КАК Дата
		|ПОМЕСТИТЬ Заказы
		|ИЗ
		|	Документ.ЗаказПоставщику.ТоварныеКатегории КАК ЗаказПоставщикуТоварныеКатегории
		|		ЛЕВОЕ СОЕДИНЕНИЕ ЗаказПоставщику КАК ЗаказПоставщику
		|		ПО ЗаказПоставщикуТоварныеКатегории.Ссылка = ЗаказПоставщику.Ссылка
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ЧастьКоллекции,
		|	Пол,
		|	ТоварнаяКатегория
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.ЧастьКоллекции КАК ЧастьКоллекции,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.ТоварнаяКатегория КАК ТоварнаяКатегория,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.Пол КАК Пол
		|ПОМЕСТИТЬ Заявки
		|ИЗ
		|	Документ.ЗаявкаНаРасходованиеДенежныхСредств.ТоварныеКатегории КАК ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории
		|ГДЕ
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.Ссылка = &ДанныеЗаполнения
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ЧастьКоллекции,
		|	Пол,
		|	ТоварнаяКатегория
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	Заказы.Ссылка КАК Ссылка,
		|	Заказы.Дата КАК Дата
		|ИЗ
		|	Заявки КАК Заявки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Заказы КАК Заказы
		|		ПО Заявки.ЧастьКоллекции = Заказы.ЧастьКоллекции
		|			И Заявки.ТоварнаяКатегория = Заказы.ТоварнаяКатегория
		|			И Заявки.Пол = Заказы.Пол
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.НомерСтроки КАК НомерСтроки,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.ЧастьКоллекции КАК ЧастьКоллекции,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.Пол КАК Пол,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.ТоварнаяКатегория КАК ТоварнаяКатегория,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.Комментарий КАК Комментарий,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.Цена КАК Цена,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.ПроцентРучнойСкидки КАК ПроцентРучнойСкидки,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.СуммаПрайсЛист КАК Сумма,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.Отменено КАК Отменено,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.ПричинаОтмены КАК ПричинаОтмены,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.КодСтроки КАК КодСтроки,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.Количество КАК Количество,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.СтавкаНДС КАК СтавкаНДС,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.СуммаНДС КАК СуммаНДС,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.СуммаСНДС КАК СуммаСНДС,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.Упаковка КАК Упаковка,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.СуммаБезСкидки КАК СуммаБезСкидки,
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.Сумма КАК СуммаИнвойс
		|ИЗ
		|	Документ.ЗаявкаНаРасходованиеДенежныхСредств.ТоварныеКатегории КАК ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории
		|ГДЕ
		|	ЗаявкаНаРасходованиеДенежныхСредствТоварныеКатегории.Ссылка = &ДанныеЗаполнения";
		
		Запрос.УстановитьПараметр("ДанныеЗаполнения", ДанныеЗаполнения);
		ПакетЗапросов = Запрос.ВыполнитьПакет();
		
		ВыборкаЗаказов = ПакетЗапросов[ПакетЗапросов.ВГраница()-1].Выбрать();
		ВыборкаЗаказов.Следующий();
		
		ТаблицаКатегорий = ПакетЗапросов[ПакетЗапросов.ВГраница()].Выгрузить();
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ДокументОснование", ВыборкаЗаказов.Ссылка);
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ЗаказПоставщику.Сделка КАК Сделка,
		|	ЗаказПоставщику.Соглашение.РегистрироватьЦеныПоставщика КАК РегистрироватьЦеныПоставщика,
		|	ЗаказПоставщику.Партнер КАК Партнер,
		|	ЗаказПоставщику.Контрагент КАК Контрагент,
		|	ЗаказПоставщику.Договор КАК Договор,
		|	ЗаказПоставщику.Организация КАК Организация,
		|	ЗаказПоставщику.Соглашение КАК Соглашение,
		|	ЗаказПоставщику.Валюта КАК Валюта,
		|	ЗаказПоставщику.Валюта КАК ВалютаВзаиморасчетов,
		|	ВЫБОР
		|		КОГДА ЗаказПоставщику.Склад.ЭтоГруппа
		|				И ЗаказПоставщику.Склад.ВыборГруппы = ЗНАЧЕНИЕ(Перечисление.ВыборГруппыСкладов.РазрешитьВЗаказах)
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
		|		ИНАЧЕ ЗаказПоставщику.Склад
		|	КОНЕЦ КАК Склад,
		|	ВЫБОР
		|		КОГДА ЗаказПоставщику.Склад.ЭтоГруппа
		|				И ЗаказПоставщику.Склад.ВыборГруппы = ЗНАЧЕНИЕ(Перечисление.ВыборГруппыСкладов.РазрешитьВЗаказах)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЗапрещеноВыбиратьГруппуСкладов,
		|	ЗаказПоставщику.ФормаОплаты КАК ФормаОплаты,
		|	ЗаказПоставщику.ЦенаВключаетНДС КАК ЦенаВключаетНДС,
		|	ЗаказПоставщику.НалогообложениеНДС КАК НалогообложениеНДС,
		|	ЗаказПоставщику.ЗакупкаПодДеятельность КАК ЗакупкаПодДеятельность,
		|	ЗаказПоставщику.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	ЗаказПоставщику.Статус КАК СтатусДокумента,
		|	ЗаказПоставщику.Подразделение КАК Подразделение,
		|	ЗаказПоставщику.ГруппаФинансовогоУчета КАК ГруппаФинансовогоУчета,
		|	ЗаказПоставщику.ВернутьМногооборотнуюТару КАК ВернутьМногооборотнуюТару,
		|	ЗаказПоставщику.СрокВозвратаМногооборотнойТары КАК СрокВозвратаМногооборотнойТары,
		|	ЗаказПоставщику.ТребуетсяЗалогЗаТару КАК ТребуетсяЗалогЗаТару,
		|	ЕСТЬNULL(ЗаказПоставщику.Соглашение.РассчитыватьДатуВозвратаТарыПоКалендарю, ЛОЖЬ) КАК РассчитыватьДатуВозвратаТарыПоКалендарю,
		|	ЕСТЬNULL(ЗаказПоставщику.Соглашение.КалендарьВозвратаТары, ЗНАЧЕНИЕ(Справочник.ПроизводственныеКалендари.ПустаяСсылка)) КАК КалендарьВозвратаТары,
		|	НЕ ЗаказПоставщику.Проведен КАК ЕстьОшибкиПроведен,
		|	ВЫБОР
		|		КОГДА ЗаказПоставщику.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовПоставщикам.Подтвержден)
		|				ИЛИ ЗаказПоставщику.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовПоставщикам.Закрыт)
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ЕстьОшибкиСтатус,
		|	ЗаказПоставщику.БанковскийСчет КАК БанковскийСчетОрганизации,
		|	ЗаказПоставщику.ПорядокРасчетов КАК ПорядокРасчетов,
		|	ЗаказПоставщику.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	ЗаказПоставщику.Марка,
		|	ЗаказПоставщику.Коллекция,
		|	ЗаказПоставщику.ЧастьКоллекции,
		|	ЗаказПоставщику.Соглашение.УчетПоТоварнымКатегориям КАК УчетПоТоварнымКатегориям,
		|	ЗаказПоставщику.ПредварительныйЗаказ.ПроцентРучнойСкидки КАК СикдкаОтПоставщика
		|ИЗ
		|	Документ.ЗаказПоставщику КАК ЗаказПоставщику
		|ГДЕ
		|	ЗаказПоставщику.Ссылка = &ДокументОснование";
		
		РезультатЗапроса = Запрос.ВыполнитьПакет();
		
		РеквизитыЗаказа = РезультатЗапроса[0].Выбрать();
		РеквизитыЗаказа.Следующий();
		
		ЗаполнитьЗначенияСвойств(Источник, РеквизитыЗаказа);
		
		Источник.ТоварныеКатегории.Загрузить(ТаблицаКатегорий);
		Источник.ЗаявкаНаРасходованиеДенежныхСредств = ДанныеЗаполнения;
		
		Если Источник.Договор.Инкотермс = перечисления.Инкотермс.DDP Тогда
			Источник.СпособДоставки = Перечисления.СпособыДоставки.СиламиПоставщикаДоНашегоСклада;
		Иначе
			Источник.СпособДоставки = Перечисления.СпособыДоставки.СиламиПеревозчикаДоНашегоСклада;
		КонецЕсли;
		
		Источник.Статус 				= Перечисления.СтатусыПоступленийТоваров.Отгружено;
		
		//Источник.ЗаполнитьЭтапыГрафикаОплаты(); //Вера
		Источник.ПоступлениеПоЗаказам 	= Истина;
		
	КонецЕсли;
	
	Источник.ПоступлениеПоЗаказам 	= Ложь;
	//Источник.ЗаполнитьЭтапыГрафикаОплаты();
	Источник.ПоступлениеПоЗаказам 	= Истина;
	
КонецПроцедуры


Процедура ПеренестиВзаиморасчетыНаДоговорОбработкаЗаполнения(Источник, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка) Экспорт
	
	Если ТипЗнч(ДанныеЗаполнения)=Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = 
		
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	РасчетыСПоставщиками.Валюта КАК Валюта,
		|	АналитикаПоПартнерам.Партнер КАК Партнер,
		|	АналитикаПоПартнерам.Договор КАК ОбъектРасчетов,
		|	РасчетыСПоставщиками.СуммаОстаток КАК Сумма
		|ИЗ
		|	РегистрНакопления.РасчетыСПоставщиками.Остатки(&ДатаОстатков) КАК РасчетыСПоставщиками
		|		{ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК АналитикаПоПартнерам
		|		ПО РасчетыСПоставщиками.АналитикаУчетаПоПартнерам = АналитикаПоПартнерам.КлючАналитики}
		|ГДЕ
		|	АналитикаПоПартнерам.Партнер = &Партнер
		|	И АналитикаПоПартнерам.Договор <> &Договор
		|	И РасчетыСПоставщиками.СуммаОстаток > 0";
		
		Запрос.УстановитьПараметр("ДатаОстатков", КонецДня(ТекущаяДатаСеанса()));
		Запрос.УстановитьПараметр("Партнер", ДанныеЗаполнения.Партнер);
		Запрос.УстановитьПараметр("Договор", ДанныеЗаполнения);
		
		ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
		
		Если ВыборкаЗапроса.Следующий() Тогда
			ЗаполнитьВзаимозачетЗадолженности(Источник, ДанныеЗаполнения, ВыборкаЗапроса.Сумма, ВыборкаЗапроса.ОбъектРасчетов);	
		Иначе
			
			Запрос.УстановитьПараметр("Партнер", Справочники.Партнеры.НайтиПоНаименованию("Поставщик для 10.3"));
			ВыборкаЗапроса.Следующий();
			
			ЗаполнитьВзаимозачетЗадолженности(Источник, ДанныеЗаполнения, 0, ВыборкаЗапроса.ОбъектРасчетов);	
			
		Конецесли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере   
Процедура ЗаполнитьВзаимозачетЗадолженности(ДокументОбъект, Договор, Сумма, ОбъектРасчетов)
	
	ДокументОбъект.ДокументОснование = Договор;
	
	Если ЗначениеЗаполнено(Сумма)
		И Сумма>0 Тогда
		ДокументОбъект.ВидОперации  = Перечисления.ВидыОперацийВзаимозачетаЗадолженности.Поставщика;
		ТипКонтрагента 				= Перечисления.ТипыУчастниковВзаимозачета.Поставщик;
		КонтрагентДебитор			= Договор.Контрагент;
		ПартнерДебитор				= Договор.Партнер;
	Иначе
		ДокументОбъект.ВидОперации  = Перечисления.ВидыОперацийВзаимозачетаЗадолженности.МеждуПоставщиками;
		ТипКонтрагента 				= Перечисления.ТипыУчастниковВзаимозачета.Поставщик;
		КонтрагентДебитор			= Справочники.Контрагенты.НайтиПоНаименованию("Поставщик для 10.3");
		ПартнерДебитор				= Справочники.Партнеры.НайтиПоНаименованию("Поставщик для 10.3");
	КонецЕсли;
	
	ДокументОбъект.Организация    	  = Договор.Организация;
	ДокументОбъект.КонтрагентДебитор  = КонтрагентДебитор;
	ДокументОбъект.КонтрагентКредитор = Договор.Контрагент;
	ДокументОбъект.ТипДебитора        = ТипКонтрагента;
	ДокументОбъект.ТипКредитора       = ТипКонтрагента;
	//ДокументОбъект.Валюта             = Договор.ВалютаВзаиморасчетов;
	//ДокументОбъект.СуммаУпр     	  = Сумма;
	
	СтрокаЗачета = ДокументОбъект.КредиторскаяЗадолженность.Добавить();
	СтрокаАванса = ДокументОбъект.ДебиторскаяЗадолженность.Добавить();
	
	СтрокаАванса.ТипРасчетов		  = Перечисления.ТипыРасчетовСПартнерами.РасчетыСПоставщиком;
	СтрокаАванса.Партнер              = ПартнерДебитор;
	СтрокаАванса.Заказ				  = ОбъектРасчетов;
	СтрокаАванса.Организация		  = Договор.Организация;
	СтрокаАванса.Сумма                = Сумма;
	СтрокаАванса.СуммаВзаиморасчетов  = Сумма;
	СтрокаАванса.ВалютаВзаиморасчетов = Договор.ВалютаВзаиморасчетов;
	
	СтрокаЗачета.ТипРасчетов		  = Перечисления.ТипыРасчетовСПартнерами.РасчетыСПоставщиком;
	СтрокаЗачета.Партнер              = Договор.Партнер;
	СтрокаЗачета.Заказ				  = Договор;
	СтрокаЗачета.Организация		  = Договор.Организация;
	СтрокаЗачета.Сумма                = Сумма;
	СтрокаЗачета.СуммаВзаиморасчетов  = Сумма;
	СтрокаЗачета.ВалютаВзаиморасчетов = Договор.ВалютаВзаиморасчетов;
	
	
КонецПроцедуры


Процедура ЗаполнитьМаркуЗаявокНаРасходДенежныхСредствПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
