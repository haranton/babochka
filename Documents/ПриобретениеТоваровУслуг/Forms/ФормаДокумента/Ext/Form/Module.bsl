&НаКлиенте
Процедура BG_ЗаполнитьПеремещаемПосле(Команда)
	ВыделенныеСтроки = Элементы.Товары.ВыделенныеСтроки;
	
	Если Объект.Товары.Количество() = 0 Тогда
		ПоказатьПредупреждение( , НСтр("ru = 'В список ""Товары"" не введено ни одной строки.'"));
		Возврат;
	конецесли;
		
	УстановитьПеремещаемЗавершение(ВыделенныеСтроки);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПеремещаемЗавершение(МассивСтрок) экспорт //Результат, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(Перемещаем) Тогда
		
		Для Каждого НомерСтроки Из МассивСтрок Цикл
			СтрокаТЧ = Объект.Товары.НайтиПоИдентификатору(НомерСтроки);
			СтрокаТЧ.Перемещаем  = Перемещаем; //ВыбранноеЗначение;
			СтрокаТЧ.Накладная  = Накладная; //ВыбранноеЗначение;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПолеПеремещаемИзЗаказа()
	
	ВсеЗаказы = Объект.Товары.Выгрузить();
	ВсеЗаказы.Свернуть("ЗаказПоставщику");
	
	ВсеЗаказы = ВсеЗаказы.ВыгрузитьКолонку("ЗаказПоставщику");
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	ЗаказПоставщикуТовары.Ссылка КАК ЗаказПоставщику,
	|	ЗаказПоставщикуТовары.КодСтроки КАК КодСтроки,
	|	ЗаказПоставщикуТовары.Перемещаем КАК Перемещаем
	|ИЗ
	|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|ГДЕ
	|	ЗаказПоставщикуТовары.Ссылка В(&ВсеЗаказы)";
	
	Запрос.УстановитьПараметр("ВсеЗаказы", ВсеЗаказы);
	
	ТаблицаЗаказов = Запрос.Выполнить().Выгрузить();
	
	ТаблицаЗаказов.Индексы.Добавить("ЗаказПоставщику,КодСтроки");
	
	Для Каждого СтрокаТоваров ИЗ Объект.Товары Цикл
		
		НайденноеПеремещение = ТаблицаЗаказов.НайтиСтроки(Новый Структура("ЗаказПоставщику,КодСтроки", СтрокаТоваров.ЗаказПоставщику, СтрокаТоваров.КодСтроки));
		
		Если НайденноеПеремещение.Количество() Тогда
			ЗаполнитьЗначенияСвойств(СтрокаТоваров, НайденноеПеремещение[0]);
		Конецесли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПредплатуПоДокументу()
	
	Объект.ПоступлениеПоЗаказам = Истина;
	ПредварительныеЗаказыСервер.ЗаполнитьПредоплатуПоДокументу(Объект, СуммаВсего);
	Если Объект.ЭтапыГрафикаОплаты.Количество() = 0 Тогда
		Объект.ПоступлениеПоЗаказам = ложь;
		ДокументОбъект = РеквизитФормыВЗначение("Объект"); 
		ЗначениеВДанныеФормы(ДокументОбъект,Объект);
		Объект.ПоступлениеПоЗаказам = Истина;
	КонецЕслИ;
КонецПроцедуры

&НаСервере
Функция ПолучитьТЗИсходныхСумм(СсылкаДокумент)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПриобретениеТоваровУслугТовары.КодСтроки КАК КодСтроки,
		|	СУММА(ПриобретениеТоваровУслугТовары.Сумма) КАК Сумма,
		|	СУММА(ПриобретениеТоваровУслугТовары.Количество) КАК Количество,
		|	СУММА(ПриобретениеТоваровУслугТовары.СуммаИнвойс) КАК СуммаИнвойс,
		|	ПриобретениеТоваровУслугТовары.Номенклатура КАК Номенклатура,
		|	ПриобретениеТоваровУслугТовары.Характеристика КАК Характеристика
		|ИЗ
		|	Документ.ПриобретениеТоваровУслуг.Товары КАК ПриобретениеТоваровУслугТовары
		|ГДЕ
		|	ПриобретениеТоваровУслугТовары.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ПриобретениеТоваровУслугТовары.КодСтроки,
		|	ПриобретениеТоваровУслугТовары.Номенклатура,
		|	ПриобретениеТоваровУслугТовары.Характеристика
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	999,
		|	СУММА(-1),
		|	СУММА(1),
		|	СУММА(-1),
		|	NULL,
		|	NULL";
	
	Запрос.УстановитьПараметр("Ссылка", СсылкаДокумент);
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	ТЗ.Индексы.Добавить("КодСтроки, Номенклатура, Характеристика");
		
	Возврат ТЗ;
	
КонецФункции

&НаКлиенте
Процедура BG_КоманднаяПанельТоварыРазмножитьСтрокиДляФотоПосле(Команда)
	
	Строки = объект.товары.НайтиСтроки(новый структура("Фотографируем",истина));
		для каждого стр из строки цикл
			если стр.количество > 1 тогда 
				НоваяСтрокаТовары=объект.Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаТовары,стр);			
				НоваяСтрокаТовары.Количество=1;
				НоваяСтрокаТовары.КоличествоУпаковок=1;
				Сообщить("Добавлена строка "+СокрЛП(НоваяСтрокаТовары.Номенклатура)+" "+СокрЛП(НоваяСтрокаТовары.Характеристика)+" "+
		             СокрЛП(НоваяСтрокаТовары.Количество));	
				СтруктураДействий = Новый Структура;
				ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(СтруктураДействий, ЭтаФорма);
				
				ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(НоваяСтрокаТовары, СтруктураДействий, Неопределено);
					
				РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
				//\\
				ПараметрыОтбора = Новый Структура;
				ПараметрыОтбора.Вставить("Номенклатура", стр.Номенклатура);
				ПараметрыОтбора.Вставить("Характеристика", стр.Характеристика);
				ПараметрыОтбора.Вставить("Количество", стр.Количество);
				НайденныеСтроки = объект.Товары.НайтиСтроки(ПараметрыОтбора);		
				
				Если НайденныеСтроки.Количество()>0 Тогда
				
					НайденныеСтроки[0].Количество=НайденныеСтроки[0].Количество-1;
					НайденныеСтроки[0].КоличествоУпаковок=НайденныеСтроки[0].КоличествоУпаковок-1;
					НайденныеСтроки[0].Фотографируем=Ложь;				
					
					СтруктураДействий = Новый Структура;
					ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(СтруктураДействий, ЭтаФорма);
					
					ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(НайденныеСтроки[0], СтруктураДействий, Неопределено);
					
					РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
                    
					Сообщить("В строке "+СокрЛП(НайденныеСтроки[0].Номенклатура)+" "+СокрЛП(НайденныеСтроки[0].Характеристика)+" изменено количество с "+
				             СокрЛП(НайденныеСтроки[0].Количество+1)+" на "+СокрЛП(НайденныеСтроки[0].Количество));		
					
				КонецЕсли;
			конецесли;
		конеццикла;

	BG_КоманднаяПанельТоварыРазмножитьСтрокиДляФотоПослеНаСервере();
	    

КонецПроцедуры

&НаСервере
Функция BG_КоманднаяПанельТоварыРазмножитьСтрокиДляФотоПослеНаСервере()
	
	ТЗИсходыеСуммы = ПолучитьТЗИсходныхСумм(Объект.Ссылка);

			
	Для каждого ТекущаяСтрока Из Объект.Товары Цикл
		
		Сумма = ТекущаяСтрока.ЦенаИнвойс * ТекущаяСтрока.Количество;
		ТекущаяСтрока.СуммаРучнойСкидки = Сумма * ТекущаяСтрока.ПроцентРучнойСкидки / 100;
		ТекущаяСтрока.СуммаИнвойс = Сумма  - ТекущаяСтрока.СуммаРучнойСкидки;  
		ТекущаяСтрока.Сумма = ТекущаяСтрока.Количество * ТекущаяСтрока.Цена;	
		ТекущаяСтрока.СуммаСНДС = ТекущаяСтрока.Сумма;
		
		Если ЗначениеЗаполнено(ТекущаяСтрока.КодСтроки) Тогда
			ИсходнаяСтрокаСуммы = ТЗИсходыеСуммы.Найти(ТекущаяСтрока.КодСтроки, "КодСтроки");	
		Иначе
			ИсходныеСтрокиСуммы = ТЗИсходыеСуммы.НайтиСтроки(Новый Структура("Номенклатура, Характеристика", ТекущаяСтрока.Номенклатура, ТекущаяСтрока.Характеристика));
			Если ИсходныеСтрокиСуммы.Количество() Тогда
				ИсходнаяСтрокаСуммы	= ИсходныеСтрокиСуммы[0];
			КонецЕсли;
		КонецЕсли;
		Если ИсходнаяСтрокаСуммы <> Неопределено Тогда
			ИсходнаяСтрокаСуммы.Количество 	= ИсходнаяСтрокаСуммы.Количество - ТекущаяСтрока.Количество;
			ИсходнаяСтрокаСуммы.СуммаИнвойс = ИсходнаяСтрокаСуммы.СуммаИнвойс - ТекущаяСтрока.СуммаИнвойс;
			ИсходнаяСтрокаСуммы.Сумма 		= ИсходнаяСтрокаСуммы.Сумма - ТекущаяСтрока.Сумма;
			Если ИсходнаяСтрокаСуммы.Количество = 0 
				И ИсходнаяСтрокаСуммы.СуммаИнвойс <> 0 Тогда
				
				ТекущаяСтрока.СуммаРучнойСкидки = ТекущаяСтрока.СуммаРучнойСкидки - ИсходнаяСтрокаСуммы.СуммаИнвойс; //разница в копейках
				ТекущаяСтрока.СуммаИнвойс = Сумма  - ТекущаяСтрока.СуммаРучнойСкидки;  
				ТекущаяСтрока.Сумма = ТекущаяСтрока.Количество * ТекущаяСтрока.Цена;	
				ТекущаяСтрока.СуммаСНДС = ТекущаяСтрока.Сумма;
		
			КонецЕсли;
			
		КонецЕсли; 	
		
	КонецЦикла;
КонецФункции

// Андрей Ринг
&НаКлиенте
Процедура ОбработкаФормированияАссортимента(ВыбранноеЗначение) Экспорт
