&НаКлиенте
Процедура НазначитьРучнуюСкидкуДляВыделенныхСтрокИнвойс(Команда)

	Если Не СкидкиНаценкиКлиент.ВозможноНазначениеРучнойСкидкиНаценки(Объект, "Товары", НСтр("ru='Товары'")) Тогда
		Возврат;
	КонецЕсли;

	АдресВоВременномХранилище = АдресДанныхДляРасчетаРучныхСкидокВоВременномХранилищеИнвойс(Истина);
	
	Оповещение = Новый ОписаниеОповещения(
		"НазначитьРучнуюСкидкуДляВыделенныхСтрокЗавершениеИнвойс", 
		ЭтотОбъект, 
		Новый Структура("АдресВоВременномХранилище", АдресВоВременномХранилище));
	
	СкидкиНаценкиКлиент.ОткрытьФормуНазначенияРучныхСкидок(
		АдресВоВременномХранилище,
		Объект.Валюта,
		Оповещение,
		Истина);
		
		Модифицированность = Истина;

КонецПроцедуры

&НаСервере
Функция АдресДанныхДляРасчетаРучныхСкидокВоВременномХранилищеИнвойс(ТолькоВыделенныеСтроки)
	
	Возврат Б_РегламентныеЗаданияСервер.АдресДанныхДляРасчетаРучныхСкидокВоВременномХранилищеЗакупкиИнвойс(ЭтаФорма, "Товары", УникальныйИдентификатор, ТолькоВыделенныеСтроки);
	
КонецФункции

&НаКлиенте
Процедура НазначитьРучнуюСкидкуДляВыделенныхСтрокЗавершениеИнвойс(СуммаРучнойСкидкиНаценки, ДополнительныеПараметры) Экспорт 
	
	АдресВоВременномХранилище = ДополнительныеПараметры.АдресВоВременномХранилище;
	
	Если СуммаРучнойСкидкиНаценки <> Неопределено Тогда
		
		НазначитьРучнуюСкидкуНаСервереИнвойс(СуммаРучнойСкидкиНаценки, Элементы.Товары.ВыделенныеСтроки, АдресВоВременномХранилище);
		
        СкидкиНаценкиКлиент.ОповеститьОбОкончанииНазначенияРучныхСкидокНаценок(СуммаРучнойСкидкиНаценки, Объект.Валюта);
		
		ВзаиморасчетыКлиентСервер.ОбновитьТекстГиперссылкиВалюты(ЭтаФорма);
				
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура НазначитьРучнуюСкидкуНаСервереИнвойс(СуммаСкидкиНаценки, Знач ВыделенныеСтроки, АдресВоВременномХранилище)
	
	ПараметрыСкидки = Новый Структура();
	ПараметрыСкидки.Вставить("ИспользуютсяАвтоматическиеСкидки", Ложь);
	ПараметрыСкидки.Вставить("РассчитыватьСуммуСНДС", Истина);
	ПараметрыСкидки.Вставить("ВыделенныеСтроки", ВыделенныеСтроки);
	ПараметрыСкидки.Вставить("АдресВоВременномХранилище", АдресВоВременномХранилище);
	
	Б_РегламентныеЗаданияСервер.НазначитьРучнуюСкидкуИнвойс(Объект, "Товары", СуммаСкидкиНаценки, ПараметрыСкидки);
	
КонецПроцедуры


&НаКлиенте
Процедура BG_ОтменитьРучныеСкидкиИнвойсПосле(Команда)
	
	Если Не СкидкиНаценкиКлиент.ВозможнаОтменаРучныхСкидокНаценок(Объект, "Товары", НСтр("ru='Товары'")) Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого СтрокаТЧ Из Объект.Товары Цикл
		
		СтрокаТЧ.ПроцентРучнойСкидки = 0;
		СтрокаТЧ.СуммаРучнойСкидки = 0;
		СтрокаТЧ.СуммаИнвойс = СтрокаТЧ.ЦенаИнвойс * СтрокаТЧ.Количество;
		
	КонецЦикла; 
	
	СкидкиНаценкиКлиент.ОповеститьОбОкончанииНазначенияРучныхСкидокНаценок();
	
	РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
	ВзаиморасчетыКлиентСервер.ОбновитьТекстГиперссылкиВалюты(ЭтаФорма);
	
	Модифицированность = Истина;
	
КонецПроцедуры


&НаКлиенте
Процедура BG_СкопироватьНезаполненныеСуммыИнвойсПоПрайсЛистуПосле(Команда)
	
	Для каждого СтрокаТЧ Из Объект.Товары Цикл   
		Если СтрокаТЧ.СуммаИнвойс = 0 
			ИЛИ СтрокаТЧ.ЦенаИнвойс = 0 Тогда
			СтрокаТЧ.ЦенаИнвойс = СтрокаТЧ.Цена;
			СтрокаТЧ.СуммаРучнойСкидки = СтрокаТЧ.Цена * СтрокаТЧ.Количество * СтрокаТЧ.ПроцентРучнойСкидки / 100;
			СтрокаТЧ.СуммаИнвойс = СтрокаТЧ.Цена * СтрокаТЧ.Количество - СтрокаТЧ.СуммаРучнойСкидки;
	    КонецЕсли;
	КонецЦикла;  
	
	Модифицированность = Истина;
	
КонецПроцедуры


&НаСервере
Процедура BG_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	ЗаполнитьКолонкуСуммаБЕЗНДС();
КонецПроцедуры

Процедура ЗаполнитьКолонкуСуммаБЕЗНДС() 
	
	НДСВключен = Объект.ЦенаВключаетНДС;
	
	Для каждого СтрокаТЧ Из Объект.Товары Цикл
		//СтрокаТЧ.СуммаБезНДС = ?(НДСВключен, СтрокаТЧ.СуммаСНДС - СтрокаТЧ.СуммаНДС, СтрокаТЧ.СуммаСНДС + СтрокаТЧ.СуммаНДС); 		
		СтрокаТЧ.СуммаБезНДС = СтрокаТЧ.СуммаСНДС - СтрокаТЧ.СуммаНДС; 		
	КонецЦикла;
		
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("РазбитьСтрокуФактЗавершение")
Процедура ba_РазбитьСтрокуФактЗавершение(НоваяСтрока, ДополнительныеПараметры)

	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;

	Если НоваяСтрока <> Неопределено Тогда

		СтруктураДействий = Новый Структура;
		ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(СтруктураДействий, ЭтаФорма);

		ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
		ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(НоваяСтрока, СтруктураДействий, КэшированныеЗначения);

		РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
		#Вставка
		ТекущаяСтрока.Сумма = ТекущаяСтрока.Цена * ТекущаяСтрока.Количество; 
		ТекущаяСтрока.СуммаСНДС = ТекущаяСтрока.Сумма; 
		НоваяСтрока.Сумма = НоваяСтрока.Цена * НоваяСтрока.Количество;
		НоваяСтрока.СуммаСНДС = НоваяСтрока.Сумма; 
		
		Сумма = ТекущаяСтрока.ЦенаИнвойс * ТекущаяСтрока.Количество;
		ТекущаяСтрока.СуммаРучнойСкидки = Сумма * ТекущаяСтрока.ПроцентРучнойСкидки / 100;
		ТекущаяСтрока.СуммаИнвойс = Сумма - ТекущаяСтрока.СуммаРучнойСкидки;
		
		Сумма = ТекущаяСтрока.ЦенаИнвойс * НоваяСтрока.Количество;
		НоваяСтрока.СуммаРучнойСкидки = Сумма * НоваяСтрока.ПроцентРучнойСкидки / 100;
		НоваяСтрока.СуммаИнвойс = Сумма - НоваяСтрока.СуммаРучнойСкидки;
        #КонецВставки
	КонецЕсли;

	УчетПрослеживаемыхТоваровКлиентСерверЛокализация.РазбитьСтрокуЗавершение(НоваяСтрока, ДополнительныеПараметры);

	ОбновитьЗависимыеРеквизитыФормыПоЗаказу(
	Объект.Товары,
	НадписьРасхождениеЗаказ, 
	Элементы.КартинкаРасхождениеЗаказ,
	Элементы.КартинкаРасхождениеЗаказы);

КонецПроцедуры

&НаКлиенте
Процедура ba_ТоварыСуммаПриИзмененииВместо(Элемент)
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов");
	СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", ЗависимыеРеквизиты());
	
	ТекущаяСтрока.Цена = ?(ТекущаяСтрока.КоличествоУпаковок <> 0, ТекущаяСтрока.Сумма / ТекущаяСтрока.КоличествоУпаковок, 0); 
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
	ОбновитьОтклоненияОтЗаказаВСтроке(ТекущаяСтрока, Объект.ПоступлениеПоЗаказам, Объект.ТребуетсяЗалогЗаТару);
	
	РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);

КонецПроцедуры

&НаКлиенте
Процедура ba_ТоварыСуммаРучнойСкидкиПриИзмененииВместо(Элемент) 
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма); 
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;

	Сумма = ТекущаяСтрока.ЦенаИнвойс * ТекущаяСтрока.Количество;
	
	ТекущаяСтрока.СуммаИнвойс = Сумма - ТекущаяСтрока.СуммаРучнойСкидки;
	Если Сумма <> 0 Тогда
		ТекущаяСтрока.ПроцентРучнойСкидки =  ТекущаяСтрока.СуммаРучнойСкидки * 100 / Сумма;	
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ba_ТоварыЦенаПриИзмененииВместо(Элемент)
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСумму");
	СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов");
	СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", ЗависимыеРеквизиты());
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
	ОбновитьОтклоненияОтЗаказаВСтроке(ТекущаяСтрока, Объект.ПоступлениеПоЗаказам, Объект.ТребуетсяЗалогЗаТару);
	
	РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
	
	Если Объект.ПоступлениеПоЗаказам Тогда
		ОбновитьНадписьОтклоненийОтЦенЗаказа();
	КонецЕсли;

КонецПроцедуры



