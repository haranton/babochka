&НаСервере
Процедура BG_ФотоПослеНаСервере()
	Запрос = Новый запрос();
	ЗАпрос.Текст = "ВЫБРАТЬ
	               |	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
	               |	ВложенныйЗапрос.ЗначениеРазмер,
	               |	ВложенныйЗапрос.ЗначениеДляСортировки КАК ЗначениеДляСортировки,
	               |	ВложенныйЗапрос.Характеристика,
	               |	ВложенныйЗапрос.ЗначениеЦвет КАК ЗначениеЦвет
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		ПриобретениеТоваровУслугТовары.Номенклатура КАК Номенклатура,
	               |		ВложенныйЗапрос.ЗначениеРазмер КАК ЗначениеРазмер,
	               |		ЕСТЬNULL(ВложенныйЗапрос.ЗначениеДляСортировки, 0) КАК ЗначениеДляСортировки,
	               |		ПриобретениеТоваровУслугТовары.Характеристика КАК Характеристика,
	               |		ВложенныйЗапрос1.Значение КАК ЗначениеЦвет
	               |	ИЗ
	               |		Документ.ПриобретениеТоваровУслуг.Товары КАК ПриобретениеТоваровУслугТовары
	               |			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	               |				ПриобретениеТоваровУслугТовары.Номенклатура КАК Номенклатура,
	               |				ПриобретениеТоваровУслугТовары.Характеристика КАК Характеристика,
	               |				ВЫБОР
	               |					КОГДА Пол.Значение = &Жен
	               |							И НомГруппа.Значение В ИЕРАРХИИ (&ОбувьРодитель)
	               |						ТОГДА Размер.Значение.ДляСортировкиЖен
	               |					ИНАЧЕ Размер.Значение.ДляСортировки
	               |				КОНЕЦ КАК ЗначениеДляСортировки,
	               |				Размер.Значение КАК ЗначениеРазмер
	               |			ИЗ
	               |				Документ.ПриобретениеТоваровУслуг.Товары КАК ПриобретениеТоваровУслугТовары
	               |					ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	               |						НоменклатураДополнительныеРеквизиты.Ссылка КАК Ссылка,
	               |						НоменклатураДополнительныеРеквизиты.Значение КАК Значение
	               |					ИЗ
	               |						Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
	               |					ГДЕ
	               |						НоменклатураДополнительныеРеквизиты.Свойство = &СвойствоПол) КАК Пол
	               |					ПО ПриобретениеТоваровУслугТовары.Номенклатура = Пол.Ссылка
	               |					ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	               |						ХарактеристикиНоменклатурыДополнительныеРеквизиты.Ссылка КАК Ссылка,
	               |						ХарактеристикиНоменклатурыДополнительныеРеквизиты.Значение КАК Значение
	               |					ИЗ
	               |						Справочник.ХарактеристикиНоменклатуры.ДополнительныеРеквизиты КАК ХарактеристикиНоменклатурыДополнительныеРеквизиты
	               |					ГДЕ
	               |						ХарактеристикиНоменклатурыДополнительныеРеквизиты.Свойство = &СвойствоРазмер) КАК Размер
	               |					ПО ПриобретениеТоваровУслугТовары.Характеристика = Размер.Ссылка
	               |					ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	               |						НоменклатураДополнительныеРеквизиты.Ссылка КАК Ссылка,
	               |						НоменклатураДополнительныеРеквизиты.Значение КАК Значение
	               |					ИЗ
	               |						Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
	               |					ГДЕ
	               |						НоменклатураДополнительныеРеквизиты.Свойство = &СвойствоНомГруппа) КАК НомГруппа
	               |					ПО ПриобретениеТоваровУслугТовары.Номенклатура = НомГруппа.Ссылка
	               |			ГДЕ
	               |				ПриобретениеТоваровУслугТовары.Ссылка = &ПоступлениеСсылка) КАК ВложенныйЗапрос
	               |			ПО ПриобретениеТоваровУслугТовары.Номенклатура = ВложенныйЗапрос.Номенклатура
	               |				И ПриобретениеТоваровУслугТовары.Характеристика = ВложенныйЗапрос.Характеристика
	               |			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	               |				ПриобретениеТоваровУслугТовары.Номенклатура КАК Номенклатура,
	               |				ПриобретениеТоваровУслугТовары.Характеристика КАК Характеристика,
	               |				Цвет.Значение КАК Значение
	               |			ИЗ
	               |				Документ.ПриобретениеТоваровУслуг.Товары КАК ПриобретениеТоваровУслугТовары
	               |					ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	               |						ХарактеристикиНоменклатурыДополнительныеРеквизиты.Ссылка КАК Ссылка,
	               |						ХарактеристикиНоменклатурыДополнительныеРеквизиты.Значение КАК Значение
	               |					ИЗ
	               |						Справочник.ХарактеристикиНоменклатуры.ДополнительныеРеквизиты КАК ХарактеристикиНоменклатурыДополнительныеРеквизиты
	               |					ГДЕ
	               |						ХарактеристикиНоменклатурыДополнительныеРеквизиты.Свойство = &СвойствоЦвет) КАК Цвет
	               |					ПО ПриобретениеТоваровУслугТовары.Характеристика = Цвет.Ссылка
	               |			ГДЕ
	               |				ПриобретениеТоваровУслугТовары.Ссылка = &ПоступлениеСсылка) КАК ВложенныйЗапрос1
	               |			ПО ПриобретениеТоваровУслугТовары.Номенклатура = ВложенныйЗапрос1.Номенклатура
	               |				И ПриобретениеТоваровУслугТовары.Характеристика = ВложенныйЗапрос1.Характеристика
	               |	ГДЕ
	               |		ПриобретениеТоваровУслугТовары.Ссылка = &ПоступлениеСсылка) КАК ВложенныйЗапрос
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Номенклатура,
	               |	ЗначениеЦвет,
	               |	ЗначениеДляСортировки";
	Запрос.УстановитьПараметр("СвойствоЦвет"  , ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Цвет"));
	Запрос.УстановитьПараметр("СвойствоНомГруппа"  , ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Номенклатурная группа"));
	Запрос.УстановитьПараметр("СвойствоРазмер", ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Размер1"));			 				
	Запрос.УстановитьПараметр("СвойствоПол"   , ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Пол"));			 					
	Запрос.УстановитьПараметр("Жен"   , Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Женский"));	
	Запрос.УстановитьПараметр("ОбувьРодитель"   , Справочники.НоменклатурныеГруппыБабочка.НайтиПоНаименованию("Женская обувь (Woman shoes)"));		
	Запрос.УстановитьПараметр("ПоступлениеСсылка", объект.Ссылка);
	Результат=	Запрос.Выполнить().Выбрать();
	ТекущаяНоменклатура=Неопределено;
	ТекущийЦветНоменклатуры=Неопределено;	
	
	ПоискФлаг=Ложь;
	Пока Результат.Следующий() Цикл

		Если не (ТекущаяНоменклатура=Результат.номенклатура и ТекущийЦветНоменклатуры=Результат.ЗначениеЦвет) тогда
			
			ТекущаяНоменклатура=Результат.номенклатура;	
	        ТекущийЦветНоменклатуры=Результат.ЗначениеЦвет;				
			
			ПараметрыОтбора = Новый Структура;		
			ПараметрыОтбора.Вставить("Номенклатура", Результат.Номенклатура);
			ПараметрыОтбора.Вставить("Характеристика", Результат.Характеристика);		
			НайденныеСтроки = объект.Товары.НайтиСтроки(ПараметрыОтбора);
			Если НайденныеСтроки.Количество()>0 Тогда
				НайденныеСтроки[0].Фотографируем=Истина;
				ПоискФлаг=Истина;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если не	ПоискФлаг тогда
	     сообщить("Ничего не найдено!");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура BG_ФотоПосле(Команда)
	BG_ФотоПослеНаСервере();
КонецПроцедуры

&НаСервере
Процедура BG_СортироватьПослеНаСервере()
	Для Каждого стр Из Объект.Товары Цикл
		Цвет1 = стр.Характеристика.ДополнительныеРеквизиты.Найти(ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Цвет"),"Свойство");
		Если Цвет1 <> Неопределено Тогда 
			стр.Цвет = Цвет1.Значение;
		Иначе
			стр.Цвет = "";
		КонецЕсли;
		Размер1 = стр.Характеристика.ДополнительныеРеквизиты.Найти(ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Размер1"),"Свойство");
		Если Размер1 <> Неопределено Тогда
			стр.Размер = Размер1.Значение;
		Иначе
			стр.Размер = "";
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура BG_СортироватьПосле(Команда)
	
	BG_СортироватьПослеНаСервере();
	Объект.Товары.Сортировать("Номенклатура,Цвет,Размер");
КонецПроцедуры

