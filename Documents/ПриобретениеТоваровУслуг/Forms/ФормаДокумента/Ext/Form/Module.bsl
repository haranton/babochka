&НаКлиенте
Процедура BG_ПересчетЦеныСУчетомСкидкиПосле(Команда)
	Режим = РежимДиалогаВопрос.ДаНет;
	СуммаСкидки = 0;
	Если ВвестиЧисло(СуммаСкидки, "Скидка- "+СокрЛП(Формат(СуммаСкидки,"ЧЦ=4; ЧДЦ=2"))+"%,"+Символы.ПС+
			"пересчитать цены номенклатуры?" , 10, 2) и СуммаСкидки <> 0 Тогда
			Ответ = Вопрос("Цены будут уменьшены на "+СокрЛП(Формат(СуммаСкидки,"ЧЦ=4; ЧДЦ=2"))+"%, продолжить?", Режим, 0);
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			Возврат;
		КонецЕсли;  
		модифицированность = истина;
	Иначе Возврат;	
	КонецЕсли;
	Для каждого Строка из объект.Товары Цикл
		Строка.Сумма=Строка.Сумма-Строка.Сумма*СуммаСкидки/100;
		//ОбработкаТабличныхЧастей.РассчитатьСуммуТабЧасти(Строка, ЭтотОбъект);
		//ОбработкаТабличныхЧастей.РассчитатьСуммуНДСТабЧасти(Строка, ЭтотОбъект);		
	    СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Этаформа.Объект);
	
		СтруктураДействий = Новый Структура;
		СтруктураДействий.Вставить("ПересчитатьЦенуСкидкуПоСуммеВЗакупках",  ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруПересчетаЦеныСкидкиВЗакупкахВТЧ(Объект, Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ПриемНаКомиссию")));
		СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
		СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
		СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов");
		СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", ЗависимыеРеквизиты());
		СтруктураДействий.Вставить("ПересчитатьСуммуСверхЗаказа", Новый Структура("РеализацияПоступлениеПоЗаказу, ТребуетсяЗалогЗаТару",
			Объект.ПоступлениеПоЗаказам, Объект.ТребуетсяЗалогЗаТару));
			
		ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(Строка, СтруктураДействий, КэшированныеЗначения);
		ОбновитьОтклоненияОтЗаказаВСтроке(Строка, Объект.ПоступлениеПоЗаказам, Объект.ТребуетсяЗалогЗаТару);
		
		Строка.СуммаСНДС  = Строка.Сумма;

		РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
				
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПодборКатегорийИзЗаказа()
	
	МассивКодовСтрок = Новый Массив;
	Для Каждого СтрокаТЧ Из Объект.ТоварныеКатегории Цикл
		
		Если СтрокаТЧ.КодСтроки <> 0 И ЗначениеЗаполнено(СтрокаТЧ.ЗаказПоставщику) Тогда
			МассивКодовСтрок.Добавить(Новый Структура("КодСтроки,ЗаказПоставщику", СтрокаТЧ.КодСтроки, СтрокаТЧ.ЗаказПоставщику));
		КонецЕсли;
		
	КонецЦикла;
	
	ПараметрыПодбора = Новый Структура(
		"ЗаказПоставщику,
		|ВалютаДокумента,
		|ПоступлениеТоваровУслуг,
		|Склад,
		|МассивКодовСтрок,
		|Партнер,
		|Контрагент,
		|Договор,
		|Организация,
		|ХозяйственнаяОперация,
		|Соглашение,
		|ВалютаВзаиморасчетов,
		|НалогообложениеНДС,
		|ЦенаВключаетНДС,
		|ПорядокРасчетов,
		|ВернутьМногооборотнуюТару,
		|НаправлениеДеятельности",
		Объект.ЗаказПоставщику,
		Объект.Валюта,
		Объект.Ссылка,
		Объект.Склад,
		МассивКодовСтрок,
		Объект.Партнер,
		Объект.Контрагент,
		Объект.Договор,
		Объект.Организация,
		Объект.ХозяйственнаяОперация,
		Объект.Соглашение,
		Объект.ВалютаВзаиморасчетов,
		Объект.НалогообложениеНДС,
		Объект.ЦенаВключаетНДС,
		Объект.ПорядокРасчетов,
		Объект.ВернутьМногооборотнуюТару,
		Объект.НаправлениеДеятельности);
	
	ОткрытьФорму(
		"Документ.ПриобретениеТоваровУслуг.Форма.ФормаПодбораТоварныхКатегорииИзЗаказа",
		ПараметрыПодбора,
		ЭтаФорма,,,, Неопределено, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
	КонецПроцедуры

&НаКлиенте
Процедура BG_ПодобратьТоварныеКатегорииИзЗаказаПосле(Команда)
	ПодборКатегорийИзЗаказа()
КонецПроцедуры

&НаСервере
Процедура ПолучитьТоварныеКатегорииИзХранилища(АдресТоваровВХранилище)
	
	ТоварыИзХранилища = ПолучитьИзВременногоХранилища(АдресТоваровВХранилище);
	
	СтруктураПоискаТоваров = Новый Структура("ЧастьКоллекции,Пол,ТоварнаяКатегория");
	Для Каждого СтрокаТоваров Из ТоварыИзХранилища Цикл
		
		// Обработка ТЧ товары.
		//СтруктураПоискаТоваров.КодСтроки = СтрокаТоваров.КодСтроки;
		МассивСтрокТЧТовары = Объект.ТоварныеКатегории.НайтиСтроки(СтруктураПоискаТоваров);
		Если МассивСтрокТЧТовары.Количество() = 0 Тогда
			
			СтрокаТЧТовары = Объект.ТоварныеКатегории.Добавить();
			
		ИначеЕсли МассивСтрокТЧТовары.Количество() = 1 Тогда
			
			СтрокаТЧТовары = МассивСтрокТЧТовары[0];
			
		ИначеЕсли МассивСтрокТЧТовары.Количество() > 1 Тогда
			
			Для Каждого СтрокаКУдалению Из МассивСтрокТЧТовары Цикл
				
				Объект.ТоварныеКатегории.Удалить(СтрокаКУдалению);
				
			КонецЦикла;
			
			СтрокаТЧТовары = Объект.ТоварныеКатегории.Добавить();
			
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(СтрокаТЧТовары, СтрокаТоваров);
		
		СтрокаТЧТовары.СуммаБезСкидки = СтрокаТЧТовары.Цена * СтрокаТЧТовары.Количество;
		
	КонецЦикла;
	
	РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
	ЗаполнитьПредплатуПоДокументу();
	
КонецПроцедуры

&НаКлиенте
Процедура BG_СтатусПриИзмененииПосле(Элемент)
	УстановитьВидимостьЭлементовПоОперацииСервер();
КонецПроцедуры

&НаКлиенте
Процедура BG_ТоварныеКатегорииКоличествоУпаковокПриИзмененииПосле(Элемент)
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Этаформа.Объект);
	
	ТекущаяСтрока = Элементы.ТоварныеКатегории.ТекущиеДанные;
	СтруктураДействий = Новый Структура;	
	
	ТекущаяСтрока.Количество = ТекущаяСтрока.КоличествоУпаковок;
	ТекущаяСтрока.Цена 		 = ?(ТекущаяСтрока.Количество=0, ТекущаяСтрока.СуммаБезСкидки, ТекущаяСтрока.СуммаБезСкидки/ТекущаяСтрока.Количество);
	
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСумму");
	
	ТекущаяСтрока.СуммаРучнойСкидки = ТекущаяСтрока.СуммаБезСкидки * ТекущаяСтрока.ПроцентРучнойСкидки / 100;
    ТекущаяСтрока.СуммаИнвойс = ТекущаяСтрока.СуммаБезСкидки - ТекущаяСтрока.СуммаРучнойСкидки;
	ТекущаяСтрока.ЦенаИнвойс = ?(ТекущаяСтрока.Количество=0, ТекущаяСтрока.СуммаИнвойс, ТекущаяСтрока.СуммаИнвойс/ТекущаяСтрока.Количество);
	ТекущаяСтрока.Цена  = ?(ТекущаяСтрока.Количество=0, ТекущаяСтрока.Сумма, ТекущаяСтрока.Сумма/ТекущаяСтрока.Количество);
    
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
	
	ТекущаяСтрока.СуммаСНДС  = ТекущаяСтрока.Сумма;

	РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
КонецПроцедуры

&НаКлиенте
Процедура BG_ТоварныеКатегорииПослеУдаленияПосле(Элемент)
	РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
КонецПроцедуры

&НаКлиенте
Процедура BG_ТоварныеКатегорииПриИзмененииПосле(Элемент)
	РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
	
	Для Каждого СтрокаКатегорий ИЗ Объект.ТоварныеКатегории Цикл
		
		СуммаТоваров = 0;
		ДанныеВТоварах = ТоварныеКатегорииТоваров.НайтиСтроки(Новый Структура("ТоварнаяКатегория, ЧастьКоллекции", СтрокаКатегорий.ТоварнаяКатегория, СтрокаКатегорий.ЧастьКоллекции));
		
		Для Каждого СтрокаТовара ИЗ ДанныеВТоварах Цикл
			СуммаТоваров = СуммаТоваров + СтрокаТовара.Сумма;
		КонецЦикла;
		
		Если НЕ СтрокаКатегорий.Отменено Тогда
			СтрокаКатегорий.СуммаТоваров = СуммаТоваров;
			СтрокаКатегорий.Разница 	 = СтрокаКатегорий.Сумма - СуммаТоваров;
		КонецЕсли;
		
		
	КонецЦикла;
	
	ЗаполнитьПредплатуПоДокументу();
КонецПроцедуры

&НаКлиенте
Процедура BG_ТоварныеКатегорииПриНачалеРедактированияПосле(Элемент, НоваяСтрока, Копирование)
	ТекущаяСтрока = Элементы.ТоварныеКатегории.ТекущиеДанные;
	ТекущаяСтрока.СтавкаНДС = ПредопределенноеЗначение("Перечисление.СтавкиНДС.БезНДС");
КонецПроцедуры

&НаКлиенте
Процедура BG_ТоварныеКатегорииПроцентРучнойСкидкиПриИзмененииПосле(Элемент)
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Этаформа.Объект);
	ТекущаяСтрока = Элементы.ТоварныеКатегории.ТекущиеДанные;
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	
	ТекущаяСтрока.СуммаРучнойСкидки = ТекущаяСтрока.СуммаБезСкидки * ТекущаяСтрока.ПроцентРучнойСкидки / 100;
	ТекущаяСтрока.СуммаИнвойс = ТекущаяСтрока.СуммаБезСкидки - ТекущаяСтрока.СуммаРучнойСкидки; 
	ТекущаяСтрока.ЦенаИнвойс = ТекущаяСтрока.СуммаИнвойс / ТекущаяСтрока.Количество;
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
	ТекущаяСтрока.СуммаСНДС  = ТекущаяСтрока.Сумма;

	РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
КонецПроцедуры

