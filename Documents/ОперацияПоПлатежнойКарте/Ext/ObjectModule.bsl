&Перед("ОбработкаПроведения")
Процедура ba_ОбработкаПроведения(Отказ, РежимПроведения)
	//++babochka
	ПроверитьЗадолженностьПоДокументуОснованию(Отказ);
	//--babochka
КонецПроцедуры
