Функция НужноОткрытьПомощникСоздания()

	Возврат Не ЗначениеЗаполнено(Объект.Ссылка)
		И Параметры.Свойство("Основание")
		И ТипЗнч(Параметры.Основание) = Тип("ДокументСсылка.ПредварительныйЗаказ");

КонецФункции

Функция ПолучитьРегистрироватьЦеныПоУсловиям()

	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭтаФорма, "РегистрироватьЦеныПоУсловиям") Тогда
		Возврат ЭтаФорма.РегистрироватьЦеныПоУсловиям;
	КонецЕсли;

	Возврат Ложь;

КонецФункции

Функция ПолучитьСписокПредварительныхЗаказов()

	СписокЗаказов = Новый СписокЗначений;

	Для Каждого СтрокаТоварнойКатегории Из Объект.ТоварныеКатегории Цикл
		Если ЗначениеЗаполнено(СтрокаТоварнойКатегории.ПредварительныйЗаказ)
			И СписокЗаказов.НайтиПоЗначению(СтрокаТоварнойКатегории.ПредварительныйЗаказ) = Неопределено Тогда
			СписокЗаказов.Добавить(СтрокаТоварнойКатегории.ПредварительныйЗаказ);
		КонецЕсли;
	КонецЦикла;

	Возврат СписокЗаказов;

КонецФункции

Процедура ОбновитьИнформациюПоПредЗаказам()

	СписокЗаказов = ПолучитьСписокПредварительныхЗаказов();

	Если СписокЗаказов.Количество() > 1 Тогда
		НадписьЗаголовокПредзаказы = НСтр("ru = 'Всего предварительных заказов'");
		НадписьЗаголовокПредзаказы = НадписьЗаголовокПредзаказы + ": " + СписокЗаказов.Количество();
	КонецЕсли;
	Если СписокЗаказов.Количество() > 1 Тогда
		Элементы.СтраницыПредзаказ.ТекущаяСтраница = Элементы.СтраницаПредзаказы;
		Если Объект.ПредварительныйЗаказ <> Документы.ПредварительныйЗаказ.ПустаяСсылка() Тогда 
			Объект.ПредварительныйЗаказ = Документы.ПредварительныйЗаказ.ПустаяСсылка();
		КонецЕсли;
	Иначе
		Элементы.СтраницыПредзаказ.ТекущаяСтраница = Элементы.СтраницаПредзаказ;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура BG_ТоварныеКатегорииПредварительныйЗаказПриИзмененииПосле(Элемент)
	ОбновитьИнформациюПоПредЗаказам();
КонецПроцедуры

&НаСервере
Функция ЗаполнитьСуммыИнвойсаПоЗаказу()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Количество КАК Количество,
		|	Товары.ПредварительныйЗаказ КАК ПредварительныйЗаказ,
		|	Товары.КодСтроки КАК КодСтроки,
		|	Товары.Характеристика КАК Характеристика
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&Товары КАК Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТТовары.КодСтроки КАК КодСтроки,
		|	ЕСТЬNULL(ПредварительныйЗаказТовары.ЦенаИнвойс, 0) КАК ЦенаИнвойс,
		|	ЕСТЬNULL(ПредварительныйЗаказТовары.ЦенаИнвойс, 0) * ВТТовары.Количество КАК СуммаИнвойс
		|ИЗ
		|	ВТТовары КАК ВТТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПредварительныйЗаказ.Товары КАК ПредварительныйЗаказТовары
		|		ПО ВТТовары.Номенклатура = ПредварительныйЗаказТовары.Номенклатура
		|			И ВТТовары.ПредварительныйЗаказ = ПредварительныйЗаказТовары.Ссылка
		|			И ВТТовары.Характеристика = ПредварительныйЗаказТовары.Характеристика";
	
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить(,"Номенклатура,Характеристика,ПредварительныйЗаказ,Количество,КодСтроки"));
	
	ТЗЦеныПредЗаказа = Запрос.Выполнить().Выгрузить();
	ТЗЦеныПредЗаказа.Индексы.Добавить("КодСтроки");
	
	Для каждого СтрокаТЧ Из Объект.Товары Цикл   
		
		НайденнаяСтрока = ТЗЦеныПредЗаказа.Найти(СтрокаТЧ.КодСтроки, "КодСтроки");
		Если НайденнаяСтрока <> Неопределено Тогда
			СтрокаТЧ.ЦенаИнвойс  = НайденнаяСтрока.ЦенаИнвойс;		
			СтрокаТЧ.СуммаИнвойс = НайденнаяСтрока.СуммаИнвойс;
		КонецЕсли;
			
	КонецЦикла; 
	
КонецФункции

&НаКлиенте
Процедура BG_ЗаполнитьСуммуИнвойсПосле(Команда)
	
	ЗаполнитьСуммыИнвойсаПоЗаказу(); 

КонецПроцедуры

&НаКлиенте
Процедура BG_ТоварыЦенаИнвойсПриИзмененииПосле(Элемент)
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;  
	Сумма = ТекущаяСтрока.ЦенаИнвойс * ТекущаяСтрока.Количество;
	ТекущаяСтрока.СуммаРучнойСкидки = Сумма * ТекущаяСтрока.ПроцентРучнойСкидки / 100;
	ТекущаяСтрока.СуммаИнвойс = Сумма - ТекущаяСтрока.СуммаРучнойСкидки;
	ТекущаяСтрока.Сумма = ТекущаяСтрока.Количество * ТекущаяСтрока.Цена;
	
КонецПроцедуры

&НаКлиенте
Процедура BG_ТоварыПроцентРучнойСкидкиПриИзмененииПосле(Элемент)
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;

	Сумма = ТекущаяСтрока.ЦенаИнвойс * ТекущаяСтрока.Количество;
	ТекущаяСтрока.СуммаРучнойСкидки = Сумма * ТекущаяСтрока.ПроцентРучнойСкидки / 100;
	ТекущаяСтрока.СуммаИнвойс = Сумма  - ТекущаяСтрока.СуммаРучнойСкидки;
	
КонецПроцедуры

&НаКлиенте
Процедура BG_ТоварыКоличествоУпаковокПриИзмененииПосле(Элемент)
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	Сумма = ТекущаяСтрока.ЦенаИнвойс * ТекущаяСтрока.Количество;
	ТекущаяСтрока.СуммаРучнойСкидки = Сумма * ТекущаяСтрока.ПроцентРучнойСкидки / 100;
	ТекущаяСтрока.СуммаИнвойс = Сумма - ТекущаяСтрока.СуммаРучнойСкидки; 
	
КонецПроцедуры

&НаКлиенте
Процедура BG_ТоварыСуммаРучнойСкидкиПриИзмененииПосле(Элемент)
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;

	Сумма = ТекущаяСтрока.ЦенаИнвойс * ТекущаяСтрока.Количество;
	
	ТекущаяСтрока.СуммаИнвойс = Сумма - ТекущаяСтрока.СуммаРучнойСкидки;
	Если Сумма <> 0 Тогда
		ТекущаяСтрока.ПроцентРучнойСкидки =  ТекущаяСтрока.СуммаРучнойСкидки * 100 / Сумма;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура BG_ТоварыСуммаИнвойсПриИзмененииПосле(Элемент)

	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	Если ТекущаяСтрока.ЦенаИнвойс = 0 Тогда
		Возврат;	
	КонецЕсли;
	
	Сумма = ТекущаяСтрока.ЦенаИнвойс * ТекущаяСтрока.Количество;
	
	ТекущаяСтрока.СуммаРучнойСкидки = Сумма - ТекущаяСтрока.СуммаИнвойс;

    Если Сумма <> 0 Тогда
		ТекущаяСтрока.ПроцентРучнойСкидки =  ТекущаяСтрока.СуммаРучнойСкидки * 100 / Сумма;	
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура НазначитьРучнуюСкидкуДляВыделенныхСтрокИнвойс(Команда)

	Если Не СкидкиНаценкиКлиент.ВозможноНазначениеРучнойСкидкиНаценки(Объект, "Товары", НСтр("ru='Товары'")) Тогда
		Возврат;
	КонецЕсли;

	АдресВоВременномХранилище = АдресДанныхДляРасчетаРучныхСкидокВоВременномХранилищеИнвойс(Истина);
	
	Оповещение = Новый ОписаниеОповещения(
		"НазначитьРучнуюСкидкуДляВыделенныхСтрокЗавершениеИнвойс", 
		ЭтотОбъект, 
		Новый Структура("АдресВоВременномХранилище", АдресВоВременномХранилище));
	
	СкидкиНаценкиКлиент.ОткрытьФормуНазначенияРучныхСкидок(
		АдресВоВременномХранилище,
		Объект.Валюта,
		Оповещение,
		Истина);

		Модифицированность = Истина;
		
КонецПроцедуры

&НаСервере
Функция АдресДанныхДляРасчетаРучныхСкидокВоВременномХранилищеИнвойс(ТолькоВыделенныеСтроки)
	
	Возврат Б_РегламентныеЗаданияСервер.АдресДанныхДляРасчетаРучныхСкидокВоВременномХранилищеЗакупкиИнвойс(ЭтаФорма, "Товары", УникальныйИдентификатор, ТолькоВыделенныеСтроки);
	
КонецФункции

&НаКлиенте
Процедура НазначитьРучнуюСкидкуДляВыделенныхСтрокЗавершениеИнвойс(СуммаРучнойСкидкиНаценки, ДополнительныеПараметры) Экспорт 
	
	АдресВоВременномХранилище = ДополнительныеПараметры.АдресВоВременномХранилище;
	
	Если СуммаРучнойСкидкиНаценки <> Неопределено Тогда
		
		НазначитьРучнуюСкидкуНаСервереИнвойс(СуммаРучнойСкидкиНаценки, Элементы.Товары.ВыделенныеСтроки, АдресВоВременномХранилище);
		
        СкидкиНаценкиКлиент.ОповеститьОбОкончанииНазначенияРучныхСкидокНаценок(СуммаРучнойСкидкиНаценки, Объект.Валюта);
			
	КонецЕсли;

КонецПроцедуры          

&НаСервере
Процедура НазначитьРучнуюСкидкуНаСервереИнвойс(СуммаСкидкиНаценки, Знач ВыделенныеСтроки, АдресВоВременномХранилище)
	
	ПараметрыСкидки = Новый Структура();
	ПараметрыСкидки.Вставить("ИспользуютсяАвтоматическиеСкидки", Ложь);
	ПараметрыСкидки.Вставить("РассчитыватьСуммуСНДС", Истина);
	ПараметрыСкидки.Вставить("ВыделенныеСтроки", ВыделенныеСтроки);
	ПараметрыСкидки.Вставить("АдресВоВременномХранилище", АдресВоВременномХранилище);
	
	Б_РегламентныеЗаданияСервер.НазначитьРучнуюСкидкуИнвойс(Объект, "Товары", СуммаСкидкиНаценки, ПараметрыСкидки);
	
КонецПроцедуры


&НаКлиенте
Процедура BG_ОтменитьРучныеСкидкиИнвойсПосле(Команда)
	
	Если Не СкидкиНаценкиКлиент.ВозможнаОтменаРучныхСкидокНаценок(Объект, "Товары", НСтр("ru='Товары'")) Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого СтрокаТЧ Из Объект.Товары Цикл
		
		СтрокаТЧ.ПроцентРучнойСкидки = 0;
		СтрокаТЧ.СуммаРучнойСкидки = 0;
		СтрокаТЧ.СуммаИнвойс = СтрокаТЧ.ЦенаИнвойс * СтрокаТЧ.Количество;
		
	КонецЦикла; 
	
	СкидкиНаценкиКлиент.ОповеститьОбОкончанииНазначенияРучныхСкидокНаценок();
	
	РассчитатьИтоговыеПоказателиЗаказа(ЭтаФорма);	
    Модифицированность = Истина;
	
КонецПроцедуры




