
функция проверканасотрудника()
	папка = Партнер.ДополнительныеРеквизиты.Найти(планывидовхарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("папка в 10.3"),"Свойство");
	если папка <> неопределено тогда
		если папка.значение = справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Сотрудники") 
				и РучнаяСкидка и не РазрешеноРуководством тогда
			возврат ложь;
		иначе 
			возврат истина;
		конецесли;
	иначе
		возврат истина;
	конецесли;
	
конецфункции

