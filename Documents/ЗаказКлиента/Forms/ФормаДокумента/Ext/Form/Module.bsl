&НаКлиенте
Процедура ПослеОтветаНаВопросОбновленияКодаПодтверждения(Результат, ДополнительныеПараметры) Экспорт
	Если Результат <> Неопределено Тогда   	
		Если Результат = КодВозвратаДиалога.Да Тогда
			Код = ОбновитьКодПодтвержденияНаСервере();
			Отправлено = ОтправитьСМСНаСервере(Код);
			ОписаниеОповещенияПослеВыполнения = Новый ОписаниеОповещения("ПослеОтправкиСМС", ЭтаФорма);
			
			Если Отправлено Тогда
				ПоказатьПредупреждение(ОписаниеОповещенияПослеВыполнения, "SMS успешно отправлено", 5, "BABOCHKA");
			Иначе
				ПоказатьПредупреждение(ОписаниеОповещенияПослеВыполнения, "Ошибка отправки SMS", 5, "BABOCHKA");
			КонецЕсли;
			
		ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
			Код = ОбновитьКодПодтвержденияНаСервере();
			
		ИначеЕсли Результат = КодВозвратаДиалога.Отмена Тогда
			Возврат;
		КонецЕсли;
		
		ПоказатьПредупреждение(ОписаниеОповещенияПослеВыполнения, "Требуется записать документ!", 5, "BABOCHKA");

		Элементы.ПоказатьКодПодтверждения.Видимость = Истина;
		Элементы.ПроверитьКодПодтверждения.Видимость = Истина;
	КонецЕсли;
КонецПроцедуры       

&НаКлиенте
Процедура ПослеСчитыванияДанных(Результат = Неопределено, ДопПараметры) Экспорт
	Если ДопПараметры.Свойство("Действие") И ДопПараметры.Действие = "ВыдатьПромокод" Тогда
		ОткрытьФорму("РегистрСведений.ОднократныеПромокодыНаСкидку.ФормаЗаписи", Новый Структура("Партнер", Объект.Партнер),ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Результат) И ДопПараметры.Свойство("Действие") И ДопПараметры.Действие = "АктивироватьПромокод" Тогда
		ПараметрыПромокодаСкидки = НайтиПромокод(Результат, Объект.Партнер);
			
		Если ПараметрыПромокодаСкидки <> Неопределено Тогда
			ПримененныеСкидки = Объект.СкидкиНаценки.НайтиСтроки(Новый Структура("СкидкаНаценка", ПараметрыПромокодаСкидки.Скидка));
			
			Если ПримененныеСкидки.Количество() = 0 Тогда
				СуммаДоРасчетаСкидок = Объект.Товары.Итог("Сумма");
				
				СтрокаТЧ = Объект.СкидкиНаценки.Добавить();
				СтрокаТЧ.СкидкаНаценка = ПараметрыПромокодаСкидки.Скидка;
				
				Объект.СкидкиРассчитаны = Ложь;
				
				//РАСЧЕТ СКИДОК
				СтруктураПараметры = Новый Структура;
				СтруктураПараметры.Вставить("ПрименятьКОбъекту",                Истина);
				СтруктураПараметры.Вставить("ТолькоПредварительныйРасчет",      Ложь);
				СтруктураПараметры.Вставить("ВосстанавливатьУправляемыеСкидки", Истина);
				СтруктураПараметры.Вставить("УправляемыеСкидки", УправляемыеСкидки);
				
				СтруктураСообщений = РассчитатьСкидкиНаценкиНаСервере(СтруктураПараметры); 
								
				Если СтруктураСообщений.Сообщения.Количество() > 0 И СтруктураСообщений.АвтоматическиОткрывать Тогда
					ОткрытьФорму("ОбщаяФорма.СообщенияСкидокНаценок", СтруктураСообщений, ЭтаФорма, УникальныйИдентификатор);
				КонецЕсли;
					
				Если СуммаДоРасчетаСкидок > Объект.Товары.Итог("Сумма") Тогда
					ПоказатьОповещениеПользователя(
					НСтр("ru = 'Промокод'"),
					,
					НСтр("ru = 'Промокод на скидку активирован'"),
					БиблиотекаКартинок.Информация32);
					
					//ПогаситьПромокод(ПараметрыПромокода);
					ПараметрыПромокода = ПараметрыПромокодаСкидки;
					Модифицированность = Истина;
				Иначе
					ПоказатьОповещениеПользователя(
					НСтр("ru = 'Промокод'"),
					,
					НСтр("ru = 'Промокод не применен. Нет подходящих товаров для применения промокода'"),
					БиблиотекаКартинок.Информация32);
					
					//ПогаситьПромокод(ПараметрыПромокода);
					ПараметрыПромокода = Неопределено;
				КонецЕсли;
			Иначе 
				ПоказатьПредупреждение(, "Скидка уже учтена!");	
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
КонецПроцедуры

