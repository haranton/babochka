Процедура ОбновитьМТМ()
	ДанныеМТМ =  ПолучитьДанныеПоМТМ();
	Задаток = СуммаМТМПолучить();
	СуммаВЕвро = ДанныеМТМ.СуммаВЕвро;
	//Остаток = ДанныеМТМ.СуммаЗаказа+ДанныеМТМ.Остаток-Объект.ЗадатокМТМ;
	Элементы.Декорация1.Заголовок = "Сумма заказа: " + ДанныеМТМ.СуммаЗаказа;
	Элементы.Декорация6.Заголовок = "Сумма скидки: " + ДанныеМТМ.СуммаСкидки ;
	Элементы.Декорация7.Заголовок = "Остаток: " + ДанныеМТМ.Остаток;
	Элементы.Декорация8.Заголовок = "Курс УУ: " + ДанныеМТМ.Курс;
	Элементы.Декорация12.Заголовок = "Внесенный задаток: " + Задаток.СуммаМТМЕвро;
КонецПроцедуры

