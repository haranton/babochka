&НаКлиенте
Процедура ВвестиОтветственного(Команда)
	ручнаяскидка = Ложь;
	объект.ОтветстветственныйЗаРучСкидку = предопределенноезначение("Справочник.ФизическиеЛица.ПустаяСсылка");
	объект.РазмерРазрешеннойСкидки = 0;
	
	МассивСкидок = Новый Массив();
	Для Каждого стр Из Объект.Товары Цикл
		МассивСкидок.Добавить(стр.ПроцентРучнойСкидки);
	КонецЦикла;
	
	СкидкаДокумента = Бабочка.МаксимумСкидки(МассивСкидок);
	
	ПараметрыОткрытияФормы = Новый Структура;
	струк = новый структура();
	
	
	струк.Вставить("скидка", СкидкаДокумента);//?(СкидкаДокумента > СкидкаБонусами, СкидкаДокумента, СкидкаБонусами)); 
	
	ПараметрыОткрытияФормы.Вставить("скидка", СкидкаДокумента);//?(СкидкаДокумента > СкидкаБонусами, СкидкаДокумента, СкидкаБонусами));
	ПараметрыОткрытияФормы.Вставить("ТекстСообщенияТелеграм", ПолучитьТекстСообщения());
	
	ОткрытьФорму("ОбщаяФорма.ПодтверждениеОтветственного",
	ПараметрыОткрытияФормы,
	ЭтотОбъект,,,,
	Новый ОписаниеОповещения("ПодтверждениеСкидкиЗавершение", ЭтотОбъект),РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
	
КонецПроцедуры 



&НаКлиенте
Процедура ПодтверждениеСкидкиЗавершение(струк, ДополнительныеПараметры) Экспорт
	
	если струк <> неопределено тогда  	
		Объект.ОтветстветственныйЗаРучСкидку = струк.ответственный;
		объект.РазмерРазрешеннойСкидки = струк.размерскидки;
		СкидкиНаценкиКлиент.СброситьФлагСкидкиРассчитаны(ЭтаФорма);
		РассчитатьСкидкиНаценки(Неопределено);
	конецесли;
	
КонецПроцедуры 

&НаКлиенте
Функция ПолучитьТекстСообщения()
	
	ПС = Символы.ПС;
	
	ТекстСообщения = "<b>Бутик:</b> "+Строка(Объект.Склад) +ПС+
					"<b>Клиент:</b> "+Строка(Объект.Партнер) +ПС+
					"<b>Кассир:</b> "+Строка(ПользователиКлиентСервер.ТекущийПользователь()) +ПС+
					"<b>Товары:</b>"+ПС;
	
	Сч = 1;
	ЕстьСкидкаПоСтрокам = Ложь;
	Для каждого СтрокаТЧ Из Объект.Товары Цикл
		Если СтрокаТЧ.ПроцентРучнойСкидки > 0 Тогда
			ТекстСообщения = ТекстСообщения + Строка(Сч)+". "+СтрокаТЧ.Номенклатура+
							"("+Строка(ПолучитьКоллекцию(СтрокаТЧ.Номенклатура))+")"+ 
							" Сумма скидки: "+ Строка(СтрокаТЧ.СуммаРучнойСкидки)+" ("+Строка(СтрокаТЧ.ПроцентРучнойСкидки)+"%)"+ПС;
			Сч = Сч + 1;
			ЕстьСкидкаПоСтрокам = Истина;
		КонецЕсли; 	
	КонецЦикла; 
	
	Если НЕ ЕстьСкидкаПоСтрокам Тогда
		ТекстСообщения = "";	
	КонецЕсли;
	
	Возврат ТекстСообщения;
	
КонецФункции    

&НаСервереБезКонтекста
