		Объект.ДоставкаТранспортнойКомпанией = Ложь;
		Объект.ТранспортнаяКомпания = ПредопределенноеЗначение("Перечисление.ТранспортныеКомпании.ПустаяСсылка");
	КонецЕсли;
	
	Модифицированность = Истина;
КонецПроцедуры    

Функция РазрешеноИспользоватьПромокод(Промокод, Партнер, РазрешенноеКоличествоПримененийКода)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СУММА(1) КАК КоличествоПрименений
		|ИЗ
		|	РегистрСведений.ОднократныеПромокодыНаСкидку КАК ОднократныеПромокодыНаСкидку
		|ГДЕ
		|	ОднократныеПромокодыНаСкидку.Промокод = &Промокод
		|	И ОднократныеПромокодыНаСкидку.Партнер = &Партнер
		|	И ОднократныеПромокодыНаСкидку.Состояние = ЗНАЧЕНИЕ(Перечисление.СтатусыДействияСкидок.НеДействует)";
	
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("Промокод", Промокод);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	КоличествоПрименений = 0;
	
	Пока Выборка.Следующий() Цикл
		КоличествоПрименений = КоличествоПрименений + ?(ЗначениеЗаполнено(Выборка.КоличествоПрименений), Выборка.КоличествоПрименений, 0);
	КонецЦикла;
	
	Возврат КоличествоПрименений < РазрешенноеКоличествоПримененийКода;
КонецФункции

