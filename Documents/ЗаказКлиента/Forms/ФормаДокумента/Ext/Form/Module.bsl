
&НаКлиенте
Процедура ba_КартаЛояльностиОбработкаВыбораВместо(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	Если ПроверитьСтатусКарты(ВыбранноеЗначение) = Ложь Тогда
		ВыбранноеЗначение = ПредопределенноеЗначение("Справочник.КартыЛояльности.ПустаяСсылка");
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	СчитанаКартаЛояльности(Неопределено, ВыбранноеЗначение);
	ЭтоЗаказПостоплаты 	= Объект.ВидЗаказа = ПредопределенноеЗначение("Перечисление.ВидыЗаказов.Постоплата");	
	ЭтоБонуснаяКарта 	= КартаБонусная();
	Если ЭтоЗаказПостоплаты И ЭтоБонуснаяКарта Тогда
		Режим = РежимДиалогаВопрос.ОК;
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект, Параметры);
		ТекстВопроса = НСтр("ru = 'Для вида заказа Постоплата не разрешено использование бонусной карты'");
		ПоказатьВопрос(Оповещение, ТекстВопроса, Режим, 0);
		Объект.КартаЛояльности = ПредопределенноеЗначение("Справочник.КартыЛояльности.ПустаяСсылка"); 
		Возврат;
	КонецЕсли; 
КонецПроцедуры  

