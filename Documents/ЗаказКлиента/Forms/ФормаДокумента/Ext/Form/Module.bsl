&НаСервере
Функция КодыМаркировкиПодобраны()
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЗТовары.Номенклатура КАК Номенклатура,
		|	ТЗТовары.Характеристика КАК Характеристика,
		|	&Ссылка КАК Ссылка,
		|	ТЗТовары.Отменено КАК Отменено
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&ТЗТовары КАК ТЗТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ВЫБОР
		|			КОГДА МаркируемыеТоварыВЗаказеКлиента.ШтрихкодУпаковки ЕСТЬ NULL
		|				ТОГДА 1
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК НеВнесенаМаркировка
		|ПОМЕСТИТЬ ВТМаркировка
		|ИЗ
		|	ВТТовары КАК ВТТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МаркируемыеТоварыВЗаказеКлиента КАК МаркируемыеТоварыВЗаказеКлиента
		|		ПО ВТТовары.Ссылка = МаркируемыеТоварыВЗаказеКлиента.ЗаказКлиента
		|			И ВТТовары.Номенклатура = МаркируемыеТоварыВЗаказеКлиента.Номенклатура
		|			И ВТТовары.Характеристика = МаркируемыеТоварыВЗаказеКлиента.Характеристика
		|ГДЕ
		|	(ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).ОсобенностьУчета = Значение(Перечисление.ОсобенностиУчетаНоменклатуры.ОбувнаяПродукция)
		|	ИЛИ ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).ОсобенностьУчета = Значение(Перечисление.ОсобенностиУчетаНоменклатуры.Духи)
		|	ИЛИ ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).ОсобенностьУчета = Значение(Перечисление.ОсобенностиУчетаНоменклатуры.ЛегкаяПромышленность)
		|	ИЛИ ВЫРАЗИТЬ(ВТТовары.Номенклатура КАК Справочник.Номенклатура).ОсобенностьУчета = Значение(Перечисление.ОсобенностиУчетаНоменклатуры.ПродукцияМаркируемаяДляГИСМ))
		|	И НЕ ВТТовары.Отменено
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТМаркировка.НеВнесенаМаркировка КАК НеВнесенаМаркировка
		|ИЗ
		|	ВТМаркировка КАК ВТМаркировка
		|ГДЕ
		|	ВТМаркировка.НеВнесенаМаркировка > 0";
	
	ТЗТовары = Объект.Товары.выгрузить();
	ТЗТовары = ТЗТовары.Скопировать(, "Номенклатура, Характеристика, Отменено");
	
	Запрос.УстановитьПараметр("ТЗТовары", ТЗТовары);
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	Возврат Запрос.Выполнить().Пустой();
	
КонецФункции

&НаКлиенте
Процедура ДобавитьКодыМаркировки(Команда)
	
	ОткрытьФорму("РегистрСведений.МаркируемыеТоварыВЗаказеКлиента.Форма.ФормаСписка", Новый Структура("ЗаказКлиента", Объект.Ссылка), ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

Процедура ОчиститьЗаписиМаркируемыхТоваров(Номенклатура, Характеристика)
	
	Выборка = РегистрыСведений.МаркируемыеТоварыВЗаказеКлиента.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.ЗаказКлиента = Объект.Ссылка
			И Выборка.Номенклатура = Номенклатура
			И Выборка.Характеристика = Характеристика Тогда
			
			Запись = Выборка.ПолучитьМенеджерЗаписи();
			Запись.Удалить();
			
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

 &НаКлиенте
Процедура ДобавитьУпаковку(Команда)
	
	Если Параметры.Ключ.Пустая() Тогда
		Предупреждение("Запишите документ!");
		Возврат;
	КонецЕсли; 
	ОткрытьФорму("РегистрСведений.УчетУпаковки.Форма.ФормаСпискаДляОткрытия", Новый Структура("ДокументОснование", Объект.Ссылка), ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ДобавитьОплатуБонуснымиБалламиЗавершение")
Процедура ba_ДобавитьОплатуБонуснымиБалламиЗавершение(Результат, ДополнительныеПараметры)

	Если Не ЗначениеЗаполнено(Результат) Тогда
		РассчитатьИтоговыеПоказателиЗаказа(ЭтаФорма);
		Возврат;
	КонецЕсли;

	ПрименитьОплатуБонуснымиБалламиКлиент(Результат.АдресВоВременномХранилище);
    #Удаление
	СкидкиНаценкиЗаполнениеКлиент.СброситьФлагСкидкиРассчитаны(ЭтаФорма);
	#КонецУдаления
	#Вставка 
	РассчитатьСкидкиНаценкиКлиент();
	#КонецВставки

КонецПроцедуры

