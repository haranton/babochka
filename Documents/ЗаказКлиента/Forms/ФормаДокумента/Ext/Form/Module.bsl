&НаКлиенте
Процедура ВидЗаказПриИзменении(Элемент)
	
	ЭтоЗаказИМ = Объект.ВидЗаказа = ПредопределенноеЗначение("Перечисление.ВидыЗаказов.ИМ");
	ЭтоЗаказМТМ = Объект.ВидЗаказа = ПредопределенноеЗначение("Перечисление.ВидыЗаказов.МТМ");
	ЭтоЗаказСотрудник = Объект.ВидЗаказа = ПредопределенноеЗначение("Перечисление.ВидыЗаказов.Сотрудник");
	                   
	элементы.МТМстр.Видимость = ЭтоЗаказМТМ;
	Элементы.Постоплата.Видимость = ЭтоЗаказМТМ;
	элементы.РазрешеноРуководством.Видимость = ЭтоЗаказСотрудник;
	элементы.ПродажаФормы.Видимость = ЭтоЗаказСотрудник;
    //bg
	Если Объект.ВидЗаказа = ПредопределенноеЗначение("Перечисление.ВидыЗаказов.Постоплата") Тогда
		Если ЗначениеЗаполнено(Объект.КартаЛояльности) И КартаБонусная() Тогда
			
			Режим = РежимДиалогаВопрос.ОК;
			Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект, Параметры);
			ТекстВопроса = НСтр("ru = 'Для вида заказа Постоплата не разрешено использование бонусной карты'");
			ПоказатьВопрос(Оповещение, ТекстВопроса, Режим, 0);
			Объект.КартаЛояльности = ПредопределенноеЗначение("Справочник.КартыЛояльности.ПустаяСсылка"); 
        	РассчитатьСкидкиНаценкиКлиент();	
		КонецЕсли; 	
	КонецЕсли; 	
	Если Объект.ВидЗаказа <> ПредопределенноеЗначение("Перечисление.ВидыЗаказов.Сотрудник") 
		И Объект.ПродажаФормы Тогда
		Объект.ПродажаФормы = Ложь;
	КонецЕсли; 	
    
	Элементы.ЖелаемаяДатаОтгрузки.ТолькоПросмотр = Не ЭтоЗаказИМ;

КонецПроцедуры    


