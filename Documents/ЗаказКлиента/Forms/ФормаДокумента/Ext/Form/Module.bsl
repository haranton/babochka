Процедура ПогаситьПромокод()
	ПараметрыПромокодаСкидки = ПараметрыПромокода;
	
	Если ПараметрыПромокодаСкидки = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
		
	Если ПараметрыПромокодаСкидки.Промокод.Персонализирован 
		ИЛИ ПараметрыПромокодаСкидки.Промокод.Одноразовый Тогда
		
		ЗаписьРегистра = РегистрыСведений.ОднократныеПромокодыНаСкидку.СоздатьМенеджерЗаписи();
		ЗаписьРегистра.Идентификатор 	= ПараметрыПромокодаСкидки.Идентификатор;
		ЗаписьРегистра.Партнер 			= ПараметрыПромокодаСкидки.Партнер;
		ЗаписьРегистра.НомерТелефона 	= ПараметрыПромокодаСкидки.НомерТелефона;
		ЗаписьРегистра.Промокод 		= ПараметрыПромокодаСкидки.Промокод;
		ЗаписьРегистра.Прочитать();
		
		Попытка
			ЗаписьРегистра.Состояние = Перечисления.СтатусыДействияСкидок.НеДействует;
			ЗаписьРегистра.ДокументДвижения = Объект.Ссылка;
			ЗаписьРегистра.Записать();
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
		
	Иначе
		//обезличенные запишем с привязкой к покупателю и документу
		ЗаписьРегистра = РегистрыСведений.ОднократныеПромокодыНаСкидку.СоздатьМенеджерЗаписи();
		ЗаписьРегистра.Идентификатор 	= ПараметрыПромокодаСкидки.Идентификатор;
		ЗаписьРегистра.Партнер 			= Объект.Партнер;
		//ЗаписьРегистра.НомерТелефона 	= ПараметрыПромокодаСкидки.НомерТелефона;
		ЗаписьРегистра.Промокод 		= ПараметрыПромокодаСкидки.Промокод;
		ЗаписьРегистра.Состояние 		= Перечисления.СтатусыДействияСкидок.НеДействует;
		ЗаписьРегистра.ДокументДвижения = Объект.Ссылка;
		ЗаписьРегистра.ДействуетС 		= Объект.Ссылка.Дата;
		ЗаписьРегистра.ДействуетДо 		= Объект.Ссылка.Дата;
					
		Попытка
			ЗаписьРегистра.Записать();
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);	
КонецПроцедуры  

