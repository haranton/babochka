&НаКлиенте
Процедура НайтиПоНомеру(Команда)
	Если Не ЗначениеЗаполнено(НомерТелефона) Тогда
		ПоказатьПредупреждение(,"Для поиска введите номер телефона");
		Возврат;
	КонецЕсли;
	НомерТелефона = СтрЗаменить(НомерТелефона,"-",""); 
	НомерТелефона = СтрЗаменить(НомерТелефона,"(","");
	НомерТелефона = СтрЗаменить(НомерТелефона,")","");
	НомерТелефона = СтрЗаменить(НомерТелефона,"+","");
	
	ОткрытьФорму("ОбщаяФорма.ФормаВыбораКлиента", Новый Структура("НомерТелефона", НомерТелефона),,,,,
					Новый ОписаниеОповещения("НайтиКлиентаЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры     
				
