КонецПроцедуры      

&НаКлиенте
Процедура СтатусДоставкиОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	СтатусОтгрузить = ПредопределенноеЗначение("Перечисление.ВариантыОбеспечения.Отгрузить");
	ЕстьНеотгруженныеТовары = Ложь;
	
	Если ВыбранноеЗначение = ПредопределенноеЗначение("Справочник.СтатусыДоставки.ПереданоВДоставку") Тогда
		Если Объект.ЗонаДоставки = ПредопределенноеЗначение("Справочник.ЗоныДоставки.ПустаяСсылка") Тогда
			ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеЗавершение", ЭтаФорма, );
			ПоказатьПредупреждение(ОписаниеОповещения, "Заполните зону доставки!", 5, "Babochka");
			
			ВыбранноеЗначение = Объект.СтатусДоставки;
			
			Возврат;
		КонецЕсли; 
		
		Для Каждого СтрокаТЧ Из Объект.Товары Цикл
			Если СтрокаТЧ.Отменено Тогда
				Продолжить;	
			КонецЕсли; 
			
			Если СтрокаТЧ.ВариантОбеспечения <> СтатусОтгрузить Тогда
				ЕстьНеотгруженныеТовары = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла; 
		
		Если ЕстьНеотгруженныеТовары Тогда
			ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеЗавершение", ЭтаФорма, );
			ТекстОповещения = "В документе есть неотгруженные товары!
			|Невозможно изменить статус.";
			ПоказатьПредупреждение(ОписаниеОповещения,ТекстОповещения, 5, "Babochka");
			
			ВыбранноеЗначение = Объект.СтатусДоставки;
			
			Возврат;
		КонецЕсли;
		
		Если НЕ КодыМаркировкиПодобраны() Тогда
			ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеЗавершение", ЭтаФорма, );
			ПоказатьПредупреждение(ОписаниеОповещения, "Заполните коды маркировок. Товары -> Заполнить -> Добавить коды маркировки", 5, "Babochka");
			
			ВыбранноеЗначение = Объект.СтатусДоставки;
			
			Возврат;
		КонецЕсли; 
		
		Если Объект.Статус <> ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.КОбеспечению") Тогда
			ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеЗавершение", ЭтаФорма, );
			ПоказатьПредупреждение(ОписаниеОповещения, "Статус заказа должен быть К выполнению!", 5, "Babochka");
			
			ВыбранноеЗначение = Объект.СтатусДоставки;
			
			Возврат;
		КонецЕсли;
		
		Объект.ДатаДоставки = ТекущаяДатаСеанса();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ba_СчитатьКартуЛояльностиВместо(Команда)  
	Если Объект.Согласован Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Партнер", Объект.Партнер);
	ПараметрыОткрытия.Вставить("Организация", Объект.Организация);
	ПараметрыОткрытия.Вставить("ВидЗаказа", Объект.ВидЗаказа);  
	
	// ЭлектронноеВзаимодействие.СервисEDI
	Если Не РедактированиеРеквизитовEDIКлиентСервер.РеквизитДоступенДляРедактирования(ЭтотОбъект, "Покупатель") Тогда
		ПараметрыОткрытия.Вставить("Контрагент", Объект.Контрагент);
		ПараметрыОткрытия.Вставить("ИзменениеКонтрагентаНедоступно", Истина);
		ПараметрыОткрытия.Вставить("ИзменениеПартнераНедоступно", Истина);
	КонецЕсли;
	// Конец ЭлектронноеВзаимодействие.СервисEDI
	
	ОткрытьФорму(
	"Справочник.КартыЛояльности.Форма.СчитываниеКартыЛояльности",
	ПараметрыОткрытия,
	ЭтаФорма,
	ЭтаФорма.УникальныйИдентификатор);
КонецПроцедуры      

