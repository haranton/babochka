&НаСервере
Процедура ba_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка) 
	ЭтоЗаказИМ 			= Объект.ВидЗаказа = Перечисления.ВидыЗаказов.ИМ;
	ЭтоЗаказМТМ 		= Объект.ВидЗаказа = Перечисления.ВидыЗаказов.МТМ;
	ЭтоЗаказСотрудник 	= Объект.ВидЗаказа = Перечисления.ВидыЗаказов.Сотрудник;
	
	Элементы.ДоставкаТранспортнойКомпанией.Видимость = ЭтоЗаказИМ;
	Элементы.ТранспортнаяКомпания.Видимость = Элементы.ДоставкаТранспортнойКомпанией.Видимость И Объект.ДоставкаТранспортнойКомпанией;
	Элементы.МТМстр.Видимость 		= ЭтоЗаказМТМ;
	Элементы.Постоплата.Видимость 	= ЭтоЗаказМТМ;
	Элементы.ПродажаФормы.Видимость = ЭтоЗаказСотрудник;
	Элементы.РазрешеноРуководством.Видимость = ЭтоЗаказСотрудник;
	
	Если Объект.Проведен И НЕ РольДоступна("ДобавлениеИзменениеЗаказовКлиентов")
					И НЕ РольДоступна("ПолныеПрава") Тогда
		Для Каждого Элем Из Элементы.Товары.ПодчиненныеЭлементы Цикл 
			Элем.ТолькоПросмотр = Истина;
		КонецЦикла;
		Элементы.Партнер.ТолькоПросмотр = Ложь;
		Элементы.ТоварыВариантОбеспечения.ТолькоПросмотр = Ложь;
		Элементы.ТоварыГруппаОтмена.ТолькоПросмотр = Ложь;
		Элементы.Партнер.ТолькоПросмотр = Ложь;
		Элементы.Подразделение.ТолькоПросмотр = Ложь;
		Элементы.ТоварыПроцентРучнойСкидки.ТолькоПросмотр = НЕ ЭтоЗаказИМ;
	КонецЕсли;

	Если Объект.Проведен Тогда 
		ПроведенныеСтроки = Объект.Товары.Количество();
	Иначе 
		ПроведенныеСтроки = 0;
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	КурсыВалютСрезПоследних.Курс
	               |ИЗ
	               |	РегистрСведений.КурсыВалют.СрезПоследних(&Период, Валюта = &Валюта) КАК КурсыВалютСрезПоследних";
	Запрос.УстановитьПараметр("Валюта", Справочники.Валюты.НайтиПоКоду("978"));
	Запрос.УстановитьПараметр("Период", Объект.Дата);
	Выб = Запрос.Выполнить().Выбрать();
	Если Выб.Следующий() Тогда 
		Курс = Выб.Курс;
	КонецЕсли;	
	
	Данные = СуммаМТМПолучить();	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Объект.ЗадатокМТМ =  Данные.СуммаМТМЕвро;
		СуммаВЕвро 		  = Данные.СуммаМТМЕвро;
		ОбновитьМТМ();
		заполнитьпредоплаты();
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Склад) и Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Объект.Организация = Объект.Склад.Организация;
	КонецЕсли;
	
	ВидимостьКурьеров = Объект.СпособДоставки = Перечисления.СпособыДоставки.ДоКлиента;
	Элементы.Курьер.Видимость = ВидимостьКурьеров; 
	Элементы.ДанныеДоставки.Видимость = ВидимостьКурьеров; 
	Элементы.ОтвественныйМенеджер.Видимость = ВидимостьКурьеров;
		
	Если Объект.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз Тогда
		ТранспортнаяКомпанияЧисло = 2;
	ИначеЕсли ЗначениеЗаполнено(Объект.ТранспортнаяКомпания)
		И Объект.ТранспортнаяКомпания <> Перечисления.ТранспортныеКомпании.BABOCHKA Тогда 
		ТранспортнаяКомпанияЧисло = 0;
	Иначе
		ТранспортнаяКомпанияЧисло = 1;
	КонецЕсли;
	// Харитонов вопрос требуется ли данный блок
	//УстановитьВидимостьДоставки();
	
	ВидимостьДоставкиВЗаказеКлиента = Бабочка.ПолучитьЗначениеДинамическихНастроек("ВидимостьДоставкиВЗаказеКлиента", Истина);
	
	Элементы.ГруппаПВЗ.Видимость = ЭтоЗаказИМ;
	Элементы.ЖелаемаяДатаОтгрузки.ТолькоПросмотр = НЕ ЭтоЗаказИМ;
	
	Если НЕ ЗначениеЗаполнено(Объект.КодПодтвержденияПВЗ) Тогда
		Элементы.ПроверитьКодПодтверждения.Видимость = Ложь;
		Элементы.ПоказатьКодПодтверждения.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры   

&НаКлиенте
Процедура ПроверитьКодПодтверждения(Команда)
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВводаКодаПодтверждения", ЭтаФорма);
	ПоказатьВводСтроки(ОписаниеОповещения,,"Введите код подтверждения", 6);
КонецПроцедуры        

Процедура ПроверитьОрганизацииВСвязанныхДокументах()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиентаДок.Ссылка КАК ЗаказКлиента,
		|	РеализацияТоваровУслуг.Ссылка КАК РеализацияТоваров
		|ПОМЕСТИТЬ ВТ_Отгрузка
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиентаДок
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|		ПО ЗаказКлиентаДок.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента.Ссылка
		|ГДЕ
		|	ЗаказКлиентаДок.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПриходныйКассовыйОрдер.Ссылка КАК ПриходныйКассовыйОрдер,
		|	ВТ_Отгрузка.ЗаказКлиента КАК ЗаказКлиента,
		|	ВТ_Отгрузка.РеализацияТоваров КАК РеализацияТоваров
		|ПОМЕСТИТЬ ВТ_ПКО
		|ИЗ
		|	ВТ_Отгрузка КАК ВТ_Отгрузка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриходныйКассовыйОрдер КАК ПриходныйКассовыйОрдер
		|		ПО (ПриходныйКассовыйОрдер.ДокументОснование = ВТ_Отгрузка.ЗаказКлиента)
		|ГДЕ
		|	ПриходныйКассовыйОрдер.Проведен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОперацияПоПлатежнойКартеРасшифровкаПлатежа.Ссылка КАК ЭквайринговаяОперация,
		|	ВТ_Отгрузка.ЗаказКлиента КАК ЗаказКлиента,
		|	ВТ_Отгрузка.РеализацияТоваров КАК РеализацияТоваров
		|ПОМЕСТИТЬ ВТ_Эквайринг
		|ИЗ
		|	ВТ_Отгрузка КАК ВТ_Отгрузка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте.РасшифровкаПлатежа КАК ОперацияПоПлатежнойКартеРасшифровкаПлатежа
		|		ПО ВТ_Отгрузка.ЗаказКлиента = ОперацияПоПлатежнойКартеРасшифровкаПлатежа.ОснованиеПлатежа
		|ГДЕ
		|	ОперацияПоПлатежнойКартеРасшифровкаПлатежа.Ссылка.Проведен
		|	И ОперацияПоПлатежнойКартеРасшифровкаПлатежа.ОснованиеПлатежа ССЫЛКА Документ.ЗаказКлиента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ПКО.ПриходныйКассовыйОрдер КАК ПриходныйКассовыйОрдер,
		|	ЕСТЬNULL(ВТ_ПКО.ЗаказКлиента, ВТ_Эквайринг.ЗаказКлиента) КАК ЗаказКлиента,
		|	ЕСТЬNULL(ВТ_ПКО.РеализацияТоваров, ВТ_Эквайринг.РеализацияТоваров) КАК РеализацияТоваров,
		|	ВТ_Эквайринг.ЭквайринговаяОперация КАК ЭквайринговаяОперация
		|ПОМЕСТИТЬ ВТ_Итог
		|ИЗ
		|	ВТ_ПКО КАК ВТ_ПКО
		|		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_Эквайринг КАК ВТ_Эквайринг
		|		ПО ВТ_ПКО.ЗаказКлиента = ВТ_Эквайринг.ЗаказКлиента
		|			И ВТ_ПКО.РеализацияТоваров = ВТ_Эквайринг.РеализацияТоваров
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Итог.ЗаказКлиента КАК ЗаказКлиента,
		|	ВТ_Итог.РеализацияТоваров КАК РеализацияТоваров,
		|	ВТ_Итог.ПриходныйКассовыйОрдер КАК ПриходныйКассовыйОрдер,
		|	ВТ_Итог.ЭквайринговаяОперация КАК ЭквайринговаяОперация,
		|	ВЫБОР
		|		КОГДА НЕ ВТ_Итог.ПриходныйКассовыйОрдер ЕСТЬ NULL
		|			ТОГДА ВЫБОР
		|					КОГДА ВТ_Итог.ЗаказКлиента.Организация <> ВТ_Итог.ПриходныйКассовыйОрдер.Организация
		|							ИЛИ ВТ_Итог.ЗаказКлиента.Организация <> ВТ_Итог.РеализацияТоваров.Организация
		|						ТОГДА ИСТИНА
		|					ИНАЧЕ ЛОЖЬ
		|				КОНЕЦ
		|		КОГДА НЕ ВТ_Итог.ЭквайринговаяОперация ЕСТЬ NULL
		|			ТОГДА ВЫБОР
		|					КОГДА ВТ_Итог.ЗаказКлиента.Организация <> ВТ_Итог.ЭквайринговаяОперация.Организация
		|							ИЛИ ВТ_Итог.ЗаказКлиента.Организация <> ВТ_Итог.РеализацияТоваров.Организация
		|						ТОГДА ИСТИНА
		|					ИНАЧЕ ЛОЖЬ
		|				КОНЕЦ
		|		КОГДА НЕ ВТ_Итог.РеализацияТоваров ЕСТЬ NULL
		|			ТОГДА ВЫБОР
		|					КОГДА ВТ_Итог.ЗаказКлиента.Организация <> ВТ_Итог.РеализацияТоваров.Организация
		|						ТОГДА ИСТИНА
		|					ИНАЧЕ ЛОЖЬ
		|				КОНЕЦ
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЕстьОшибки
		|ИЗ
		|	ВТ_Итог КАК ВТ_Итог";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();

	Если Выборка.Следующий() Тогда
		Оповестить = Выборка.ЕстьОшибки;
	Иначе
		Оповестить = Ложь;
	КонецЕсли;
	
	Если Оповестить Тогда
		Сообщить("Проверьте правильность заполнения связанных документов! Поле 'Организация' отличается!");
	КонецЕсли;
КонецПроцедуры   

Процедура ПроверитьТоварыMarketPlace()
	Объект.ЕстьТоварыMarketPlace = Ложь;
	
	Для Каждого СтрокаТЧ Из Объект.Товары Цикл 
		Если НЕ СтрокаТЧ.Отменено Тогда
			Объект.ЕстьТоварыMarketPlace = Объект.ЕстьТоварыMarketPlace ИЛИ СтрокаТЧ.Номенклатура.ЭтоMarketPlace;
		КонецЕсли;	
	КонецЦикла;
    Элементы.ДекорацияMarketPlace.Видимость = Объект.ЕстьТоварыMarketPlace;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Отменено КАК Отменено
		|ПОМЕСТИТЬ ВТ_Товары
		|ИЗ
		|	&Товары КАК Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Товары.Номенклатура КАК Номенклатура,
		|	ВЫРАЗИТЬ(ВТ_Товары.Номенклатура КАК Справочник.Номенклатура).Реализация КАК Поле1
		|ИЗ
		|	ВТ_Товары КАК ВТ_Товары
		|ГДЕ
		|	НЕ ВЫРАЗИТЬ(ВТ_Товары.Отменено КАК БУЛЕВО)
		|	И (ВЫРАЗИТЬ(ВТ_Товары.Номенклатура КАК Справочник.Номенклатура).Реализация = ИСТИНА
		|			ИЛИ ВЫРАЗИТЬ(ВТ_Товары.Номенклатура КАК Справочник.Номенклатура).ФинансоваяОтчетность = ИСТИНА)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Товары.Номенклатура КАК Номенклатура,
		|	ВЫРАЗИТЬ(ВТ_Товары.Номенклатура КАК Справочник.Номенклатура).Реализация КАК Поле1
		|ИЗ
		|	ВТ_Товары КАК ВТ_Товары
		|ГДЕ
		|	НЕ ВЫРАЗИТЬ(ВТ_Товары.Отменено КАК БУЛЕВО)
		|	И ВЫРАЗИТЬ(ВТ_Товары.Номенклатура КАК Справочник.Номенклатура).BG = ИСТИНА
		|	И ВЫРАЗИТЬ(ВТ_Товары.Номенклатура КАК Справочник.Номенклатура).ФинансоваяОтчетность = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить(,"Номенклатура, Отменено"));
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();

	Элементы.ТоварНаРеализации.Видимость = НЕ РезультатЗапроса[1].Пустой();
	Элементы.ЗапрещенаПродажа.Видимость = НЕ РезультатЗапроса[2].Пустой();
КонецПроцедуры 

