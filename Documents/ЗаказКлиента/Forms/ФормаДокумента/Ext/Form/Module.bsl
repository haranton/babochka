Функция НайтиПромокод(Идентификатор, Партнер)
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОднократныеПромокодыНаСкидку.Промокод.Скидка КАК Скидка,
		|	ОднократныеПромокодыНаСкидку.Промокод КАК Промокод,
		|	ОднократныеПромокодыНаСкидку.Идентификатор КАК Идентификатор,
		|	ОднократныеПромокодыНаСкидку.Партнер КАК Партнер,
		|	ОднократныеПромокодыНаСкидку.НомерТелефона КАК НомерТелефона,
		|	ОднократныеПромокодыНаСкидку.Состояние КАК Состояние,
		|	ОднократныеПромокодыНаСкидку.ДействуетС КАК ДействуетС,
		|	ОднократныеПромокодыНаСкидку.ДействуетДо КАК ДействуетДо
		|ИЗ
		|	РегистрСведений.ОднократныеПромокодыНаСкидку КАК ОднократныеПромокодыНаСкидку
		|ГДЕ
		|	ОднократныеПромокодыНаСкидку.Промокод.Статус = ЗНАЧЕНИЕ(перечисление.СтатусыВидовКартЛояльности.действует)
		|	И ОднократныеПромокодыНаСкидку.Идентификатор = &Идентификатор
		|	И ВЫБОР
		|			КОГДА ОднократныеПромокодыНаСкидку.Промокод.Персонализирован
		|				ТОГДА ОднократныеПромокодыНаСкидку.Партнер = &Партнер
		|		Иначе Истина КОНЕЦ
		|	    |";
	
	Запрос.УстановитьПараметр("Идентификатор", Идентификатор);
	Запрос.УстановитьПараметр("Партнер", Партнер);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
		
	Если Выборка.Следующий() Тогда
		Если Выборка.Состояние <> Перечисления.СтатусыДействияСкидок.Действует
			ИЛИ Выборка.ДействуетС >= ТекущаяДатаСеанса() 
			ИЛИ КонецДня(Выборка.ДействуетДо) <= ТекущаяДатаСеанса() Тогда
				
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Срок действия промокода истёк";
			Сообщение.Сообщить();
			УстановитьПривилегированныйРежим(Ложь);
	
			Возврат Неопределено;
		КонецЕсли;
		Если Выборка.Промокод.КоличествоПримененийКода = 0 
			ИЛИ (Выборка.Промокод.КоличествоПримененийКода > 0 
				И РазрешеноИспользоватьПромокод(Выборка.Промокод, Партнер, Выборка.Промокод.КоличествоПримененийКода)) Тогда
			
			Структура = Новый Структура("Скидка, Промокод, Идентификатор, Партнер, НомерТелефона, Состояние, ДействуетС, ДействуетДо");
			ЗаполнитьЗначенияСвойств(Структура, Выборка);
			
			УстановитьПривилегированныйРежим(Ложь);
	
			Возврат Структура;
		КонецЕсли;
	КонецЕсли;
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = "Промокод не найден";
	
	Если НЕ РезультатЗапроса.Пустой() И Выборка.Промокод.КоличествоПримененийКода > 0 Тогда
		Сообщение.Текст = "Превышено количество применений промокода!";
	КонецЕсли;
		
	Сообщение.Сообщить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Неопределено;
КонецФункции

Процедура ВернутьПромокодВДействие()
	ПараметрыПромокодаСкидки = ПараметрыПромокода;
	
	Если ПараметрыПромокодаСкидки = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если ПараметрыПромокодаСкидки.Промокод.Персонализирован 
		ИЛИ ПараметрыПромокодаСкидки.Промокод.Одноразовый Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		
		ЗаписьРегистра = РегистрыСведений.ОднократныеПромокодыНаСкидку.СоздатьМенеджерЗаписи();
		ЗаписьРегистра.Идентификатор 	= ПараметрыПромокодаСкидки.Идентификатор;
		ЗаписьРегистра.Партнер 			= ПараметрыПромокодаСкидки.Партнер;
		ЗаписьРегистра.НомерТелефона 	= ПараметрыПромокодаСкидки.НомерТелефона;
		ЗаписьРегистра.Промокод 		= ПараметрыПромокодаСкидки.Промокод;
		ЗаписьРегистра.Прочитать();
		
		Попытка
			ЗаписьРегистра.Состояние = Перечисления.СтатусыДействияСкидок.Действует;
			ЗаписьРегистра.ДокументДвижения = Неопределено;
			ЗаписьРегистра.Записать();
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
		
		УстановитьПривилегированныйРежим(Ложь);
		
	Иначе
		//обезличенные запишем с привязкой к покупателю и документу
		УстановитьПривилегированныйРежим(Истина);
		
		Выборка = РегистрыСведений.ОднократныеПромокодыНаСкидку.Выбрать(Новый Структура("Идентификатор", ПараметрыПромокодаСкидки.Идентификатор));
		Пока Выборка.Следующий() Цикл
			
			Если Выборка.ДокументДвижения 	= Объект.Ссылка 
				И Выборка.Партнер 			= Объект.Партнер
				И Выборка.Промокод 			= ПараметрыПромокодаСкидки.Промокод Тогда
				
				Запись = Выборка.ПолучитьМенеджерЗаписи();
				Запись.Удалить();
				Прервать;

			КонецЕсли;
			
		КонецЦикла;
				
		УстановитьПривилегированныйРежим(Ложь);	
	КонецЕсли;
КонецПроцедуры

