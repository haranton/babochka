Функция ПолучитьДанныеПоМТМ()
	Данные = Новый Структура();
	СуммаРучнойСкидки = 0;
	СуммаАвтоматическойСкидки = 0;
	Сумма = 0;
	Евро = Объект.Валюта;
	Для Каждого Стр Из Объект.Товары Цикл
		Если Стр.Отменено = Ложь Тогда
			СуммаРучнойСкидки = СуммаРучнойСкидки + Стр.СуммаРучнойСкидки; 
			СуммаАвтоматическойСкидки = СуммаАвтоматическойСкидки + Стр.СуммаАвтоматическойСкидки;
			Сумма = Сумма + Стр.Сумма;
		КонецЕсли;
	КонецЦикла;
	СуммаЗаказа = РаботаСКурсамиВалют.ПересчитатьВВалюту(Сумма, Объект.Валюта, Евро, Объект.Дата);
	СуммаСкидки = РаботаСКурсамиВалют.ПересчитатьВВалюту(СуммаРучнойСкидки + СуммаАвтоматическойСкидки, Объект.Валюта, Евро, Объект.Дата);

	Данные.Вставить("СуммаЗаказа", СуммаЗаказа);
	Данные.Вставить("СуммаСкидки", СуммаСкидки);
	
	Запрос = Новый Запрос;
	Запрос.Текст =  ТекстЗапросаОстаткиРасчетов();
		
	Запрос.УстановитьПараметр("ЗаказКлиента", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Остаток = 0;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		  Остаток = ВыборкаДетальныеЗаписи.КОплате;
	КонецЦикла;
	
	Остаток = РаботаСКурсамиВалют.ПересчитатьВВалюту(Остаток, Объект.Валюта, Евро, Объект.Дата);
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	РасчетыСКлиентамиОбороты.Регистратор КАК документ,
	               |	-РасчетыСКлиентамиОбороты.СуммаОборот КАК Сумма,
	               |	РасчетыСКлиентамиОбороты.Период КАК дата,
	               |	РасчетыСКлиентамиОбороты.Регистратор.Дата КАК РегистраторДата
	               |ИЗ
	               |	РегистрНакопления.РасчетыСКлиентами.Обороты(, , Регистратор, ОбъектРасчетов.Объект = &ЗаказКлиента) КАК РасчетыСКлиентамиОбороты
	               |ГДЕ
	               |	РасчетыСКлиентамиОбороты.СуммаОборот < 0
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	РегистраторДата УБЫВ";
	Запрос.УстановитьПараметр("ЗаказКлиента", Объект.Ссылка);
	Результат = Запрос.Выполнить();
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ДатаДок = Объект.Дата;
	Иначе
		ДатаДок = ТекущаяДатаСеанса();
	КонецЕсли;
	Если НЕ Результат.Пустой() Тогда
		 Выборка = Результат.Выгрузить();
		 ДатаДок = Выборка[0].РегистраторДата;
	КонецЕсли;

	//СтруктураКурса = РаботаСКурсамиВалют.ПолучитьКурсВалюты(объект.Валюта, ?(ЗначениеЗаполнено(Объект.Ссылка), объект.Дата, ТекущаяДатаСеанса()));
	СтруктураКурса = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Константы.ВалютаУправленческогоУчета.Получить(), ДатаДок);
	
	Данные.Вставить("Остаток", Формат(Остаток,"ЧДЦ=0"));
	Данные.Вставить("Курс", Формат(СтруктураКурса.Курс,"ЧДЦ=2"));

	СуммаВЕвро = РаботаСКурсамиВалют.ПересчитатьВВалюту(Объект.ЗадатокМТМ, Объект.Валюта, Евро, Объект.Дата);
	Данные.Вставить("СуммаВЕвро", СуммаВЕвро);
	
	Возврат Данные;
КонецФункции      

Функция СуммаМТМПолучить()
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РасчетыСКлиентамиОбороты.Регистратор КАК документ,
	|	-РасчетыСКлиентамиОбороты.СуммаОборот КАК Сумма,
	|	РасчетыСКлиентамиОбороты.Период КАК дата,
	|	РасчетыСКлиентамиОбороты.Регистратор.Дата КАК РегистраторДата
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентами.Обороты(, , Регистратор, ОбъектРасчетов.Объект = &ЗаказКлиента) КАК РасчетыСКлиентамиОбороты
	|ГДЕ
	|	РасчетыСКлиентамиОбороты.СуммаОборот < 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	РегистраторДата УБЫВ";
	Запрос.УстановитьПараметр("ЗаказКлиента", Объект.Ссылка);
	Результат = Запрос.Выполнить();
	СуммаМТМ = 0;
	ДатаДок = Дата(1,1,1);
	Если НЕ Результат.Пустой() Тогда
		 Выборка = Результат.Выгрузить();
		 СуммаМТМ =  Выборка[0].Сумма;
		 ДатаДок = Выборка[0].РегистраторДата;
	КонецЕсли;
	Евро = Объект.Валюта;
	СуммаМТМЕвро = РаботаСКурсамиВалют.ПересчитатьВВалюту(СуммаМТМ, Объект.Ссылка.Валюта, Евро, ДатаДок);
	Данные = Новый Структура();
	Данные.Вставить("СуммаМТМЕвро", Формат(СуммаМТМЕвро,"ЧДЦ=0"));
	
	Возврат Данные;
КонецФункции

&НаКлиенте
Процедура ОтменитьСкидкиПоПромокоду()
	ПримененнаяСкидка = ПолучитьСкидкуПромокодаДляУдаления();
		
	Если УправляемыеСкидки.НайтиПоЗначению(ПримененнаяСкидка) <> Неопределено Тогда
		УправляемыеСкидки.Удалить(УправляемыеСкидки.НайтиПоЗначению(ПримененнаяСкидка));
	КонецЕсли;
	
	СтрокиСоСкидкой = Объект.СкидкиНаценки.НайтиСтроки(Новый Структура("СкидкаНаценка",ПримененнаяСкидка));
	
	Для Каждого Строка Из СтрокиСоСкидкой Цикл	
		Объект.СкидкиНаценки.Удалить(Строка);				
	КонецЦикла;
	
	//РАСЧЕТ СКИДОК
	СтруктураПараметры = Новый Структура;
	СтруктураПараметры.Вставить("ПрименятьКОбъекту",                Истина);
	СтруктураПараметры.Вставить("ТолькоПредварительныйРасчет",      Ложь);
	СтруктураПараметры.Вставить("ВосстанавливатьУправляемыеСкидки", Истина);
	СтруктураПараметры.Вставить("УправляемыеСкидки", УправляемыеСкидки);
	
	СтруктураСообщений = РассчитатьСкидкиНаценкиНаСервере(СтруктураПараметры);
	Если СтруктураСообщений.Сообщения.Количество() > 0 И СтруктураСообщений.АвтоматическиОткрывать Тогда
		ОткрытьФорму("ОбщаяФорма.СообщенияСкидокНаценок", СтруктураСообщений, ЭтаФорма, УникальныйИдентификатор);
	КонецЕсли;
	
	ПоказатьОповещениеПользователя(
	НСтр("ru = 'Промокод'"),
	,
	НСтр("ru = 'Промокод на скидку деактивирован'"),
	БиблиотекаКартинок.Информация32);
	
	ВернутьПромокодВДействие();
	
	ПараметрыПромокода = Неопределено;
	Модифицированность = Истина;
КонецПроцедуры   

