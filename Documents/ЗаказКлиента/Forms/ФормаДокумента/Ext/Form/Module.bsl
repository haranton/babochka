&После("СпособМестоДоставкиПеревозчикПриИзменении")
Процедура ba_СпособМестоДоставкиПеревозчикПриИзменении(Элемент)
	//bg
	ВидимостьКурьеров = Объект.СпособДоставки = ПредопределенноеЗначение("Перечисление.СпособыДоставки.ДоКлиента");
