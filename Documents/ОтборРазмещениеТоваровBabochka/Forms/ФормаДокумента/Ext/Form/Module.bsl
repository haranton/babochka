Процедура ЗаполнитьОстаткиПоЯчейке(Команда)
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Склад", Объект.Склад);
	
	ОткрытьФорму("Документ.ОтборРазмещениеТоваровBabochka.Форма.ФормаЗаполнениеОстатковЯчейки", 
				ПараметрыОткрытия,
				ЭтаФорма,
				ЭтаФорма.УникальныйИдентификатор,,,
				Новый ОписаниеОповещения("ЗаполнитьОстаткиПоЯчейкеОбработкаВыбора", ЭтаФорма, ),РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Функция ЗаполнитьОстаткиПоЯчейкеОбработкаВыбора(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		Если НЕ Результат.Свойство("Ячейка") Тогда
			Возврат Неопределено;	
		КонецЕсли; 
		
		Ячейка = Результат.Ячейка;
		
		ЗаполнитьОстатки(Ячейка);
		
	КонецЕсли; 

	Возврат Неопределено;
	
КонецФункции

&НаСервере
Функция ЗаполнитьОстатки(Ячейка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТоварыВЯчейкахBabochkaОстатки.Номенклатура КАК Номенклатура,
		|	ТоварыВЯчейкахBabochkaОстатки.Характеристика КАК Характеристика,
		|	ТоварыВЯчейкахBabochkaОстатки.Ячейка КАК Ячейка,
		|	ТоварыВЯчейкахBabochkaОстатки.ВНаличииОстаток КАК Количество
		|ИЗ
		|	РегистрНакопления.ТоварыВЯчейкахBabochka.Остатки(, Ячейка = &Ячейка) КАК ТоварыВЯчейкахBabochkaОстатки
		|ГДЕ
		|	ТоварыВЯчейкахBabochkaОстатки.ВНаличииОстаток > 0";
	
	Запрос.УстановитьПараметр("Ячейка", Ячейка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл  
		
		СтрокаТЧ = Объект.ТоварыОтбор.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, Выборка);
			
	КонецЦикла;	  
	
КонецФункции


&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Объект.Статус <> ПредопределенноеЗначение("Перечисление.СтатусыОтборовРазмещенийТоваровBabochka.Выполнено") Тогда
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыОтборовРазмещенийТоваровBabochka.Выполнено");
	КонецЕсли;
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение
		И Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийОтбораРазмещенияТоваровBabochka.СнятиеСРезерва") 
		И НЕ РазрешеноРедактирование() Тогда      
		Отказ = Истина;
		ПоказатьПредупреждение(,"Пользователю запрещено снимать с резерва", 10);
	КонецЕсли;
	
	Если НачалоДня(Объект.Дата) <> НачалоДня(ТекущаяДатаСеанса())
		И ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение
		И НЕ РазрешеноПроведениеЗаднимЧислом() Тогда
		
		Отказ = Истина;
		ПоказатьПредупреждение(,"Пользователю запрещено проводить документы задним числом", 10);
	
	КонецЕсли;
	
	Если НЕ ДоступныПолныеПрава() 
		И НЕ Объект.Проведен
		И ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		Объект.Дата = ТекущаяДатаСеанса();
		
	КонецЕсли;  
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДоступныПолныеПрава()   
	
	Возврат РольДоступна("ПолныеПрава");
	
КонецФункции

&НаСервереБезКонтекста
Функция РазрешеноПроведениеЗаднимЧислом()   
	
	Возврат РольДоступна("РазрешеноПроведениеОтбораЗаднимЧисломАдресноеХранение") ИЛИ РольДоступна("ПолныеПрава");
	
КонецФункции

&НаСервереБезКонтекста
Функция РазрешеноРедактирование()     
	
	Возврат РольДоступна("РазрешеноСниматьСРезерваАдресноеХранение") ИЛИ РольДоступна("ПолныеПрава");
	
КонецФункции

&НаКлиенте
Процедура ВосстановитьДвиженияРезерва(Команда)
	
	ОткрытьФорму("Документ.ОтборРазмещениеТоваровBabochka.Форма.ФормаВводаПароля", 
				,
				ЭтаФорма,
				ЭтаФорма.УникальныйИдентификатор,,,
				Новый ОписаниеОповещения("ОбработатьВводПароляИВосстановитьДвижения", ЭтаФорма, ),РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Функция ОбработатьВводПароляИВосстановитьДвижения(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено 
		И Результат.Свойство("ПарольВерен") 
		И Результат.ПарольВерен Тогда
		
		Для каждого СтрокаТЧ Из Объект.ТоварыОтбор Цикл
			СтрокаТЧ.НеОтображатьДвижения = Ложь;	
		КонецЦикла; 
		
		Модифицированность = Истина;
	КонецЕсли; 
	
КонецФункции

&НаКлиенте
Процедура УпорядочитьПоНоменклатуре(Команда)
	
	УпорядочитьНоменклатуруНаСервере();
		
КонецПроцедуры

&НаСервере
Процедура УпорядочитьНоменклатуруНаСервере()
	
	ЭтотОбъект.Объект.ТоварыОтбор.Сортировать("Ячейка, Номенклатура, Характеристика");
	
КонецПроцедуры

&НаСервере
Процедура УпорядочитьРазмещениеНаСервере() 
	
	ЭтотОбъект.Объект.ТоварыРазмещение.Сортировать("Ячейка, Номенклатура, Характеристика");
	
КонецПроцедуры

&НаКлиенте
Процедура УпорядочитьРазмещение(Команда)
	УпорядочитьРазмещениеНаСервере();
КонецПроцедуры




