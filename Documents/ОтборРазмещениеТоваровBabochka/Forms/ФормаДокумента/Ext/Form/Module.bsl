#Область ОписаниеПеременных

&НаКлиенте
Перем КэшированныеЗначения; //используется механизмом обработки изменения реквизитов ТЧ

&НаКлиенте
Перем ТекущиеДанныеИдентификатор; //используется для передачи текущей строки в обработчик ожидания

&НаКлиенте
Перем ПараметрыДляЗаписи Экспорт;

#КонецОбласти

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);

	Если Параметры.Ключ.Пустая() Тогда
		
		Если НЕ ЗначениеЗаполнено(Объект.Статус) Тогда
			Объект.Статус = Перечисления.СтатусыОтборовРазмещенийТоваровBabochka.Подготовлено;	
		КонецЕсли; 
		
		Если ЗначениеЗаполнено(Объект.Распоряжение) 
			И НЕ ЗначениеЗаполнено(Объект.ВидОперации) Тогда    
			
			Если ТипЗнч(Объект.Распоряжение) = Тип("ДокументСсылка.ПриходныйОрдерНаТовары") 
				ИЛИ ТипЗнч(Объект.Распоряжение) = Тип("ДокументСсылка.ОприходованиеИзлишковТоваров") Тогда
				 Объект.ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваровBabochka.Размещение;
			 ИначеЕсли ТипЗнч(Объект.Распоряжение) = Тип("ДокументСсылка.РасходныйОрдерНаТовары")
				 ИЛИ ТипЗнч(Объект.Распоряжение) = Тип("ДокументСсылка.СписаниеНедостачТоваров") 
				 ИЛИ ТипЗнч(Объект.Распоряжение) = Тип("ДокументСсылка.ЗаявкаНаПеремещение") Тогда 
				 Объект.ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваровBabochka.Отбор;
			 Иначе
				 Объект.ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваровBabochka.Перемещение;
			 КонецЕсли;
			 
		Иначе
			Если НЕ ЗначениеЗаполнено(Объект.ВидОперации) Тогда
				Объект.ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваровBabochka.Размещение;	
			КонецЕсли;
		КонецЕсли; 
		
		Объект.Ответственный = Пользователи.ТекущийПользователь();
		Объект.ДатаНачалаВыполнения = ТекущаяДатаСеанса();
		
	КонецЕсли;  
	
	Элементы.ВосстановитьРезерв.Видимость = Объект.ЭтоРезерв;	
	
	УстановитьУсловноеОформление();
	
	Если НЕ Параметры.Ключ.Пустая() Тогда
		ЗаполнитьИспользованиеХарактеристик();
	КонецЕсли;
	
	Если НЕ Параметры.Ключ.Пустая() 
		И Объект.Статус = Перечисления.СтатусыОтборовРазмещенийТоваровBabochka.Выполнено 
		И НЕ РольДоступна("ПолныеПрава") Тогда
		УстановитьДоступностьЭлементов(Истина);
	КонецЕсли;
	
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма, "Товары");

	// СтандартныеПодсистемы.ПодключаемыеКоманды 
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект); 
	//ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, , "ТоварыРазмещение"); 
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды    
	
КонецПроцедуры

&НаСервере
Функция УстановитьДоступностьЭлементов(Запрет = Истина)
	      	
	Элементы.ТоварыРазмещение.ТолькоПросмотр = Запрет;//ДоступностьЭлементов;		
	Элементы.ТоварыОтбор.ТолькоПросмотр 	 = Запрет;		
	Элементы.ЗаполнитьЯчейкиРасход.Доступность = НЕ Запрет;
	Элементы.ТоварыРазмещениеЗаполнитьЯчейки.Доступность = НЕ Запрет;
	Элементы.ТоварыОтборУстановитьЯчейкуОтбор.Доступность = НЕ Запрет;
		     	
КонецФункции

Функция ЗаполнитьИспользованиеХарактеристик()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧРазмещение.Номенклатура КАК Номенклатура1
		|ПОМЕСТИТЬ ВТ_ТоварыРазмещение
		|ИЗ
		|	&ТЧРазмещение КАК ТЧРазмещение
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЧ_Отбор.Номенклатура КАК Номенклатура1
		|ПОМЕСТИТЬ ВТ_Отбор
		|ИЗ
		|	&ТЧ_Отбор КАК ТЧ_Отбор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ВТ_ТоварыРазмещение.Номенклатура1 КАК Справочник.Номенклатура).ИспользованиеХарактеристик КАК ИспользованиеХарактеристик,
		|	ВТ_ТоварыРазмещение.Номенклатура1 КАК Номенклатура
		|ИЗ
		|	ВТ_ТоварыРазмещение КАК ВТ_ТоварыРазмещение
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВЫРАЗИТЬ(ВТ_Отбор.Номенклатура1 КАК Справочник.Номенклатура).ИспользованиеХарактеристик,
		|	ВТ_Отбор.Номенклатура1
		|ИЗ
		|	ВТ_Отбор КАК ВТ_Отбор";
	
	Запрос.УстановитьПараметр("ТЧ_Отбор", Объект.ТоварыОтбор.Выгрузить(,"Номенклатура"));
	Запрос.УстановитьПараметр("ТЧРазмещение", Объект.ТоварыРазмещение.Выгрузить(,"Номенклатура"));
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	Для каждого СтрокаТЧ Из Объект.ТоварыОтбор Цикл
		НайденнаяСтрока = ТЗ.Найти(СтрокаТЧ.Номенклатура, "Номенклатура");
		Если НайденнаяСтрока <> Неопределено Тогда
			СтрокаТЧ.ИспользованиеХарактеристик = НайденнаяСтрока.ИспользованиеХарактеристик;	
		КонецЕсли;
	КонецЦикла;
	Для каждого СтрокаТЧ Из Объект.ТоварыРазмещение Цикл
		НайденнаяСтрока = ТЗ.Найти(СтрокаТЧ.Номенклатура, "Номенклатура");
		Если НайденнаяСтрока <> Неопределено Тогда
			СтрокаТЧ.ИспользованиеХарактеристик = НайденнаяСтрока.ИспользованиеХарактеристик;	
		КонецЕсли;
	КонецЦикла;

КонецФункции

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	// СтандартныеПодсистемы.ПодключаемыеКоманды 
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект); 
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды 
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УстановитьВидимостьЭлементов(); 
	Если Параметры.Ключ.Пустая()
		И ЗначениеЗаполнено(Объект.Распоряжение)
		И ТипЗнч(Объект.Распоряжение) <> Тип("ДокументСсылка.ИнвентаризацияАдресногоСклада") 
		И НЕ Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийОтбораРазмещенияТоваровBabochka.СнятиеСРезерва") Тогда   
		ЗаполнитьЯчейкиНаСервере(Истина);
		ЗаполнитьЯчейкиНаСервере(Ложь);
	КонецЕсли;  
	
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "СканерШтрихкода");
	//
	// СтандартныеПодсистемы.ПодключаемыеКоманды 
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект); 
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды      
	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
		
	// ПодключаемоеОборудование
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Тогда
			ОбработатьШтрихкоды(МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВМассив(Параметр));
		КонецЕсли;
	КонецЕсли;
	// Конец ПодключаемоеОборудование
	
КонецПроцедуры

&НаСервере
Процедура НоменклатураПриИзмененииСервер(КэшированныеЗначения)
	
	ТекущаяСтрока = Объект.Товары.НайтиПоИдентификатору(Элементы.Товары.ТекущаяСтрока);
	
	СтруктураДействийСТекущейСтрокой = Новый Структура;
	СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));
	СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
	СтруктураДействийСТекущейСтрокой.Вставить("ПроверитьХарактеристикуПоВладельцу", ТекущаяСтрока.Характеристика);
	СтруктураДействийСТекущейСтрокой.Вставить("ПроверитьЗаполнитьУпаковкуПоВладельцу", ТекущаяСтрока.Упаковка);
	СтруктураДействийСТекущейСтрокой.Вставить("ПересчитатьКоличествоЕдиниц");
	СтруктураДействийСТекущейСтрокой.Вставить("НоменклатураПриИзмененииПереопределяемый", Новый Структура("ИмяФормы, ИмяТабличнойЧасти",
		ЭтаФорма.ИмяФормы, "Товары"));
	
	УпаковочныеЛистыСервер.НоменклатураУпаковочныйЛистПриИзменении(ЭтаФорма, Объект.Товары,
		"ТоварыНоменклатура", КэшированныеЗначения, СтруктураДействийСТекущейСтрокой);
		
		
КонецПроцедуры

