&НаКлиенте
Функция УстановитьВидимостьЭлементов()
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийОтбораРазмещенияТоваровBabochka.Перемещение") Тогда
		
		Элементы.ЗонаОтгрузки.Видимость = Ложь;
		Элементы.ЗонаПриемки.Видимость = Ложь;
		Элементы.ГруппаТоварыОтбор.Видимость = Истина;
		Элементы.ГруппаТоварыРазмещение.Видимость = Истина;
		
		Объект.ЗонаОтгрузки = Неопределено;
		Объект.ЗонаПриемки = Неопределено;
		Элементы.ТоварыРазмещениеПеренестиИзОтбора.Видимость = Истина;
	
		Возврат 0;
		
	КонецЕсли;
	
	ЭтоРазмещение = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийОтбораРазмещенияТоваровBabochka.Размещение")
				ИЛИ Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийОтбораРазмещенияТоваровBabochka.СнятиеСРезерва");
	
	Элементы.ЗонаОтгрузки.Видимость = НЕ ЭтоРазмещение;
	Элементы.ЗонаПриемки.Видимость = ЭтоРазмещение;
	Элементы.ГруппаТоварыОтбор.Видимость = НЕ ЭтоРазмещение;
	Элементы.ГруппаТоварыРазмещение.Видимость = ЭтоРазмещение;
	Элементы.ГруппаТоварыОстатки.Видимость = Ложь;
	Элементы.ТоварыРазмещениеПеренестиИзОтбора.Видимость = Ложь;
	
	Если НЕ ЗначениеЗаполнено(Объект.Распоряжение) Тогда
		
		Элементы.ЗонаОтгрузки.Видимость = Ложь;
		Элементы.ЗонаПриемки.Видимость = Ложь;
			
	КонецЕсли;

	Возврат 1;
	
КонецФункции

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент) 
	
	УстановитьВидимостьЭлементов(); 
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийОтбораРазмещенияТоваровBabochka.Отбор") Тогда
		Объект.ТоварыРазмещение.Очистить();
		Объект.ЗонаПриемки = Неопределено;	
	ИначеЕсли Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийОтбораРазмещенияТоваровBabochka.Размещение") Тогда
		Объект.ТоварыОтбор.Очистить(); 
		Объект.ЗонаОтгрузки = Неопределено;
	ИначеЕсли Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийОтбораРазмещенияТоваровBabochka.Перемещение") Тогда
		Объект.ТоварыОтбор.Очистить();
		Объект.ТоварыРазмещение.Очистить();  
		Объект.Распоряжение = Неопределено;
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЯчейкиНаСервере(ЭтоПриход = Истина) 
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	Результат = ДокументОбъект.ЗаполнитьЯчейки(ЭтоПриход);
	Если Результат.Товары <> Неопределено Тогда 
		Если ЭтоПриход Тогда
			Объект["ТоварыРазмещение"].Загрузить(Результат.Товары);
		Иначе
			Объект["ТоварыОтбор"].Загрузить(Результат.Товары); 
			
			//чтобы снимать каждую отдельную строку в резерве
			Если Объект.ЭтоРезерв Тогда
				Для каждого СтрокаТЧ Из Объект.ТоварыОтбор Цикл
					Если СтрокаТЧ.Количество > 1 Тогда   
						КоличествоРазбить = СтрокаТЧ.Количество;
						СтрокаТЧ.Количество = 1;
						КоличествоРазбить = КоличествоРазбить - 1;
						Пока КоличествоРазбить > 0 Цикл
							НоваяСтрока = Объект.ТоварыОтбор.Добавить();
							ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
							НоваяСтрока.Количество = 1;
							КоличествоРазбить = КоличествоРазбить - 1;
						КонецЦикла;
					КонецЕсли;		
				КонецЦикла;	
			КонецЕсли;
		КонецЕсли;
		Если Результат.МассивОшибок.Количество() Тогда
			Для каждого СтрокаОшибка Из Результат.МассивОшибок Цикл
				Сообщить(СтрокаОшибка);	
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьЯчейки(Команда)  
	
	ОчиститьСообщения();
	ЗаполнитьЯчейкиНаСервере();    
	
КонецПроцедуры

&НаКлиенте
Процедура СтатусПриИзменении(Элемент)
	
	Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыОтборовРазмещенийТоваровBabochka.Выполнено") Тогда
		Объект.ДатаОкончанияВыполнения = ТекущаяДатаСеанса();
	Иначе
		Объект.ДатаОкончанияВыполнения = Дата(1,1,1);
	КонецЕсли;  
	
	Если НЕ Параметры.Ключ.Пустая() 
		И Объект.Статус <> ПредопределенноеЗначение("Перечисление.СтатусыОтборовРазмещенийТоваровBabochka.Выполнено") Тогда
		
		ЕстьДвиженияПослеДокумента = ВыполнитьПроверкуНаИзменениеСтатуса();
		Если ЕстьДвиженияПослеДокумента Тогда
			Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыОтборовРазмещенийТоваровBabochka.Выполнено");   
			ТекстСообщения = "Нельзя изменить статус документа.
							 |Для изменения статуса сначала распроведите все документы после него."; 
			ПоказатьПредупреждение(,ТекстСообщения,,"BABOCHKA"); 
		Иначе
			УстановитьДоступностьЭлементов(Ложь);
		КонецЕсли;
	Иначе
		УстановитьДоступностьЭлементов(Ложь);  	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ВыполнитьПроверкуНаИзменениеСтатуса()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОстаткиВЯчейкахОбороты.Регистратор КАК Регистратор
		|ИЗ
		|	РегистрНакопления.ОстаткиВЯчейках.Обороты(, , Регистратор, ) КАК ОстаткиВЯчейкахОбороты
		|ГДЕ
		|	ОстаткиВЯчейкахОбороты.Регистратор = &Регистратор";
	
	Запрос.УстановитьПараметр("Регистратор", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		ЕстьДвиженияПослеДокумента = АдресноеХранениеBabochka.ВыполнитьПроверкуЕстьДвиженияПослеДокумента(Объект.Ссылка, Ложь);
	
		Возврат ЕстьДвиженияПослеДокумента;
			
	КонецЕсли;	
	             
	Возврат Ложь;
	
КонецФункции

