	Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);

	Поток = Ответ.ПолучитьТелоКакПоток();
	Кодировка = "utf-8"; 

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.ОткрытьПоток(Поток, Кодировка); 
	Результат = ПрочитатьJSON(ЧтениеJSON);
	Если ТипЗнч(Результат) = Тип("Структура") 
		И Результат.Свойство("access_token") Тогда
		
		Константы.СДЭКТокен.Установить(Результат.access_token);
		
	КонецЕсли; 

	ОтветСервера = Ответ.ПолучитьТелоКакСтроку("UTF-8"); // ЧтениеJSON.Закрыть();

КонецПроцедуры

