Функция СформироватьТекстЗапросаДляРасчета()
	
	Результат = ПолучитьДанныеЗаказа(); 
	ВыборкаШапка = Результат.ВыборкаШапка;
	ВыборкаШапка.Следующий();
	ВыборкаМесто = Результат.ВыборкаТовары;
	
	РезОтправка = Новый Структура();
	РезОтправка.Вставить("type", 1);
	РезОтправка.Вставить("currency", 1);
	
	from_location = Новый Структура();
	from_location.Вставить("code", 137);
	РезОтправка.Вставить("from_location", from_location);
	
	to_location = Новый Структура();
	to_location.Вставить("code", ВыборкаШапка.ГородДоставкиКод);
	to_location.Вставить("address", ВыборкаШапка.АдресДоставки);
	РезОтправка.Вставить("to_location", to_location);
	
	packages = Новый Массив;
	
	Пока ВыборкаМесто.Следующий() Цикл
		
		Упаковка = Новый Структура();
		
		Упаковка.Вставить("height", 17);
		Упаковка.Вставить("length", 42);
		Упаковка.Вставить("width", 33);
		Упаковка.Вставить("weight", Результат.КоличествоТоваров * 700);
		
		packages.Добавить(Упаковка);
	
	КонецЦикла;

	РезОтправка.Вставить("packages", packages);
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, РезОтправка);
	
	Возврат ЗаписьJSON.Закрыть();

КонецФункции

&НаКлиенте
Процедура ВыбратьТариф(Команда)
	
	Идентификатор = 0;
	ГалкаУстановлена = Ложь;
	Для каждого СтрокаТЧ Из ТЗРезультат Цикл
		Если СтрокаТЧ.Галка Тогда
			Если ГалкаУстановлена Тогда
				ПоказатьПредупреждение(, "Выберите один тариф!" ,, "BABOCHKA");
				Возврат;
			Иначе
				ГалкаУстановлена = Истина;	
				Идентификатор = СтрокаТЧ.ПолучитьИдентификатор();
			КонецЕсли; 
		КонецЕсли; 	
	КонецЦикла; 
	Если НЕ ГалкаУстановлена Тогда
		
		ПоказатьПредупреждение(, "Ни один тариф не выбран!" ,, "BABOCHKA");
		Возврат;
		
	КонецЕсли; 
	
	Ответ = ПолучитьСтруктуруОтвета();
	ВыбранНедопустимыйТипДоставки = ПроверитьЗаполнениеТарифаВБазе(Идентификатор);
	Если ВыбранНедопустимыйТипДоставки Тогда
		ПоказатьПредупреждение(,"Данный тип доставки не поддерживается, обратитесь к администратору.",,"BABOCHKA");	
	КонецЕсли; 
	СтрокаТЗ = ТЗРезультат.НайтиПоИдентификатору(Идентификатор);
	Если СтрокаТЗ <> Неопределено И НЕ ВыбранНедопустимыйТипДоставки Тогда
		ЗаполнитьЗначенияСвойств(Ответ, СтрокаТЗ);
		Закрыть(Ответ);
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Функция ПроверитьЗаполнениеТарифаВБазе(Идентификатор)
	
	СтрокаТЗ = ТЗРезультат.НайтиПоИдентификатору(Идентификатор);
	Если НЕ ЗначениеЗаполнено(СтрокаТЗ.ТарифВБазе) Тогда
		
		СоответствиеТарифовДоставки = ПолучитьСоответствиеТарифовДоставки();
		
		ТарифСДЭК = Справочники.ТарифыСДЭКИМ.СоздатьЭлемент();
		ТарифСДЭК.КодТарифа = СтрокаТЗ.tariff_code;
		ТарифСДЭК.Наименование = СтрокаТЗ.tariff_name;
		ТарифСДЭК.Описание = СтрокаТЗ.tariff_description;
		РежиДоставки = СоответствиеТарифовДоставки.Получить(СтрокаТЗ.delivery_mode);
		Если РежиДоставки = Неопределено Тогда
			Возврат Истина;
		КонецЕсли; 
		Если НЕ ЭтоВозврат Тогда
			ТарифСДЭК.Отключен = Истина;
		КонецЕсли; 
		ТарифСДЭК.РежимДоставки = РежиДоставки;
		ТарифСДЭК.Записать();
		
		СтрокаТЗ.ТарифВБазе = ТарифСДЭК.Ссылка;
		
	КонецЕсли; 
	
	Возврат Ложь;
	
КонецФункции

Функция ПолучитьСоответствиеТарифовДоставки()
	
	Соответствие = Новый Соответствие();
	Соответствие.Вставить(1, Перечисления._ТипыДоставки.ДверьДверь);
	Соответствие.Вставить(2, Перечисления._ТипыДоставки.ДверьСклад);
	Соответствие.Вставить(3, Перечисления._ТипыДоставки.ДоДвери);
	Соответствие.Вставить(4, Перечисления._ТипыДоставки.ДоСклада);
	
	ВОзврат Соответствие;
	
КонецФункции
 
&НаКлиенте
Функция ПолучитьСтруктуруОтвета()
	
	Результат = Новый Структура();
	Результат.Вставить("ТарифВБазе", ПредопределенноеЗначение("Справочник.ТарифыСДЭКИМ.ПустаяСсылка"));
	
	Возврат Результат;
	
КонецФункции
 