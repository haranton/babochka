Функция ОтправитьНаСайтЗаказ()
	
	Попытка
		
		Токен = "Bearer "+ Константы.СДЭКТокен.Получить();
		HTTPСоединение = Новый HTTPСоединение(URL, , , , , , Новый ЗащищенноеСоединениеOpenSSL(), );
		HTTPЗапрос = Новый HTTPЗапрос("/v2/orders/");
		
		HTTPЗапрос.Заголовки.Вставить("Authorization", Токен); 
	    HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		
		HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаЗапроса); 
		Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
		
		Поток = Ответ.ПолучитьТелоКакПоток();
		Кодировка = "utf-8"; 

		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.ОткрытьПоток(Поток, Кодировка); 
		Результат = ПрочитатьJSON(ЧтениеJSON);
		ОтветСервера = Ответ.ПолучитьТелоКакСтроку("UTF-8"); // ЧтениеJSON.Закрыть();
		
		Если ТипЗнч(Результат) = Тип("Структура") 
			И Результат.Свойство("requests") Тогда
			
			request = Результат.requests[0];
			Если request.state = "ACCEPTED" Тогда
				Если Результат.Свойство("entity") 
					И Результат.entity.Свойство("uuid") Тогда
					
					Uuid_ = Результат.entity.uuid;
					ЗаявкаОбъект = Заявка.ПолучитьОбъект();
					ЗаявкаОбъект.СДЭКUuid = Uuid_;
					ЗаявкаОбъект.Записать();
					
				КонецЕсли; 		
			КонецЕсли; 
			Если request.state = "INVALID"
				И request.type = "AUTH" Тогда
				АвторизацияНаСервере();
				Возврат Истина;
			КонецЕсли; 
			Если request.Свойство("errors") Тогда
				errors = request.errors[0];
				Ошибки = errors.message;
			КонецЕсли; 
		КонецЕсли;
		
		Request = СериализацияЗначения(СтрокаЗапроса);
	    ПреобразоватьИЗаписатьЛог(Request, Результат, ОтветСервера, "СДЭК Регистрация заказа", "Заявка "+Заявка.Номер);
		
		Возврат Ложь;
	Исключение
		
        Request = СериализацияЗначения(ОписаниеОшибки());
	    ПреобразоватьИЗаписатьЛог(Request, Результат, ОтветСервера, "СДЭК Регистрация заказа", "Заявка "+Заявка.Номер);
		
		Возврат Ложь;
		
    КонецПопытки;
КонецФункции

Функция СериализацияЗначения(ЗначениеПараметра)
	
	Если ТипЗнч(ЗначениеПараметра) = Тип("СписокXDTO")
		 Или ТипЗнч(ЗначениеПараметра) = Тип("ОбъектXDTO")
		 Или ТипЗнч(ЗначениеПараметра) = Тип("ЗначениеXDTO") Тогда
		ЗаписьXML = Новый ЗаписьXML;
		ЗаписьXML.УстановитьСтроку();
		ФабрикаXDTO.ЗаписатьXML(ЗаписьXML, ЗначениеПараметра);
		Результат = ЗаписьXML.Закрыть();
	Иначе
		Результат = XMLСтрока(ЗначениеПараметра);
	КонецЕсли;
	Возврат Результат;
	
КонецФункции

Функция ПреобразоватьИЗаписатьЛог(Request, Response, ResponseСтрокой, ИмяМетода, НаименованиеЛога)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	
	Попытка
		ЗаписатьJSON(ЗаписьJSON, Response);
		ОтветСДЭК = ЗаписьJSON.Закрыть();
	Исключение
	    ОтветСДЭК = ResponseСтрокой;
	КонецПопытки; 
	
	
	ЗаписатьЛог(НаименованиеЛога, Request, ОтветСДЭК, ИмяМетода, Заявка);
		
КонецФункции
 
Процедура ЗаписатьЛог(НаименованиеЛога, Request, Response, ИмяМетода, Основание)

	ЛогЗаписи = Справочники.ЛогиОбменовСВнешнимиСистемами.СоздатьЗапись(НаименованиеЛога);
	ЛогЗаписи.ДобавитьПараметр("Request", Request);
	ЛогЗаписи.ДобавитьПараметр("Response", Response);
	ЛогЗаписи.ТипДанных = ИмяМетода;
	ЛогЗаписи.Основание = Основание;
	ЛогЗаписи.Записать();   		

