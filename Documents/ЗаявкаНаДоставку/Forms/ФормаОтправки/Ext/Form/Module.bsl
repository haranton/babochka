		|	ЕСТЬNULL(ЗаявкаНаДоставку.СДЭКПунктВыдачиЗаказа.КодПВЗ, """") КАК КодПВЗ
		|ИЗ
		|	Документ.ЗаявкаНаДоставку КАК ЗаявкаНаДоставку
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТелефонПартнера КАК ТелефонПартнера
		|		ПО (ИСТИНА)
		|ГДЕ
		|	ЗаявкаНаДоставку.Ссылка = &Заявка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаявкаНаДоставкуТовары.Номенклатура.Код КАК ware_key,
		|	ЗаявкаНаДоставкуТовары.Номенклатура.Наименование + "" "" + ЕСТЬNULL(ЗаявкаНаДоставкуТовары.Характеристика.НаименованиеПолное, """") КАК name,
		|	ВЫРАЗИТЬ(ЗаявкаНаДоставкуТовары.Сумма / ЗаявкаНаДоставкуТовары.Количество КАК ЧИСЛО(15, 2)) КАК cost,
		|	ЗаявкаНаДоставкуТовары.Количество КАК amount,
		|	700 КАК weight,
		|	ЗаявкаНаДоставкуТовары.Место КАК Место,
		|	ЗаявкаНаДоставкуТовары.Номенклатура.ОсобенностьУчета = ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.ОбувнаяПродукция)
		|		ИЛИ ЗаявкаНаДоставкуТовары.Номенклатура.ОсобенностьУчета = ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.Духи)
		|		ИЛИ ЗаявкаНаДоставкуТовары.Номенклатура.ОсобенностьУчета = ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.ЛегкаяПромышленность)
		|		ИЛИ ЗаявкаНаДоставкуТовары.Номенклатура.ОсобенностьУчета = ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.ПродукцияМаркируемаяДляГИСМ) КАК МаркируемыйТовар,
		|	ЗаявкаНаДоставкуТовары.Номенклатура.ОсобенностьУчета = ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.ПродукцияМаркируемаяДляГИСМ) КАК ЭтоМех,
		|	ЗаявкаНаДоставкуТовары.Номенклатура КАК Номенклатура,
		|	ЗаявкаНаДоставкуТовары.Характеристика КАК Характеристика,
		|	ЗаявкаНаДоставкуТовары.Заказ КАК Заказ,
		|	ЗаявкаНаДоставкуТовары.Номенклатура.Код КАК НоменклатураКод
		|ИЗ
		|	Документ.ЗаявкаНаДоставку.Товары КАК ЗаявкаНаДоставкуТовары
		|ГДЕ
		|	ЗаявкаНаДоставкуТовары.Ссылка = &Заявка
		|ИТОГИ ПО
		|	Место
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МаркируемыеТоварыВЗаказеКлиента.ЗаказКлиента КАК ЗаказКлиента,
		|	МаркируемыеТоварыВЗаказеКлиента.Номенклатура КАК Номенклатура,
		|	МаркируемыеТоварыВЗаказеКлиента.Характеристика КАК Характеристика,
		|	МаркируемыеТоварыВЗаказеКлиента.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
		|	МаркируемыеТоварыВЗаказеКлиента.Серия КАК Серия
		|ИЗ
		|	РегистрСведений.МаркируемыеТоварыВЗаказеКлиента КАК МаркируемыеТоварыВЗаказеКлиента
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаДоставку.Товары КАК ЗаявкаНаДоставкуТовары
		|		ПО МаркируемыеТоварыВЗаказеКлиента.ЗаказКлиента = ЗаявкаНаДоставкуТовары.Заказ
		|			И МаркируемыеТоварыВЗаказеКлиента.Номенклатура = ЗаявкаНаДоставкуТовары.Номенклатура
		|			И МаркируемыеТоварыВЗаказеКлиента.Характеристика = ЗаявкаНаДоставкуТовары.Характеристика
		|ГДЕ
		|	ЗаявкаНаДоставкуТовары.Ссылка = &Заявка";
	
	Запрос.УстановитьПараметр("Заявка", Заявка);
	Запрос.УстановитьПараметр("ВидНоменклатурыУслуги", Справочники.ВидыНоменклатуры.НайтиПоНаименованию("Услуги"));
