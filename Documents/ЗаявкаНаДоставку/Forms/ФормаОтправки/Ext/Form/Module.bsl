
&НаСервере
Процедура ПриОткрытииНаСервере(Заявка)
	
	Если (Заявка.СДЭКТипДоставки = Перечисления._ТипыДоставки.ДверьСклад
		ИЛИ Заявка.СДЭКТипДоставки = Перечисления._ТипыДоставки.ДоСклада) 
		И НЕ ЗначениеЗаполнено(Заявка.СДЭКПунктВыдачиЗаказа) Тогда
		ЕстьОшибки = Истина;
		Ошибки = "Пункт выдачи заказа должен быть заполнен!";
	КонецЕсли;
	
	Результат = ПроверитьЗаполнениеПолейСДЭК(Заявка);
	ЕстьОшибкиЗаполнения = Результат.ЕстьОшибкиЗаполнения;
	
	Если ЕстьОшибкиЗаполнения Тогда
		
		Если ЗначениеЗаполнено(Результат.СписокОшибок) Тогда
			Ошибки = "Для отправки заказа необходимо заполнить все поля!"+Символы.ПС + Результат.СписокОшибок;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Результат.ОшибкаНесоответствияОплат) Тогда
			Ошибки = Результат.ОшибкаНесоответствияОплат;
		КонецЕсли;
		
		Элементы.Отправить.Доступность = Ложь;
		
	КонецЕсли; 

	Если НЕ ЭтоВызовКурьера
		И ЗначениеЗаполнено(Заявка.СДЭКНомер) Тогда
		Ошибки = "Uuid заполнен, заявка уже выгружена. ";
		Элементы.Отправить.Доступность = Ложь;
	КонецЕсли; 
	
	Если ЭтоВызовКурьера
		И ЗначениеЗаполнено(Заявка.СДЭКНомерЗаявкиКурьера) Тогда
		
		Ошибки = "Заявка уже выгружена. ";
		Элементы.ОтправитьВызовКурьера.Доступность = Ложь;
		
	КонецЕсли;

КонецПроцедуры

Функция ПроверитьЗаполнениеПолейСДЭК(Заявка)
	
	Результат = Новый Структура();
	СписокОшибок = "";
	ОшибкаСтатусОплачен = "";
	ОшибкаНесоответствияОплат = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаявкаНаДоставку.Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка) КАК ФИОПолучателя,
		|	ЗаявкаНаДоставку.АдресДоставки = """" КАК АдресДоставки,
		|	ЗаявкаНаДоставку.СДЭКГородДоставки = ЗНАЧЕНИЕ(Справочник.ГородаСДЭК.ПустаяСсылка) КАК ГородКуда,
		|	ЗаявкаНаДоставку.СтраховатьГруз = ЛОЖЬ КАК ИспользуетсяСтрахованиеГруза,
		|	ЗаявкаНаДоставку.СДЭКТипДоставки = ЗНАЧЕНИЕ(Перечисление._ТипыДоставки.ПустаяСсылка) КАК ТипДоставки,
		|	ЗаявкаНаДоставку.НомерПоДаннымКлиента = """" КАК НомерНаСайте,
		|	ЗаявкаНаДоставку.ТранспортнаяКомпания <> ЗНАЧЕНИЕ(Перечисление.ТранспортныеКомпании.CDEK) КАК ТранспортнаяКомпания,
		|	ЗаявкаНаДоставку.СуммаНаложенногоПлатежа КАК СуммаНаложенногоПлатежа,
		|	ЗаявкаНаДоставку.НаложенныйПлатеж КАК НаложенныйПлатеж
		|ИЗ
		|	Документ.ЗаявкаНаДоставку КАК ЗаявкаНаДоставку
		|ГДЕ
		|	ЗаявкаНаДоставку.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(СостоянияЗаказовКлиентов.ПроцентОплаты, 0) КАК ПроцентОплаты
		|ИЗ
		|	Документ.ЗаявкаНаДоставку.Заказы КАК ЗаявкаНаДоставкуЗаказы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияЗаказовКлиентов КАК СостоянияЗаказовКлиентов
		|		ПО ЗаявкаНаДоставкуЗаказы.Заказ = СостоянияЗаказовКлиентов.Заказ
		|ГДЕ
		|	ЗаявкаНаДоставкуЗаказы.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаявкаНаДоставкуТовары.Заказ) КАК КОЛИЧЕСТВО
		|ИЗ
		|	Документ.ЗаявкаНаДоставку.Товары КАК ЗаявкаНаДоставкуТовары
		|ГДЕ
		|	ЗаявкаНаДоставкуТовары.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ПартнерыКонтактнаяИнформация.Представление, """") КАК Телефон
		|ИЗ
		|	Документ.ЗаявкаНаДоставку КАК ЗаявкаНаДоставку
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
		|		ПО ЗаявкаНаДоставку.Партнер = ПартнерыКонтактнаяИнформация.Ссылка
		|			И (ПартнерыКонтактнаяИнформация.Тип = &Тип)
		|			И (ПартнерыКонтактнаяИнформация.Вид = &Вид)
		|ГДЕ
		|	ЗаявкаНаДоставку.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Заявка);
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон);
	Запрос.УстановитьПараметр("Вид", Справочники.ВидыКонтактнойИнформации.ТелефонПартнера);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[0].Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Если Выборка.ФИОПолучателя Тогда
			СписокОшибок = СписокОшибок +"ФИО получателя, ";	
		КонецЕсли;
		Если Выборка.АдресДоставки Тогда
			СписокОшибок = СписокОшибок +"адрес доставки, ";	
		КонецЕсли;
		Если Выборка.ГородКуда Тогда
			СписокОшибок = СписокОшибок +"город, ";	
		КонецЕсли;
		Если Выборка.ТипДоставки Тогда
			СписокОшибок = СписокОшибок +"тип доставки, ";	
		КонецЕсли;
		Если Выборка.НомерНаСайте Тогда
			СписокОшибок = СписокОшибок +"номер на сайте, ";	
		КонецЕсли;
		Если Выборка.ТранспортнаяКомпания Тогда
			СписокОшибок = СписокОшибок +"транспортная компания, ";	
		КонецЕсли;
		
	КонецЕсли; 
	
	Выборка = РезультатЗапроса[3].Выбрать();

	Если Выборка.Следующий() Тогда
		Если Выборка.Телефон ="" Тогда
			СписокОшибок = СписокОшибок +"телефон партнера, ";
		КонецЕсли; 
	КонецЕсли;
	
	Если Прав(СписокОшибок, 2) = ", " Тогда
		СписокОшибок = Лев(СписокОшибок, СтрДлина(СписокОшибок)-2);	
	КонецЕсли; 
	
	Выборка = РезультатЗапроса[1].Выбрать();

	Если Выборка.Следующий() Тогда
		Если Выборка.ПроцентОплаты < 100 
			И НЕ Заявка.НаложенныйПлатеж Тогда
			ОшибкаНесоответствияОплат = "Заказ не оплачен, должна стоять галка Наложенный платеж.";
		КонецЕсли; 
		Если Выборка.ПроцентОплаты >= 100 
			И Заявка.НаложенныйПлатеж Тогда
			ОшибкаНесоответствияОплат = "Заказ оплачен, снимите галку Наложенный платеж.";
		КонецЕсли; 
	КонецЕсли;
	
	Выборка = РезультатЗапроса[2].Выбрать();

	Если Выборка.Следующий() Тогда
		Если Выборка.Количество > 1 Тогда
			ОшибкаНесоответствияОплат = "Отправка заявки рассчитано для одного Заказа. Удалите лишние.";
		КонецЕсли; 
	КонецЕсли;
			
	ЕстьОшибкиЗаполнения = ЗначениеЗаполнено(СписокОшибок) ИЛИ ЗначениеЗаполнено(ОшибкаНесоответствияОплат);
	Результат.Вставить("ЕстьОшибкиЗаполнения", ЕстьОшибкиЗаполнения);
	Результат.Вставить("СписокОшибок", СписокОшибок);
	Результат.Вставить("ОшибкаНесоответствияОплат", ОшибкаНесоответствияОплат);

	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Заявка") Тогда
		Заявка = Параметры.Заявка;	
	КонецЕсли;
	
	Если Параметры.Свойство("ЭтоОтправкаВозврата") Тогда
		Элементы.ОтправкаСДЭК.Видимость = НЕ Параметры.ЭтоОтправкаВозврата;
		Элементы.ВызовКурьера.Видимость = Параметры.ЭтоОтправкаВозврата;
		ЭтоВызовКурьера = Параметры.ЭтоОтправкаВозврата;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПриОткрытииНаСервере(Заявка);
	
	ОтправлятьНаТестовыйСервер = ЭтоОтправкаНаТестовыйСервер();
	Если ОтправлятьНаТестовыйСервер Тогда
		URL = "api.edu.cdek.ru";  //Тестовый
	Иначе
		URL = "api.cdek.ru";      //Рабочий
	КонецЕсли; 
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЭтоОтправкаНаТестовыйСервер()
	Возврат Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_ОтправкаНаТестовыйСервер", Истина);	
КонецФункции
 
&НаСервере
Функция СформироватьТекстЗапросаДляОтправки()
	
	Результат = ПолучитьДанныеЗаказа(); 
	ВыборкаШапка = Результат.ВыборкаШапка;
	ВыборкаШапка.Следующий();
	ТЗМаркировка = Результат.ТЗМаркировка;
	
	ВыборкаМесто = Результат.ВыборкаТовары;
	
	Заказ  = СоздатьОбъектXDTO("order");
	Заказ.number =  ВыборкаШапка.number;
	Заказ.comment =  ВыборкаШапка.ПримечаниеТК;
	
	Отправитель = СоздатьОбъектXDTO("location");
	Отправитель.city = "Санкт-Петербург";
	Отправитель.address = "Невский пр-кт, дом № 153А, помещение 20Н";
	Отправитель.code = "137";
	
	Заказ.from_location = Отправитель;
	
	Если Заявка.СДЭКТипДоставки = Перечисления._ТипыДоставки.ДверьСклад
		ИЛИ Заявка.СДЭКТипДоставки = Перечисления._ТипыДоставки.ДоСклада Тогда
		Заказ.delivery_point = ВыборкаШапка.КодПВЗ;
	Иначе
		
		Получатель = СоздатьОбъектXDTO("location");
		Получатель.city = ВыборкаШапка.ГородДоставкиНаименование;
		Получатель.address = ВыборкаШапка.АдресДоставки;
		Получатель.code = ВыборкаШапка.ГородДоставкиКод;
		
		Заказ.to_location = Получатель;
			
	КонецЕсли;
	
	ЕстьДинамическаяДоставка = Ложь;
	ЕстьЧастичнаяДоставка = Ложь;
	
	ДопУслугиЗаявки = Заявка.СДЭКДопУслуги.Получить();
	
	Если ТипЗнч(ДопУслугиЗаявки) = Тип("СписокЗначений") Тогда
		Для каждого СтрокаДопУслуга Из ДопУслугиЗаявки Цикл
			Если СтрокаДопУслуга.Значение.КодУслуги = "PART_DELIV" Тогда
				ЕстьЧастичнаяДоставка = Истина;	
			КонецЕсли;
		КонецЦикла; 
	КонецЕсли;  
	
	ЕстьДинамическаяДоставка = ЕстьЧастичнаяДоставка 
					И (Заявка.СДЭКТипДоставки = Перечисления._ТипыДоставки.ДверьДверь ИЛИ Заявка.СДЭКТипДоставки = Перечисления._ТипыДоставки.ДоДвери)
					И Заявка.НаложенныйПлатеж;
					
	ЗаказКлиента = Заявка.Заказы[0].Заказ; 
	КартаЛояльности = ЗаказКлиента.КартаЛояльности;  //тикет 48249
	Если ЗначениеЗаполнено(КартаЛояльности) Тогда
		ВидКарты = КартаЛояльности.Владелец.Наименование;
		Если ВидКарты = "Premium 5%"
			ИЛИ ВидКарты = "Platinum 15%"
			ИЛИ ВидКарты = "VIP 20%" Тогда
		    ЕстьДинамическаяДоставка = Ложь; 
		КонецЕсли;
	КонецЕсли;
	
	Пока ВыборкаМесто.Следующий() Цикл
		ВыборкаТовары = ВыборкаМесто.Выбрать();
		
		Упаковка = СоздатьОбъектXDTO("packages");
		Упаковка.number = "bar-001"+Строка(ВыборкаМесто.Место);
		
		Упаковка.height = 17;
		Упаковка.length = 42;
		Упаковка.width  = 33;
		КоличествоТовараВУпаковке = 0;
		
		Пока ВыборкаТовары.Следующий() Цикл
			
			Если ВыборкаТовары.НоменклатураКод = "Ц0000120605" 
				И ЕстьДинамическаяДоставка Тогда //убираем доставку из товаров
				Продолжить;
			КонецЕсли; 
			
			Товар = СоздатьОбъектXDTO("item");
			ЗаполнитьЗначенияСвойств(Товар, ВыборкаТовары);	
			Товар.name = СтрЗаменить(Товар.name, "&", ""); 
			
			СуммаОплатыПриПолучении = СоздатьОбъектXDTO("payment");
			Если ВыборкаШапка.НаложенныйПлатеж Тогда    
				СуммаОплатыПриПолучении.value = Товар.cost;	
			Иначе
				СуммаОплатыПриПолучении.value = 0;	
			КонецЕсли; 
			Товар.cost = Товар.amount;//Товар.cost; объявленную стоимость занижаем, чтобы страховка была низкой	
			
			Если ВыборкаТовары.НоменклатураКод = "Ц0000120605" Тогда //"доставка ИМ" не может иметь объявленную ценность
				Товар.cost = 0;
				Товар.name = Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_НазваниеДоставки", "Доставка ИМ при выкупе менее 15000руб");
			КонецЕсли;
			Товар.payment = СуммаОплатыПриПолучении;
			
			Если ВыборкаТовары.МаркируемыйТовар Тогда
				 
				Если ВыборкаТовары.amount > 1 Тогда
					Сообщить("Для маркируемых товаров количество в строке не должно превышать 1 шт: "+ВыборкаТовары.name+"
							|Выгрузка невозможна.");
					Возврат 0;	
				КонецЕсли;   
				НайденныеСтроки = ТЗМаркировка.НайтиСтроки(Новый Структура("Номенклатура, Характеристика, ЗаказКлиента", 
											ВыборкаТовары.Номенклатура,ВыборкаТовары.Характеристика,ВыборкаТовары.Заказ));
											
				Если НайденныеСтроки.Количество() Тогда
					НайденнаяСтрока = НайденныеСтроки[0];
					
					Если НЕ ВыборкаТовары.ЭтоМех Тогда
						РазобранныйШтрихкодСтруктурой = МенеджерОборудованияМаркировкаКлиентСервер.РазобратьШтриховойКодТовара(НайденнаяСтрока.ШтрихкодУпаковки.ЗначениеШтрихкода);
						hex_code = СтрЗаменить(Строка(РазобранныйШтрихкодСтруктурой.РеквизитКодаТовараHEX), " ", "");
		
						Товар.marking = hex_code;
						ТЗМаркировка.Удалить(НайденнаяСтрока);
					КонецЕсли; 
					
				Иначе
					Сообщить("Не внесен код маркировки для товара "+ВыборкаТовары.name+" 
					|Выгрузка невозможна.");
					Возврат 0;
				КонецЕсли; 
			КонецЕсли; 
			Упаковка.items.Добавить(Товар);
			
			КоличествоТовараВУпаковке = КоличествоТовараВУпаковке + ВыборкаТовары.amount;
			
		КонецЦикла; 
		
		Упаковка.weight = КоличествоТовараВУпаковке * 700;
		
		Если ЕстьДинамическаяДоставка Тогда
			
			Товар = СоздатьОбъектXDTO("item");
			Товар.ware_key = "Ц0000120605";
			Товар.cost = 0;
			Товар.weight = 10;
			Товар.amount = 1;
			Товар.name = Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_НазваниеДинамическойДоставки", "Доставка при полном отказе");
			
			СуммаОплатыПриПолучении = СоздатьОбъектXDTO("payment");
			СуммаОплатыПриПолучении.value = 0;	
			
			Товар.payment = СуммаОплатыПриПолучении;
			
			Упаковка.items.Добавить(Товар);	 
			Упаковка.weight = Упаковка.weight +10;
			
		КонецЕсли;  
		
		
		Заказ.packages.Добавить(Упаковка);
	
	КонецЦикла;
	
	Получатель = СоздатьОбъектXDTO("client");
	Получатель.name = ВыборкаШапка.ПартнерНаименование;
	
	Телефон = СоздатьОбъектXDTO("phone");
	Телефон.number = ВыборкаШапка.НомерТелефона;
	Если ЗначениеЗаполнено(Телефон.number) И НЕ СтрНачинаетсяС(Телефон.number, "+") Тогда
		Телефон.number = "+"+Телефон.number;
	КонецЕсли; 
	
	Получатель.phones.Добавить(Телефон);
	
	Заказ.recipient = Получатель;
	
	Отправитель = СоздатьОбъектXDTO("sender");
	Отправитель.name = Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_КонтактноеЛицо", "");
	Отправитель.company = Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_Продавец", "");
	Phone_отправитель = СоздатьОбъектXDTO("phone");
	Phone_отправитель.number = Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_ПродавецТелефон", "");
    Отправитель.phones.Добавить(Phone_отправитель);
	
	Заказ.sender = Отправитель;
	
	ДопУслугиЗаявки = Заявка.СДЭКДопУслуги.Получить();
	
	Если ТипЗнч(ДопУслугиЗаявки) = Тип("СписокЗначений") Тогда
		Для каждого СтрокаДопУслуга Из ДопУслугиЗаявки Цикл
			
			ДопУслуга = СоздатьОбъектXDTO("service");
			ДопУслуга.code = СтрокаДопУслуга.Значение.КодУслуги;
			Если ДопУслуга.code = "PACKAGE_1" Тогда
				ДопУслуга.parameter = Заявка.КоличествоМест;
			Иначе
				ДопУслуга.parameter = 0;
			КонецЕсли; 
			
			Заказ.services.Добавить(ДопУслуга);
			
		КонецЦикла; 
	КонецЕсли; 
	
	Если ЕстьДинамическаяДоставка Тогда
		
		СтоимостьДинамическойДоставки = Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_СтоимостьДинамическойДоставки", 900);
		
		ДинамическаяДоставка = СоздатьОбъектXDTO("delivery_recipient_cost_adv");	
		ДинамическаяДоставка.sum = СтоимостьДинамическойДоставки;
		ДинамическаяДоставка.threshold = 0;  //при полном отказе + строка в ТЧ товары
		
		Заказ.delivery_recipient_cost_adv.Добавить(ДинамическаяДоставка);
		
		ДинамическаяДоставка = СоздатьОбъектXDTO("delivery_recipient_cost_adv");	
		ДинамическаяДоставка.sum = СтоимостьДинамическойДоставки;
		ДинамическаяДоставка.threshold = 30000;
		
		Заказ.delivery_recipient_cost_adv.Добавить(ДинамическаяДоставка);
	

    КонецЕсли;
			
	Заказ.tariff_code = ВыборкаШапка.КодТарифа;
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ФабрикаXDTO.ЗаписатьJSON(ЗаписьJSON, Заказ);
	
	СтрокаЗапроса = ЗаписьJSON.Закрыть();
	
	СтрокаЗапроса = Прав(СтрокаЗапроса, СтрДлина(СтрокаЗапроса)-13);
	СтрокаЗапроса = Лев(СтрокаЗапроса, СтрДлина(СтрокаЗапроса)-1);
	
КонецФункции

Функция ПолучитьДанныеЗаказа()
	
