&НаСервере
Процедура ПолучитьИнформациюПоЗаказуНаСервере(ЭтоВозврат = Ложь)
	
	Токен = "Bearer "+ Константы.СДЭКТокен.Получить();
		
	HTTPСоединение = Новый HTTPСоединение(URL, , , , , , Новый ЗащищенноеСоединениеOpenSSL(), );
	
	Метод = "/v2/orders/"+?(ЭтоВозврат, Заявка.СДЭКUuidЗаявкиКурьера, Заявка.СДЭКUuid);
	HTTPЗапрос = Новый HTTPЗапрос(Метод);

	HTTPЗапрос.Заголовки.Вставить("Authorization", Токен); 
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");

	HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаЗапроса); 
	Ответ = HTTPСоединение.Получить(HTTPЗапрос);

	Поток = Ответ.ПолучитьТелоКакПоток();
	Кодировка = "utf-8"; 

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.ОткрытьПоток(Поток, Кодировка); 
	Результат = ПрочитатьJSON(ЧтениеJSON);
	
	Если ТипЗнч(Результат) = Тип("Структура") 
		И Результат.Свойство("entity") Тогда
		
		cdek_number = "";
		АктуальныйСтатус = "";
		
		entity = Результат.entity;
		Если ТипЗнч(entity) = Тип("Структура") 
			И entity.Свойство("cdek_number") Тогда
			
			cdek_number = entity.cdek_number;
			Номер = cdek_number; 		
		КонецЕсли; 
		total_sum = 0;
		Если ТипЗнч(entity) = Тип("Структура") 
			И entity.Свойство("delivery_detail") Тогда
			Если entity.delivery_detail.Свойство("total_sum") Тогда
				total_sum = entity.delivery_detail.total_sum;
			КонецЕсли; 
		КонецЕсли; 
		
		Если ТипЗнч(entity) = Тип("Структура")
			И entity.Свойство("statuses") Тогда
			
			Для каждого Статус Из entity.statuses Цикл
				АктуальныйСтатус = Статус.name;
				СтатусДоставки = АктуальныйСтатус;
				Прервать;	
			КонецЦикла;
			
		КонецЕсли; 
		
		Если cdek_number <> "" 
			ИЛИ АктуальныйСтатус <> "" Тогда
			
			НомерЗаявкиКурьера = cdek_number;
			СтатусДоставкиВозвратТК = АктуальныйСтатус;
					
			ЗаявкаОбъект = Заявка.ПолучитьОбъект();
			Если ЭтоВозврат Тогда
				ЗаявкаОбъект.НомерВозвратаСДЭК = cdek_number;
				ЗаявкаОбъект.СтатусДоставкиВозвратТК = АктуальныйСтатус;
				ЗаявкаОбъект.СуммаУслугВозвратСДЭК = total_sum;
			Иначе
				ЗаявкаОбъект.СДЭКНомер = cdek_number;
				ЗаявкаОбъект.СтатусДоставкиТК = АктуальныйСтатус;
				ЗаявкаОбъект.СуммаУслугСДЭК = total_sum;
			КонецЕсли;
			ЗаявкаОбъект.Записать();
			
		КонецЕсли; 
				
	КонецЕсли; 
	Если ТипЗнч(Результат) = Тип("Структура") 
		И Результат.Свойство("requests") Тогда
		
		request = Результат.requests[0];
		Если request.state = "INVALID"
			И request.type = "AUTH" Тогда
			АвторизацияНаСервере();
		КонецЕсли; 
		Если request.Свойство("errors")
			И ТипЗнч(request.errors) = Тип("Массив") Тогда
			
			Если Ошибки <> "" Тогда
				Ошибки = Ошибки+Символы.ПС;	
			КонецЕсли; 
				
			Для каждого СтрокаОшибка Из request.errors Цикл
				Ошибки = Ошибки + СтрокаОшибка.message+Символы.ПС;	
			КонецЦикла; 
			
		КонецЕсли;
	КонецЕсли; 
	
	ОтветСервера = Ответ.ПолучитьТелоКакСтроку("UTF-8");
	
	Request = СериализацияЗначения("URL: "+URL+"/"+Метод);
    Если ЭтоВозврат Тогда
		ИмяМетода = "СДЭК Информация по заказу возвратной накладной";
	Иначе
		ИмяМетода = "СДЭК Информация по заказу";
	КонецЕсли; 
    ПреобразоватьИЗаписатьЛог(Request, Результат, ОтветСервера, ИмяМетода, "Заявка "+Заявка.Номер);
	
КонецПроцедуры

&НаКлиенте
Процедура Отправить(Команда)
	
	Ошибки = "";
	ЭтоОтправкаЗаказа = Истина;
	
	СформироватьТекстЗапросаДляОтправки();
	ТребуетсяПереотправкаИзЗаТокена = ОтправитьНаСайтЗаказ();
	
	Если ТребуетсяПереотправкаИзЗаТокена Тогда
		ОтправитьНаСайтЗаказ();
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Uuid_) Тогда
		Таймер(1);
		ПолучитьИнформациюПоЗаказуНаСервере();
	КонецЕсли; 
		
	Если Ошибки = "" Тогда
		Закрыть();	
	КонецЕсли; 
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция Таймер(КоличествоСекунд)
	
	НачалоОтсчета = ТекущаяДата();
	КонецОтсчета = НачалоОтсчета+КоличествоСекунд;
	
	УсловиеПрерывания = Истина;
	Пока УсловиеПрерывания Цикл
		Если ТекущаяДата()>КонецОтсчета Тогда
			УсловиеПрерывания = Ложь;	
		КонецЕсли; 		
	КонецЦикла; 
	
КонецФункции
 
&НаКлиенте
Процедура Обновить(Команда)
	ПолучитьИнформациюПоЗаказуНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Результат = Новый Структура();
	Результат.Вставить("Uuid", Uuid_);
	Результат.Вставить("Номер", Номер);
	Результат.Вставить("СтатусДоставки", СтатусДоставки);
	Результат.Вставить("ЭтоОтправкаЗаказа", ЭтоОтправкаЗаказа);
	Результат.Вставить("НомерЗаявкиКурьера", НомерЗаявкиКурьера);
	Результат.Вставить("СтатусДоставкиВозврат", СтатусДоставкиВозвратТК);
	
	Закрыть(Результат);
	
КонецПроцедуры

&НаСервере
Процедура ОтправитьВызовКурьераНаСервере()
	
	СформироватьТекстВозвратаНаСервере();
	Если ЗначениеЗаполнено(Ошибки) Тогда
		Возврат;	
	КонецЕсли; 
	ОтправитьЗаявкуНаВызовКурьера();
	
КонецПроцедуры

Функция ПолучитьИнформациюКурьерНаСервере()
	
	Если НЕ ЗначениеЗаполнено(Заявка.СДЭКUuidЗаявкиКурьера) Тогда
		Возврат 0;	
	КонецЕсли; 
	
	Токен = "Bearer "+ Константы.СДЭКТокен.Получить();
		
	HTTPСоединение = Новый HTTPСоединение(URL, , , , , , Новый ЗащищенноеСоединениеOpenSSL(), );
	
	Метод = "/v2/intakes/"+Заявка.СДЭКUuidЗаявкиКурьера;
	HTTPЗапрос = Новый HTTPЗапрос(Метод);

	HTTPЗапрос.Заголовки.Вставить("Authorization", Токен); 
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");

	HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаЗапроса); 
	Ответ = HTTPСоединение.Получить(HTTPЗапрос);
	ОтветСервера = Ответ.ПолучитьТелоКакСтроку();

	Поток = Ответ.ПолучитьТелоКакПоток();
	Кодировка = "utf-8"; 

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.ОткрытьПоток(Поток, Кодировка); 
	Результат = ПрочитатьJSON(ЧтениеJSON);
	
	Если ТипЗнч(Результат) = Тип("Структура") 
		И Результат.Свойство("entity") Тогда
		
		entity = Результат.entity;
		Если ТипЗнч(entity) = Тип("Структура") 
			И entity.Свойство("intake_number") Тогда
			
			ЗаявкаОбъект = Заявка.ПолучитьОбъект();
			ЗаявкаОбъект.СДЭКНомерЗаявкиКурьера = entity.intake_number;
			ЗаявкаОбъект.СДЭКЗаявкаНаВызовКурьераОтправлена = Истина;
			ЗаявкаОбъект.Записать();
			НомерЗаявкиКурьера = entity.intake_number;
		КонецЕсли; 
						
	КонецЕсли; 
	
	Если ТипЗнч(Результат) = Тип("Структура") 
		И Результат.Свойство("requests") Тогда
		
		request = Результат.requests[0];
		Если request.state = "INVALID"
			И request.type = "AUTH" Тогда
			АвторизацияНаСервере();
		КонецЕсли; 
		Ошибки = "";
		Если request.Свойство("errors")
			И ТипЗнч(request.errors) = Тип("Массив") Тогда
			
			Для каждого СтрокаОшибка Из request.errors Цикл
				Ошибки = Ошибки+СтрокаОшибка.message+Символы.ПС;	
			КонецЦикла; 
			
		КонецЕсли;
	КонецЕсли; 
	
	ОтветСервера = Ответ.ПолучитьТелоКакСтроку("UTF-8");
	
	Request = СериализацияЗначения("URL: "+URL+"/"+Метод);
    ПреобразоватьИЗаписатьЛог(Request, Результат, ОтветСервера, "СДЭК Информация по заявке", "Заявка "+Заявка.Номер);
	
КонецФункции
 
Функция ОтправитьЗаявкуНаВызовКурьера()
	
	Попытка
	
		Токен = "Bearer "+ Константы.СДЭКТокен.Получить();
		HTTPСоединение = Новый HTTPСоединение(URL, , , , , , Новый ЗащищенноеСоединениеOpenSSL(), );
		HTTPЗапрос = Новый HTTPЗапрос("/v2/orders/");
		
		HTTPЗапрос.Заголовки.Вставить("Authorization", Токен); 
	    HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		
		HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаЗапроса); 
		Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
		
		Поток = Ответ.ПолучитьТелоКакПоток();
		Кодировка = "utf-8"; 

		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.ОткрытьПоток(Поток, Кодировка); 
		Результат = ПрочитатьJSON(ЧтениеJSON);
		ОтветСервера = Ответ.ПолучитьТелоКакСтроку("UTF-8"); // ЧтениеJSON.Закрыть();
		
		Если ТипЗнч(Результат) = Тип("Структура") 
			И Результат.Свойство("requests") Тогда
			
			request = Результат.requests[0];
			Если request.state = "ACCEPTED" Тогда
				Если Результат.Свойство("entity") 
					И Результат.entity.Свойство("uuid") Тогда
					
					ЗаявкаОбъект = Заявка.ПолучитьОбъект();
					ЗаявкаОбъект.СДЭКUuidЗаявкиКурьера = Результат.entity.uuid;
					ЗаявкаОбъект.Записать();
					
				КонецЕсли; 		
			КонецЕсли; 
			Если request.state = "INVALID"
				И request.type = "AUTH" Тогда
				АвторизацияНаСервере();
			КонецЕсли; 
		КонецЕсли; 
		Если ТипЗнч(Результат) = Тип("Структура") 
			И Результат.Свойство("errors") Тогда
			
			errors = Результат.errors[0];
			Ошибки = errors.message; 
		КонецЕсли;
		Если  ТипЗнч(Результат) = Тип("Структура") 
			И Результат.Свойство("requests") Тогда
			requests = Результат.requests;
			Если ТипЗнч(requests) = Тип("Массив") Тогда
				request = requests[0];	
				Если request.Свойство("errors") Тогда
					errors = request.errors[0];	
					Ошибки = errors.message;
				КонецЕсли; 
			КонецЕсли; 
			
		КонецЕсли;
		Request = СериализацияЗначения(СтрокаЗапроса);
	    ПреобразоватьИЗаписатьЛог(Request, Результат, ОтветСервера, "СДЭК Регистрация заказа возвратной накладной", "Заявка "+Заявка.Номер);
	
	Исключение
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	
	ПолучитьИнформациюПоЗаказуНаСервере(Истина);
	
КонецФункции
 
&НаСервере
Функция СформироватьТекстВозвратаНаСервере()
	
	Ошибки = "";
	СтрокаЗапроса = "";
	
	Результат = ПолучитьДанныеЗаказаВозвратнаяНакладная(); 
	ВыборкаШапка = Результат.ВыборкаШапка;
	ВыборкаШапка.Следующий();
	ТЗМаркировка = Результат.ТЗМаркировка;
	
	ВыборкаМесто = Результат.ВыборкаТовары;
	Если ВыборкаМесто.Количество() = 0 Тогда
		Ошибки = "Нет товаров к отправке";
		Возврат 0;	
	КонецЕсли; 
	
	Заказ  = СоздатьОбъектXDTO("order");
	Заказ.number =  ВыборкаШапка.number;
	Заказ.comment =  ВыборкаШапка.ПримечаниеТК;
	
	Отправитель = СоздатьОбъектXDTO("location");
	Отправитель.city = ВыборкаШапка.ГородОтправки;
	Отправитель.address = ВыборкаШапка.АдресОтправки;
	Отправитель.code = ВыборкаШапка.КодГородаОтправки;
	
	Заказ.from_location = Отправитель;
	
	Если Заявка.СДЭКВыбранныйТарифВозвратнаяНакладная.РежимДоставки = Перечисления._ТипыДоставки.ДверьСклад
		ИЛИ Заявка.СДЭКВыбранныйТарифВозвратнаяНакладная.РежимДоставки = Перечисления._ТипыДоставки.ДоСклада Тогда
		Заказ.delivery_point = ВыборкаШапка.КодПВЗ;
	Иначе
		
		Получатель = СоздатьОбъектXDTO("location");
		Получатель.city = ВыборкаШапка.ГородДоставкиНаименование;
		Получатель.address = Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_Адрес","");//ВыборкаШапка.АдресДоставки;
		Получатель.code = ВыборкаШапка.ГородДоставкиКод;
		
		Заказ.to_location = Получатель;
			
	КонецЕсли;
	
	Пока ВыборкаМесто.Следующий() Цикл
		ВыборкаТовары = ВыборкаМесто.Выбрать();
		
		Упаковка = СоздатьОбъектXDTO("packages");
		Упаковка.number = "bar-001"+Строка(ВыборкаМесто.Место);
		
		Упаковка.height = 17;
		Упаковка.length = 42;
		Упаковка.width  = 33;
		КоличествоТовараВУпаковке = 0;
		
		Пока ВыборкаТовары.Следующий() Цикл
		
			Товар = СоздатьОбъектXDTO("item");
			ЗаполнитьЗначенияСвойств(Товар, ВыборкаТовары);	
			
			СуммаОплатыПриПолучении = СоздатьОбъектXDTO("payment");
			Если ВыборкаШапка.НаложенныйПлатеж Тогда
				СуммаОплатыПриПолучении.value = Товар.cost;	
			Иначе
				СуммаОплатыПриПолучении.value = 0;	
			КонецЕсли; 
			Если ВыборкаТовары.НоменклатураКод = "Ц0000120605" Тогда //"доставка ИМ" не может иметь объявленную ценность
				Товар.cost = 0;
				Товар.name = Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_НазваниеДоставки", "Доставка ИМ при выкупе менее 15000руб");;
			КонецЕсли;
			Товар.payment = СуммаОплатыПриПолучении;
			
			Если ВыборкаТовары.МаркируемыйТовар Тогда
				 
				Если ВыборкаТовары.amount > 1 Тогда
					Сообщить("Для маркируемых товаров количество в строке не должно превышать 1 шт: "+ВыборкаТовары.name+"
							|Выгрузка невозможна.");
					Возврат 0;	
				КонецЕсли;   
				НайденныеСтроки = ТЗМаркировка.НайтиСтроки(Новый Структура("Номенклатура, Характеристика, ЗаказКлиента", 
											ВыборкаТовары.Номенклатура,ВыборкаТовары.Характеристика,ВыборкаТовары.Заказ));
											
				Если НайденныеСтроки.Количество() Тогда
					НайденнаяСтрока = НайденныеСтроки[0];
					
					Если НЕ ВыборкаТовары.ЭтоМех Тогда
						РазобранныйШтрихкодСтруктурой = МенеджерОборудованияМаркировкаКлиентСервер.РазобратьШтриховойКодТовара(НайденнаяСтрока.ШтрихкодУпаковки.ЗначениеШтрихкода);
						hex_code = СтрЗаменить(Строка(РазобранныйШтрихкодСтруктурой.РеквизитКодаТовараHEX), " ", "");
		
						Товар.marking = hex_code;	
					КонецЕсли; 
					
				Иначе
					Сообщить("Не внесен код маркировки для товара "+ВыборкаТовары.name+" 
					|Выгрузка невозможна.");
					Возврат 0;
				КонецЕсли; 
			КонецЕсли; 
			Упаковка.items.Добавить(Товар);
			
			КоличествоТовараВУпаковке = КоличествоТовараВУпаковке + ВыборкаТовары.amount;
			
		КонецЦикла;
		Упаковка.weight = КоличествоТовараВУпаковке * 700;
		
		Заказ.packages.Добавить(Упаковка);
	
	КонецЦикла;
	
	Получатель = СоздатьОбъектXDTO("client");
	Получатель.name = Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_Продавец", ""); 
	
	Телефон = СоздатьОбъектXDTO("phone");
	Телефон.number = Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_ТелефонКомпании", "");
	Если ЗначениеЗаполнено(Телефон.number) И НЕ СтрНачинаетсяС(Телефон.number, "+") Тогда
		Телефон.number = "+"+Телефон.number;
	КонецЕсли; 
	
	Получатель.phones.Добавить(Телефон);
	
	Заказ.recipient = Получатель;
	
	Отправитель = СоздатьОбъектXDTO("sender");
	Отправитель.company = ВыборкаШапка.ПартнерНаименование;
	Отправитель.name = ВыборкаШапка.ПартнерНаименование;
	
	Телефон = СоздатьОбъектXDTO("phone");
	Телефон.number = ВыборкаШапка.НомерТелефона;
	Если ЗначениеЗаполнено(Телефон.number) И НЕ СтрНачинаетсяС(Телефон.number, "+") Тогда
		Телефон.number = "+"+Телефон.number;
	КонецЕсли; 
	
	Отправитель.phones.Добавить(Телефон);
	Отправитель.passport_requirements_satisfied = Ложь;
	
	Заказ.sender = Отправитель;
	
	Seller = СоздатьОбъектXDTO("client");
	Seller.name = Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_Продавец", "");
	Заказ.Seller = Seller;
	
	ДопУслугиЗаявки = Заявка.СДЭКДопУслугиВозвратнаяНакладная.Получить();
	
	Если ТипЗнч(ДопУслугиЗаявки) = Тип("СписокЗначений") Тогда
		Для каждого СтрокаДопУслуга Из ДопУслугиЗаявки Цикл
			
			ДопУслуга = СоздатьОбъектXDTO("service");
			ДопУслуга.code = СтрокаДопУслуга.Значение.КодУслуги;
			Если ДопУслуга.code = "PACKAGE_1" Тогда
				ДопУслуга.parameter = Заявка.КоличествоМест;
			Иначе
				ДопУслуга.parameter = 0;
			КонецЕсли; 
			
			Заказ.services.Добавить(ДопУслуга);
			
		КонецЦикла; 
	КонецЕсли; 
	
	Заказ.tariff_code = ВыборкаШапка.КодТарифа;
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ФабрикаXDTO.ЗаписатьJSON(ЗаписьJSON, Заказ);
	
	СтрокаЗапроса = ЗаписьJSON.Закрыть();
	
	СтрокаЗапроса = Прав(СтрокаЗапроса, СтрДлина(СтрокаЗапроса)-13);
	СтрокаЗапроса = Лев(СтрокаЗапроса, СтрДлина(СтрокаЗапроса)-1);
	
КонецФункции

Функция ПолучитьДанныеЗаказаВозвратнаяНакладная()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаявкаНаДоставку.Комментарий КАК comment,
		|	ЗаявкаНаДоставку.СДЭКОтправительВозвратнойНакладной КАК ПартнерНаименование,
		|	ЗаявкаНаДоставку.НомерПоДаннымКлиента + ""_return"" КАК number,
		|	137 КАК ГородДоставкиКод,
		|	""Санкт-Петербург"" КАК ГородДоставкиНаименование,
		|	ЗаявкаНаДоставку.СДЭКАдресВозвратнойНакладной КАК АдресОтправки,
		|	ЗаявкаНаДоставку.НаложенныйПлатеж КАК НаложенныйПлатеж,
		|	ЗаявкаНаДоставку.СтраховатьГруз КАК СтраховатьГруз,
		|	ЗаявкаНаДоставку.СДЭКТелефонВозвратнойНакладной КАК НомерТелефона,
		|	ЕСТЬNULL(ЗаявкаНаДоставку.СДЭКВыбранныйТарифВозвратнаяНакладная.КодТарифа, 0) КАК КодТарифа,
		|	ЗаявкаНаДоставку.СДЭКДопУслуги КАК СДЭКДопУслуги,
