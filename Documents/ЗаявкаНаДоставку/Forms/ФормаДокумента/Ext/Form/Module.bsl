#КонецОбласти


#Область ЛПост
&НаКлиенте
Процедура ОтправитьЛПост(Команда)
	
	Если Модифицированность Тогда
		ЭтотОбъект.Записать();	
	КонецЕсли; 
	
	Если НЕ Объект.Проведен Тогда
		Сообщить("Проведите сначала документ!");
		Возврат;	
	КонецЕсли;
	
	ЕстьОшибкиМаркировки = ПроверитьНаОшибкиЗаполненияМаркировки(Объект.Ссылка);
	Если ЕстьОшибкиМаркировки Тогда  
		Сообщить("В заявке есть строка с маркировкой и количеством больше 1!
				 |Разбейте строку и заполните маркировку");
		Возврат;	
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура();
	ПараметрыОткрытия.Вставить("Заявка", Объект.Ссылка);
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ОтправкаЛПостЗавершение", ЭтаФорма);
	
	ОткрытьФорму("Обработка.ОбменLPost.Форма.ФормаОтправкиLPost", ПараметрыОткрытия, ЭтаФорма,,,,
				ОповещениеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПроверитьНаОшибкиЗаполненияМаркировки(Заявка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаявкаНаДоставкуТовары.Количество КАК Количество
		|ИЗ
		|	Документ.ЗаявкаНаДоставку.Товары КАК ЗаявкаНаДоставкуТовары
		|ГДЕ
		|	ЗаявкаНаДоставкуТовары.Маркировка <> """"
		|	И ЗаявкаНаДоставкуТовары.Количество > 1
		|	И ЗаявкаНаДоставкуТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Заявка);
	
	Возврат НЕ Запрос.Выполнить().Пустой(); 
	
КонецФункции

&НаКлиенте
Функция ОтправкаЛПостЗавершение(РезультатЗакрытия, Дополнительныепараметры) Экспорт
	
	Если РезультатЗакрытия <> Неопределено Тогда
		
		Объект.НомерТК = РезультатЗакрытия.НомерТК;
		Объект.СсылкаНаЭтикетку = РезультатЗакрытия.СсылкаНаЭтикетку;
			 
	КонецЕсли; 
	
	ЭтаФорма.Прочитать();			
	
КонецФункции

