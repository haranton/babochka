Процедура ОкруглитьСуммыПоСтрокамНаСервере()
	
	СуммаВсего = Объект.Товары.Итог("Сумма");
	КоличествоСтрок = Объект.Товары.Количество();
	
	Если КоличествоСтрок = 1 Тогда
		СуммаВсего = Окр(СуммаВсего);
		Объект.СуммаДокумента = СуммаВсего;
	КонецЕсли;
		
	Для каждого Строка Из Объект.Товары Цикл   
		
		Если КоличествоСтрок = 1 Тогда
			Строка.Сумма = СуммаВсего; 
			Прервать;
		КонецЕсли;
		Строка.Сумма = Окр(Строка.Сумма);
		КоличествоСтрок = КоличествоСтрок - 1;
		СуммаВсего = СуммаВсего - Строка.Сумма;
	КонецЦикла;
	
	
