&НаКлиенте
Процедура ПартнерПриИзменении(Элемент) 
	
	Телефон =  СтрЗаменить(Бабочка.ПолучитьНомерТелефонаКлиент(Объект.Партнер)," ","");
	Телефон = СТрЗаменить(Телефон, "(","");
	Телефон = СТрЗаменить(Телефон, ")","");
	Телефон = СТрЗаменить(Телефон, "-","");
	Телефон = СТрЗаменить(Телефон, "+","");
	Объект.ТелефонПолучателя = Телефон;
		
КонецПроцедуры

