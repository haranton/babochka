#Область Заказы

&НаСервере
Процедура ДобавитьТоварыЗаказаСервер(Заказ)
	
	ДокО = РеквизитФормыВЗначение("Объект");
	ДокО.ДобавитьТоварыЗаказаСервер(Заказ);
	ЗначениеВРеквизитФормы(ДокО, "Объект");
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьТоварыЗаказа()
	
	ТД = Элементы.Заказы.ТекущиеДанные;
	Если ТД <> Неопределено  Тогда
		ДобавитьТоварыЗаказаСервер(ТД.Заказ);
	КонецЕсли; 
	
	УстановитьОтборСтрок();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыЗаказПриИзменении(Элемент)
	
	ДобавитьТоварыЗаказа();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ДобавитьТоварыЗаказа();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыПередУдалением(Элемент, Отказ)
	
	ТД = Элементы.Заказы.ТекущиеДанные;
	ТекЗаказ = ТД.Заказ;
	Объект.АдресДоставки = "";
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыПослеУдаления(Элемент)

	Если Не ЗначениеЗаполнено(ТекЗаказ) Тогда
		Возврат;
	КонецЕсли;
	
	МассивСтрок = Объект.Товары.НайтиСтроки(Новый Структура("Заказ", ТекЗаказ));
	Для каждого Строка Из МассивСтрок Цикл
		Объект.Товары.Удалить(Строка);
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтборСтрок()
	
	ВыделенныеСтроки = Элементы.Заказы.ВыделенныеСтроки;
	Если ВыделенныеСтроки = Неопределено Тогда
		Возврат;	
	КонецЕсли; 
	
	Если ВыделенныеСтроки.Количество() > 1 Тогда
		
		МассивЗаказов = Новый Массив;
		Для каждого Строка Из ВыделенныеСтроки Цикл
			СтрокаЗаказа = Объект.Заказы.Получить(Строка);
			Если СтрокаЗаказа <> Неопределено Тогда
				МассивЗаказов.Добавить(СтрокаЗаказа.Заказ);	
			КонецЕсли; 					
		КонецЦикла; 
		ОбработатьВыделениеСтрокЗаказа(МассивЗаказов);
		
		Элементы.Товары.ОтборСтрок = Новый ФиксированнаяСтруктура("ОтображатьСтроку", Истина);
		
		Возврат;
		
	КонецЕсли; 
	
	ТекущиеДанные = Элементы.Заказы.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		Если ЗначениеЗаполнено(ТекущиеДанные.Заказ) Тогда
			Элементы.Товары.ОтборСтрок = Новый ФиксированнаяСтруктура("Заказ",ТекущиеДанные.Заказ);
		Иначе
			Элементы.Товары.ОтборСтрок = Неопределено;
		КонецЕсли;
	Иначе
		Элементы.Товары.ОтборСтрок = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ОбработатьВыделениеСтрокЗаказа(СписокЗаказов)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = "ВЫБРАТЬ
	 |	Таб.Номенклатура КАК Номенклатура,
	 |	Таб.Характеристика КАК Характеристика,
	 |	Таб.Упаковка КАК Упаковка,
	 |	Таб.КоличествоУпаковок КАК КоличествоУпаковок,
	 |	Таб.Количество КАК Количество,
	 |	Таб.Цена КАК Цена,
	 |	Таб.Сумма КАК Сумма,
	 |	Таб.СтавкаНДС КАК СтавкаНДС,
	 |	Таб.СуммаНДС КАК СуммаНДС,
	 |	Таб.СуммаСНДС КАК СуммаСНДС,
	 |	Таб.Заказ КАК Заказ,
	 |	Таб.НомерСтрокиЗаказа КАК НомерСтрокиЗаказа,
	 |	Таб.Отменено КАК Отменено,
	 |	ЛОЖЬ КАК ОтображатьСтроку
	 |ПОМЕСТИТЬ Данные
	 |ИЗ
	 |	&ТекТаб КАК Таб
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	Данные.Заказ КАК Заказ
	 |ПОМЕСТИТЬ ЗаказыДляОтбора
	 |ИЗ
	 |	Данные КАК Данные
	 |ГДЕ
	 |	Данные.Заказ В(&СписокЗаказов)
	 |
	 |СГРУППИРОВАТЬ ПО
	 |	Данные.Заказ
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	Данные.Номенклатура КАК Номенклатура,
	 |	Данные.Характеристика КАК Характеристика,
	 |	Данные.Упаковка КАК Упаковка,
	 |	Данные.КоличествоУпаковок КАК КоличествоУпаковок,
	 |	Данные.Количество КАК Количество,
	 |	Данные.Цена КАК Цена,
	 |	Данные.Сумма КАК Сумма,
	 |	Данные.СтавкаНДС КАК СтавкаНДС,
	 |	Данные.СуммаНДС КАК СуммаНДС,
	 |	Данные.СуммаСНДС КАК СуммаСНДС,
	 |	Данные.Заказ КАК Заказ,
	 |	Данные.НомерСтрокиЗаказа КАК НомерСтрокиЗаказа,
	 |	Данные.Отменено КАК Отменено,
	 |	ВЫБОР
	 |		КОГДА ЗаказыДляОтбора.Заказ ЕСТЬ NULL
	 |			ТОГДА ЛОЖЬ
	 |		ИНАЧЕ ИСТИНА
	 |	КОНЕЦ КАК ОтображатьСтроку
	 |ИЗ
	 |	Данные КАК Данные
	 |		ЛЕВОЕ СОЕДИНЕНИЕ ЗаказыДляОтбора КАК ЗаказыДляОтбора
	 |		ПО Данные.Заказ = ЗаказыДляОтбора.Заказ";
	
	 Запрос.УстановитьПараметр("ТекТаб", Объект.Товары.Выгрузить());
	 Запрос.УстановитьПараметр("СписокЗаказов", СписокЗаказов);
	 Объект.Товары.Загрузить(Запрос.Выполнить().Выгрузить());
	 
КонецФункции
 
&НаКлиенте
Процедура ЗаказыПриАктивизацииСтроки(Элемент)
	
	УстановитьОтборСтрок();
	
