&НаКлиенте
Процедура ЛПостПунктВыдачиЗаказаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если НЕ ЗначениеЗаполнено(Объект.РегионДоставки) Тогда
		ПоказатьПредупреждение(,"Заполните регион доставки!",, "Babochka");
		Возврат;	
	КонецЕсли; 
	
	ПараметрыОткрытия = Новый Структура("Регион", Объект.РегионДоставки);
    ОткрытьФорму("Справочник.ЛПостПунктыДоставки.Форма.ФормаВыбора", ПараметрыОткрытия, Элемент);
    
КонецПроцедуры

&НаКлиенте
Процедура ИнтервалДоставкиПоСПБПриИзменении(Элемент)
	
	Элементы.Интервал.СписокВыбора.Очистить();    
	Элементы.Интервал2.СписокВыбора.Очистить();    
	Если Объект.ИнтервалДоставкиПоСПБ Тогда
		Элементы.Интервал.СписокВыбора.Добавить("00010101103000:00010101130000", "10.30-13.00");
		Элементы.Интервал.СписокВыбора.Добавить("00010101130000:00010101160000", "13.00-16.00");
		Элементы.Интервал.СписокВыбора.Добавить("00010101150000:00010101180000", "15.00-18.00");
		Элементы.Интервал.СписокВыбора.Добавить("00010101170000:00010101200000", "17.00-20.00");
		
		Элементы.Интервал2.СписокВыбора.Добавить("00010101103000:00010101130000", "10.30-13.00");
		Элементы.Интервал2.СписокВыбора.Добавить("00010101130000:00010101160000", "13.00-16.00");
		Элементы.Интервал2.СписокВыбора.Добавить("00010101150000:00010101180000", "15.00-18.00");
		Элементы.Интервал2.СписокВыбора.Добавить("00010101170000:00010101200000", "17.00-20.00");
	
	Иначе
		Элементы.Интервал.СписокВыбора.Добавить("00010101103000:00010101150000", "10.30-15.00");
		Элементы.Интервал.СписокВыбора.Добавить("00010101130000:00010101180000", "13.00-18.00");
		Элементы.Интервал.СписокВыбора.Добавить("00010101160000:00010101200000", "16.00-20.00");
		
		Элементы.Интервал2.СписокВыбора.Добавить("00010101103000:00010101150000", "10.30-15.00");
