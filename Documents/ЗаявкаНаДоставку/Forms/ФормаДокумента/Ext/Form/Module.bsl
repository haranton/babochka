&НаСервере
Функция КоличествоМестПриИзмененииНаСервере()

	Возврат 0; //хотят заполнять вручную, задача 37851
	
	Если Объект.КоличествоМест <= 1 Тогда
		Для каждого СтрокаТЧ Из Объект.Товары Цикл
			СтрокаТЧ.Место = 1;			
		КонецЦикла;
	Иначе
		КоличествоСтрок = Объект.Товары.Итог("Количество");
		РассчитанноеКолвоТовараВУпаковке = Цел(КоличествоСтрок/Объект.КоличествоМест)+1;
		КолвоТовараВУпаковке = РассчитанноеКолвоТовараВУпаковке;
		НомерМеста = 1;
		
		Для каждого СтрокаТЧ Из Объект.Товары Цикл
			Если КолвоТовараВУпаковке <= 0 Тогда
				КолвоТовараВУпаковке = РассчитанноеКолвоТовараВУпаковке;
				НомерМеста = НомерМеста + 1;
			КонецЕсли; 
			
			СтрокаТЧ.Место = НомерМеста;
			КолвоТовараВУпаковке = КолвоТовараВУпаковке - СтрокаТЧ.Количество;
			
		КонецЦикла;
		
	КонецЕсли; 
КонецФункции

&НаКлиенте
Процедура ЗапасыКоличествоПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	СтруктураДействий = Новый Структура;
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
	СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСумму");
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, Неопределено);
	
КонецПроцедуры

