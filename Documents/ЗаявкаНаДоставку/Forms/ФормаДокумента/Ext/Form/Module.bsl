&НаСервере
Функция ЗаполнитьПоляЛПостТКНаСервере()
	
	Если Объект.Заказы.Количество() > 1 Тогда
		Сообщить("Заполнение полей рассчитано для одного Заказа. Удалите лишние.");
		Возврат 0;	
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СостоянияЗаказовКлиентов.ПроцентОплаты КАК ПроцентОплаты
		|ИЗ
		|	РегистрСведений.СостоянияЗаказовКлиентов КАК СостоянияЗаказовКлиентов
		|ГДЕ
		|	СостоянияЗаказовКлиентов.Заказ = &Заказ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ПартнерыКонтактнаяИнформация.НомерТелефона) КАК НомерТелефона,
		|	ПартнерыКонтактнаяИнформация.Ссылка КАК Партнер
		|ПОМЕСТИТЬ ТелефонКлиента
		|ИЗ
		|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
		|ГДЕ
		|	ПартнерыКонтактнаяИнформация.Ссылка = &Партнер
		|	И ПартнерыКонтактнаяИнформация.Тип = &Тип
		|	И ПартнерыКонтактнаяИнформация.Вид = &Вид
		|
		|СГРУППИРОВАТЬ ПО
		|	ПартнерыКонтактнаяИнформация.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПартнерыКонтактнаяИнформация.Ссылка КАК Партнер,
		|	ПартнерыКонтактнаяИнформация.АдресЭП КАК АдресЭП
		|ПОМЕСТИТЬ АдресЭПКлиента
		|ИЗ
		|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
		|ГДЕ
		|	ПартнерыКонтактнаяИнформация.Ссылка = &Партнер
		|	И ПартнерыКонтактнаяИнформация.Тип = &ТипЭлПочта
		|
		|СГРУППИРОВАТЬ ПО
		|	ПартнерыКонтактнаяИнформация.Ссылка,
		|	ПартнерыКонтактнаяИнформация.АдресЭП
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(АдресЭПКлиента.АдресЭП, """") КАК АдресЭП,
		|	ЕСТЬNULL(ТелефонКлиента.НомерТелефона, """") КАК НомерТелефона,
		|	Партнеры.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Партнеры КАК Партнеры
		|		ЛЕВОЕ СОЕДИНЕНИЕ АдресЭПКлиента КАК АдресЭПКлиента
		|		ПО Партнеры.Ссылка = АдресЭПКлиента.Партнер
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТелефонКлиента КАК ТелефонКлиента
		|		ПО Партнеры.Ссылка = ТелефонКлиента.Партнер
		|ГДЕ
		|	Партнеры.Ссылка = &Партнер";
	
	Запрос.УстановитьПараметр("Заказ", Объект.Заказы[0].Заказ);
	Запрос.УстановитьПараметр("Партнер", Объект.Партнер);
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон);
	Запрос.УстановитьПараметр("Вид", Справочники.ВидыКонтактнойИнформации.ТелефонПартнера);
    Запрос.УстановитьПараметр("ТипЭлПочта", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Если РезультатЗапроса[0].Пустой() Тогда
		Объект.СтатусОплатыЗаказа = "Не оплачен";	
	КонецЕсли; 
	
	Выборка = РезультатЗапроса[0].Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Объект.СтатусОплатыЗаказа = ?(Выборка.ПроцентОплаты>=100, "Оплачен", "Не оплачен");
	КонецЦикла;
	
	ВыборкаКИ = РезультатЗапроса[3].Выбрать();
	Если ВыборкаКИ.Следующий() Тогда
		Объект.ПолучательФИО = ВыборкаКИ.Наименование;
        Объект.ТелефонПолучателя = ВыборкаКИ.НомерТелефона;
		Объект.EmailПолучателя = ВыборкаКИ.АдресЭП;
    КонецЕсли;
    	
	ОбъектРасчетов = Объект.Заказы[0].Заказ;
	Если ТипЗнч(ОбъектРасчетов) = Тип("ДокументСсылка.ЧекККМ") 
		И ОбъектРасчетов.Статус = Перечисления.СтатусыЧековККМ.Пробит Тогда
		Объект.СтатусОплатыЗаказа = "Оплачен";	
	КонецЕсли; 
	
	Доставка = Справочники.Номенклатура.НайтиПоКоду("Ц0000120605");
	НайденныеСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", Доставка));
	ЕстьДоставка = НайденныеСтроки.Количество() > 0;
	ЗаказОплачен = Объект.СтатусОплатыЗаказа = "Оплачен";
	
	Адрес = Объект.АдресДоставки;
	ГородСтрокой ="";
	ГородСтрокой = НайтиГород(Адрес, "городской округ");
	
	Если ГородСтрокой = "" Тогда
		НачалоПоиска = СтрНайти(Адрес, "Россия");
		Если НачалоПоиска > 0 Тогда
			ГородСтрокой = Сред(Адрес, СтрНайти(Адрес," ",,НачалоПоиска,1)+1, СтрНайти(Адрес,",",,НачалоПоиска,2)-СтрНайти(Адрес," ",,НачалоПоиска,1)-1);
		КонецЕсли;
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЛПостРегионы.Наименование КАК Наименование,
		|	ЛПостРегионы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ЛПостРегионы КАК ЛПостРегионы
		|ГДЕ
		|	ЛПостРегионы.Наименование ПОДОБНО &Наименование";
	
	Запрос.УстановитьПараметр("Наименование", "%"+ГородСтрокой+"%");
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	КоличествоГородов = Выборка.Количество();
	
	Если КоличествоГородов > 1 Тогда
		Сообщить("Найдено несколько регионов в справочнике для "+ГородСтрокой+", выберите регион вручную");	
	Иначе
		Если Выборка.Следующий() Тогда
			Объект.РегионДоставки = Выборка.Ссылка;	
		Иначе
			Сообщить("Регион не найден, заполните вручную.");
			Объект.РегионДоставки = Справочники.ГородаСДЭК.ПустаяСсылка();
		КонецЕсли; 
	КонецЕсли; 
	
КонецФункции
 
&НаКлиенте
Процедура ЗаполнитьПоляЛПост(Команда)
	
	//Объект.СтраховатьГруз = Истина;
	//СтраховатьГрузПриИзменении(Неопределено);
	
	ЗаполнитьПоляЛПостТКНаСервере();
	
	Если Объект.СтатусОплатыЗаказа = "Не оплачен" Тогда
		Объект.НаложенныйПлатеж = Истина;
		НаложенныйПлатежПриИзменении(Неопределено);
	Иначе
		Объект.НаложенныйПлатеж = Ложь;
		объект.СуммаНаложенногоПлатежа = 0;
	КонецЕсли; 
	Объект.ПримечаниеТК = "Услуга примерки, частичный выкуп, вежливый курьер!";
	Объект.КоличествоМест = 1; 
	Объект.ДоставитьВКратчайшийСрок = истина;
	Объект.ИнтервалДоставкиЛПост = "С 9 до 12";
	
	КоличествоМестПриИзменении(Неопределено);
	
	ТекДата = ТекущаяДата();
	Если (ТекДата-НачалоДня(ТекДата))< Дата(1,1,1,19,30,0)-Дата(1,1,1) Тогда
		Объект.ДатаОтгрузки = ТекДата;
	Иначе
		Объект.ДатаОтгрузки = КонецДня(ТекДата)+1;
	КонецЕсли; 
	
	КоличествоТовараВЗаявке = Объект.Товары.Итог("Количество");
	Объект.ВесПриОтправке = КоличествоТовараВЗаявке*200;
	МассивИнтервалов = РасчитатьПредварительнуюСтоимостьДоставкиИДатуДоставкиЛПост(Неопределено);

	ДокументСсылка = Объект.Заказы[0].Заказ;
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ВозвратТоваровПоставщику") Тогда
		Объект.СуммаСтрахования = ПолучитьСуммуДокумента(ДокументСсылка);
		Объект.СуммаНаложенногоПлатежа = 0;
	КонецЕсли; 

	ВызыватьФормуВыбораВремениДоставкиЛПост = ПолучитьЗначениеДинамическихНастроек();
	
	Если ВызыватьФормуВыбораВремениДоставкиЛПост Тогда
		ПараметрыОткрытия = Новый Структура();
	    ПараметрыОткрытия.Вставить("МассивИнтервалов", МассивИнтервалов);
	    
	    ОповещениеОЗакрытии = Новый ОписаниеОповещения("ЗаполнитьВремяДоставки", ЭтаФорма);
	    
	    ОткрытьФорму("Обработка.ОбменLPost.Форма.ФормаВыбораВремениДоставки", ПараметрыОткрытия, ЭтаФорма,,,,
                ОповещениеОЗакрытии,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
   	
	КонецЕсли;
	 
	Модифицированность = Истина;
	
КонецПроцедуры

