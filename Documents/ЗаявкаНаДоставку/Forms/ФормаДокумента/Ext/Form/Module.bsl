Функция СформироватьUuidШКЭтикетка(ЗаявкаНаДоставку)
	
	Токен = "Bearer "+ Константы.СДЭКТокен.Получить();
	HTTPСоединение = Новый HTTPСоединение(URL, , , , , , Новый ЗащищенноеСоединениеOpenSSL(), );
	HTTPЗапрос = Новый HTTPЗапрос("/v2/print/barcodes/");
	
	HTTPЗапрос.Заголовки.Вставить("Authorization", Токен); 
    HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	
	
	ЗапросСтруктура = Новый Структура("order_uuid", ЗаявкаНаДоставку.СДЭКUuid);
	Массив = Новый Массив;
	Массив.Добавить(ЗапросСтруктура);
	СтруктураOrders = Новый Структура("orders", Массив);
	
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, СтруктураOrders);
	
	СтрокаЗапроса = ЗаписьJSON.Закрыть();
	
	HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаЗапроса); 
	Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);

	//через поток не все ответы парсит
	ОтветСервера = Ответ.ПолучитьТелоКакСтроку("UTF-8"); // ЧтениеJSON.Закрыть();
	
	ОшибкаАутентификации = СтрНайти(ОтветСервера, "{""type"":""AUTH""") > 0;
	Если ОшибкаАутентификации Тогда
		АвторизацияНаСервере();
		Возврат	"";
	КонецЕсли; 

	UuidКвитанции = "";
	НайденныйUuid =  СтрНайти(ОтветСервера,Символ(34)+"uuid"+Символ(34)+":");
	Если НайденныйUuid > 0 Тогда
		
		UuidКвитанции = Сред(ОтветСервера, НайденныйUuid+8,36);
		
	КонецЕсли; 
	
	ОтветФункции = Новый Структура();
	ОтветФункции.Вставить("UuidКвитанции", UuidКвитанции);
	ОтветФункции.Вставить("ОшибкаАутентификации", ОшибкаАутентификации);
	
	Возврат ОтветФункции;
		
КонецФункции

