&НаСервере
Функция ОбновитьСтатусНаСервере()
	
	Если НЕ ЗначениеЗаполнено(Объект.СДЭКUuid) Тогда
		Возврат Истина;	
	КонецЕсли; 
	
	Токен = "Bearer "+ Константы.СДЭКТокен.Получить();
		
	HTTPСоединение = Новый HTTPСоединение(URL, , , , , , Новый ЗащищенноеСоединениеOpenSSL(), );
	
	Метод = "/v2/orders/"+Объект.СДЭКUuid;
	HTTPЗапрос = Новый HTTPЗапрос(Метод);

	HTTPЗапрос.Заголовки.Вставить("Authorization", Токен); 
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");

	Ответ = HTTPСоединение.Получить(HTTPЗапрос);

	Поток = Ответ.ПолучитьТелоКакПоток();
	Кодировка = "utf-8"; 

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.ОткрытьПоток(Поток, Кодировка); 
	Результат = ПрочитатьJSON(ЧтениеJSON);
	
	ОтветФункции = Ложь;
	
	Если ТипЗнч(Результат) = Тип("Структура") 
		И Результат.Свойство("entity") Тогда
		
		cdek_number = "";
		АктуальныйСтатус = "";
		
		entity = Результат.entity;
		
		Если ТипЗнч(entity) = Тип("Структура")
			И entity.Свойство("statuses") Тогда
			
			Для каждого Статус Из entity.statuses Цикл
				АктуальныйСтатус = Статус.name;
				СтатусДоставки = АктуальныйСтатус;
				Прервать;
			КонецЦикла;
			
			ОтветФункции = Истина;
		КонецЕсли; 
		
		Если АктуальныйСтатус <> "" 
			И Объект.СтатусДоставкиТК <> АктуальныйСтатус Тогда
			
			Объект.СтатусДоставкиТК = АктуальныйСтатус;
			
		КонецЕсли;
		
		Если entity.Свойство("delivery_detail") Тогда
			delivery_detail = entity.delivery_detail;
			Если ТипЗнч(delivery_detail) = Тип("Структура") 
				И delivery_detail.Свойство("total_sum") Тогда
				Объект.СуммаУслугСДЭК = delivery_detail.total_sum;
			КонецЕсли;
		КонецЕсли; 
		Вес = 0;
		Если entity.Свойство("packages") Тогда
			packages = entity.packages;
			Если ТипЗнч(packages) = Тип("Массив") Тогда
				Для каждого стр Из packages Цикл
					Вес = Вес + стр.weight_calc;	
				КонецЦикла; 	
			КонецЕсли; 
			Объект.ВесПриОтправке = Вес;
		КонецЕсли; 
		
		Если Результат.Свойство("related_entities") Тогда
			related_entities = Результат.related_entities;
			Если ТипЗнч(related_entities) = Тип("Массив") Тогда
				Для каждого стр Из related_entities Цикл
					Если стр.Свойство("cdek_number") Тогда
						//Объект.НомерВозвратаСДЭК = стр.cdek_number;
						ОбновитьИнформациюПоВозврату(Объект.НомерВозвратаСДЭК);
					КонецЕсли; 	
				КонецЦикла; 	
			КонецЕсли;
		КонецЕсли;
				
	КонецЕсли; 
	Если ТипЗнч(Результат) = Тип("Структура") 
		И Результат.Свойство("requests") Тогда
		
		request = Результат.requests[0];
		Если request.state = "INVALID"
			И request.type = "AUTH" Тогда
			АвторизацияНаСервере();
		КонецЕсли; 
		
	КонецЕсли; 
	
	ОтветСервера = Ответ.ПолучитьТелоКакСтроку("UTF-8");
	
	Request = СериализацияЗначения("URL: "+URL+"/"+Метод);
    ПреобразоватьИЗаписатьЛог(Request, Результат, ОтветСервера, "СДЭК Информация по заказу", "Заявка "+Объект.Номер);

	Возврат ОтветФункции;
	
КонецФункции

Функция ОбновитьИнформациюПоВозврату(cdek_number)
	
	Если НЕ ЗначениеЗаполнено(cdek_number) Тогда
		Возврат Истина;	
	КонецЕсли; 
	
	Токен = "Bearer "+ Константы.СДЭКТокен.Получить();
		
	HTTPСоединение = Новый HTTPСоединение(URL, , , , , , Новый ЗащищенноеСоединениеOpenSSL(), );
	
	Метод = "/v2/orders?cdek_number="+cdek_number;
	HTTPЗапрос = Новый HTTPЗапрос(Метод);

	HTTPЗапрос.Заголовки.Вставить("Authorization", Токен); 
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");

	Ответ = HTTPСоединение.Получить(HTTPЗапрос);

	Поток = Ответ.ПолучитьТелоКакПоток();
	Кодировка = "utf-8"; 

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.ОткрытьПоток(Поток, Кодировка); 
	Результат = ПрочитатьJSON(ЧтениеJSON);
	
	ОтветФункции = Ложь;
	
	Если ТипЗнч(Результат) = Тип("Структура") 
		И Результат.Свойство("entity") Тогда
		
		//cdek_number = "";
		АктуальныйСтатус = "";
		
		entity = Результат.entity;
		
		Если ТипЗнч(entity) = Тип("Структура")
			И entity.Свойство("statuses") Тогда
			
			Для каждого Статус Из entity.statuses Цикл
				АктуальныйСтатус = Статус.name;
				СтатусДоставки = АктуальныйСтатус;
			КонецЦикла;
			
			ОтветФункции = Истина;
		КонецЕсли; 
		
		Если entity.Свойство("delivery_detail") Тогда
			delivery_detail = entity.delivery_detail;
			Если ТипЗнч(delivery_detail) = Тип("Структура") 
				И delivery_detail.Свойство("total_sum") Тогда
				
				Объект.СуммаУслугВозвратСДЭК = delivery_detail.total_sum;
				Объект.СуммаУслугСДЭК = Объект.СуммаУслугСДЭК + Объект.СуммаУслугВозвратСДЭК;
				
			КонецЕсли;
		КонецЕсли; 
		
		Вес = 0;
		Если entity.Свойство("packages") Тогда
			packages = entity.packages;
			Если ТипЗнч(packages) = Тип("Массив") Тогда
				Для каждого стр Из packages Цикл
					Вес = Вес + стр.weight_calc;	
				КонецЦикла; 	
			КонецЕсли; 
			
			Объект.ВесВозврата = Вес;
			
		КонецЕсли; 
		
		Если АктуальныйСтатус <> "" 
			И Объект.СтатусДоставкиВозвратТК <> АктуальныйСтатус Тогда
			
			Объект.СтатусДоставкиВозвратТК = АктуальныйСтатус;
			
		КонецЕсли; 
	КонецЕсли;
	
	Возврат ОтветФункции;
	
КонецФункции
 
