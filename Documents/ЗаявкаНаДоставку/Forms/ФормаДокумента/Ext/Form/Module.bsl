&НаКлиенте
Процедура ЗаполнитьПоляТК(Команда)
	
	//Объект.СтраховатьГруз = Истина;
	//СтраховатьГрузПриИзменении(Неопределено);
	
	ЗаполнитьПоляТКНаСервере();
	
	Если Объект.СтатусОплатыЗаказа = "Не оплачен" Тогда
		Объект.НаложенныйПлатеж = Истина;
		НаложенныйПлатежПриИзменении(Неопределено);
	Иначе
		Объект.НаложенныйПлатеж = Ложь;
		объект.СуммаНаложенногоПлатежа = 0;
	КонецЕсли; 
	
	Объект.КоличествоМест = 1;
	КоличествоМестПриИзменении(Неопределено);
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоляТКНаСервере()
	
	Если Объект.Заказы.Количество() > 1 Тогда
		Сообщить("Заполнение полей рассчитано для одного Заказа. Удалите лишние.");
		Возврат;	
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СостоянияЗаказовКлиентов.ПроцентОплаты КАК ПроцентОплаты
		|ИЗ
		|	РегистрСведений.СостоянияЗаказовКлиентов КАК СостоянияЗаказовКлиентов
		|ГДЕ
		|	СостоянияЗаказовКлиентов.Заказ = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", Объект.Заказы[0].Заказ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Объект.СтатусОплатыЗаказа = "Не оплачен";	
	КонецЕсли; 
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Объект.СтатусОплатыЗаказа = ?(Выборка.ПроцентОплаты>=100, "Оплачен", "Не оплачен");
	КонецЦикла;
	
	
	ОбъектРасчетов = Объект.Заказы[0].Заказ;
	Если ТипЗнч(ОбъектРасчетов) = Тип("ДокументСсылка.ВозвратТоваровПоставщику")
		ИЛИ (ТипЗнч(ОбъектРасчетов) = Тип("ДокументСсылка.ЧекККМ") 
		И ОбъектРасчетов.Статус = Перечисления.СтатусыЧековККМ.Пробит) Тогда
		 
		Объект.СтатусОплатыЗаказа = "Оплачен";	
	КонецЕсли; 
	
	ТД = ТекущаяДата(); 
	ВремяТекущее = ТД - НачалоДня(ТД); 
	Если ВремяТекущее > 15*3600+15*60 Тогда   //Время > 15:15
		Объект.СДЭКДатаЗабораГруза = КонецДня(ТекущаяДата())+1;
		Объект.СДЭКВремяЗабораГрузаС = Дата(1,1,1) + 14*3600;
		Объект.СДЭКВремяЗабораГрузаПо = Дата(1,1,1) + 17*3600;
	Иначе
		Объект.СДЭКДатаЗабораГруза = НачалоДня(ТД);
		Объект.СДЭКВремяЗабораГрузаС = Дата(1,1,1) + Час(ТД)*3600 + 15*60;
		Объект.СДЭКВремяЗабораГрузаПо = Объект.СДЭКВремяЗабораГрузаС + 3*3600;
	КонецЕсли; 
	
	Доставка = Справочники.Номенклатура.НайтиПоКоду("Ц0000120605");
	НайденныеСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", Доставка));
	ЕстьДоставка = НайденныеСтроки.Количество() > 0;
	ЗаказОплачен = Объект.СтатусОплатыЗаказа = "Оплачен";
	
	Объект.ПримечаниеТК = "Частичная доставка Примерка, частичный выкуп, вежливый курьер.";
	
	СДЭК_Примечание = Бабочка.ПолучитьЗначениеДинамическихНастроек("СДЭК_Примечание", "Оплата доставки ТОЛЬКО при выкупе менее 15000руб., вежливый курьер.");
	Если ЕстьДоставка И НЕ ЗаказОплачен Тогда
		Объект.ПримечаниеТК = СДЭК_Примечание;	
	КонецЕсли; 
	Если НЕ ЕстьДоставка И НЕ ЗаказОплачен Тогда
		Объект.ПримечаниеТК = "Вежливый курьер."	
	КонецЕсли; 
	Если ЗаказОплачен Тогда
		Объект.ПримечаниеТК = "Вежливый курьер, возможен частичный возврат."	
	КонецЕсли; 
	
		
	Объект.СДЭКВыбранныйТариф = Справочники.ТарифыСДЭКИМ.НайтиПоРеквизиту("КодТарифа", "136");
	Объект.СДЭКТипДоставки = Объект.СДЭКВыбранныйТариф.РежимДоставки;
	
	//++babochka тикет 48145
	//ИзменитьПримечаниеСДЭК();
    //--babochka
	
	ДопУслугиСДЭК.Очистить();
	ДополнительныеУслугиСДЭК = Справочники.ДополнительныеУслугиСДЭК;
	ДопУслугиСДЭК.Добавить(ДополнительныеУслугиСДЭК.НайтиПоРеквизиту("КодУслуги", "TRYING_ON"));
	
	Если Объект.Товары.Итог("Количество") > 1 Тогда
		
		ДопУслугиСДЭК.Добавить(ДополнительныеУслугиСДЭК.НайтиПоРеквизиту("КодУслуги", "PART_DELIV"));
		
	КонецЕсли; 
	
	//ДопУслугиСДЭК.Добавить(ДополнительныеУслугиСДЭК.НайтиПоРеквизиту("КодУслуги", "INSURANCE"));
	
	Если ЗначениеЗаполнено(Объект.АдресДоставки) Тогда
		Город = НайтиГородПоИндексуНаСервере();
	Иначе
		Город = Справочники.ГородаСДЭК.ПустаяСсылка();
	КонецЕсли;
	Если ЗначениеЗаполнено(Город) Тогда
		Объект.СДЭКГородДоставки = Город;	
	Иначе
		Адрес = Объект.АдресДоставки;
		ГородСтрокой ="";
		ГородСтрокой = НайтиГород(Адрес, "городской округ");
		
		Если ГородСтрокой = "" Тогда
			НачалоПоиска = СтрНайти(Адрес, "Россия");
			Если НачалоПоиска > 0 Тогда
				ГородСтрокой = Сред(Адрес, СтрНайти(Адрес," ",,НачалоПоиска,1)+1, СтрНайти(Адрес,",",,НачалоПоиска,2)-СтрНайти(Адрес," ",,НачалоПоиска,1)-1);
			КонецЕсли;
		КонецЕсли; 
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ГородаСДЭК.Наименование КАК Наименование,
			|	ГородаСДЭК.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.ГородаСДЭК КАК ГородаСДЭК
			|ГДЕ
			|	ГородаСДЭК.Наименование = &Наименование";
		
		Запрос.УстановитьПараметр("Наименование", ГородСтрокой);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		КоличествоГородов = Выборка.Количество();
		
		Если КоличествоГородов > 1 Тогда
			Если ГородСтрокой = "Москва" Тогда
				Объект.СДЭКГородДоставки = Справочники.ГородаСДЭК.НайтиПоКоду("000005052");
			Иначе
				Сообщить("Найдено несколько городов в справочнике СДЭК для "+ГородСтрокой+", выберите город вручную");	
			КонецЕсли;
			 
		Иначе
			Если Выборка.Следующий() Тогда
				Объект.СДЭКГородДоставки = Выборка.Ссылка;	
			Иначе
				Сообщить("Город не найден, заполните вручную.");
				Объект.СДЭКГородДоставки = Справочники.ГородаСДЭК.ПустаяСсылка();
			КонецЕсли; 
		КонецЕсли; 
	КонецЕсли; 
	
КонецПроцедуры

Функция НайтиГородПоИндексуНаСервере()
	
	Город = Справочники.ГородаСДЭК.ПустаяСсылка();
	МассивСтрок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Объект.АдресДоставки," ");
	Индекс = "";
	Если МассивСтрок.Количество() Тогда
		Индекс = МассивСтрок[0];	
	КонецЕсли; 
	
	ТолькоЦифрыВСтроке = СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Индекс);
	
	Если ТолькоЦифрыВСтроке Тогда
		
	    Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ГородаСДЭК.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.ГородаСДЭК КАК ГородаСДЭК
			|ГДЕ
			|	ГородаСДЭК.Индексы ПОДОБНО &Индекс";
		
		Запрос.УстановитьПараметр("Индекс", "%"+Индекс+"%");
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Если Выборка.Следующий() Тогда
			Город = Выборка.Ссылка;	
		КонецЕсли; 
		
	КонецЕсли;
	
	Возврат Город;
	
КонецФункции

Функция НайтиГород(ИсходнаяСтрока, СтрокаИсправления)
    ГородСтрокой="";

	НачальнаяПозиция = СтрНайти(ИсходнаяСтрока, СтрокаИсправления);
	Если НачальнаяПозиция > 0 Тогда
		Если Прав(СтрокаИсправления, 1) = " " Тогда
			НачальнаяПозиция = НачальнаяПозиция-1;
		КонецЕсли; 
	
		ПозицияКонец = СтрНайти(ИсходнаяСтрока,",",,НачальнаяПозиция);
		ГородСтрокой = Сред(ИсходнаяСтрока, НачальнаяПозиция+1+СтрДлина(СтрокаИсправления), ПозицияКонец-НачальнаяПозиция-1-СтрДлина(СтрокаИсправления));
		
	КонецЕсли;

	Возврат ГородСтрокой;
	
КонецФункции

&НаСервере
Процедура СДЭКТипДоставкиПриИзмененииНаСервере()
	
	Если Объект.СДЭКТипДоставки = Перечисления._ТипыДоставки.ДверьСклад
		ИЛИ Объект.СДЭКТипДоставки = Перечисления._ТипыДоставки.ДоСклада Тогда
		Элементы.СДЭКПунктВыдачиЗаказа.Видимость = Истина;
	Иначе	
		Объект.СДЭКПунктВыдачиЗаказа = Справочники.ПунктыВыдачиЗаказовСДЭК.ПустаяСсылка();
		Элементы.СДЭКПунктВыдачиЗаказа.Видимость = Ложь;
	КонецЕсли;
	//ИзменитьПримечаниеСДЭК();
	
КонецПроцедуры

