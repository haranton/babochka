&НаКлиенте
Процедура ОбщийПодбор(Команда)
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ПодобратьЗаказыЗавершение", ЭтаФорма);
	
	ОткрытьФорму("Документ.ЗаявкаНаДоставку.Форма.Форма", , ЭтаФорма,,,,
				ОповещениеОЗакрытии,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Функция ПодобратьЗаказыЗавершение(РезультатЗакрытия, Дополнительныепараметры) Экспорт
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат 0;	
	КонецЕсли; 
	
	Если РезультатЗакрытия.Свойство("АдресВХРезультатЗакрытия") Тогда
		ОбщийПодборЗавершениеСервер(РезультатЗакрытия.АдресВХРезультатЗакрытия);
	КонецЕсли; 
	
	Модифицированность = Истина;
 	
КонецФункции

&НаСервере
Функция ОбщийПодборЗавершениеСервер(АдресВХ)
	
	РезультатЗакрытия = ПолучитьИзВременногоХранилища(АдресВХ);
	
	Для каждого Заказ Из РезультатЗакрытия Цикл
		
		МассивСтрок = Объект.Товары.НайтиСтроки(Новый Структура("Заказ", Заказ));
		Для каждого Строка Из МассивСтрок Цикл
			Объект.Товары.Удалить(Строка);
		КонецЦикла;
		
		МассивСтрок = Объект.Заказы.НайтиСтроки(Новый Структура("Заказ", Заказ));
		Для каждого Строка Из МассивСтрок Цикл
			Объект.Заказы.Удалить(Строка);
		КонецЦикла;
		
		СтрокаЗаказ = Объект.Заказы.Добавить();
		СтрокаЗаказ.Заказ = Заказ;
		
		
		ДобавитьТоварыЗаказаСервер(Заказ);
		
	КонецЦикла; 
	
	Если Заказ <> Неопределено Тогда
		
		Если ТипЗнч(Заказ) <> Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			Объект.Партнер = Заказ.Партнер;
			Если НЕ ЗначениеЗаполнено(Объект.АдресДоставки) Тогда
				Объект.АдресДоставки = ПолучитьАдресИзПартнера();		
			КонецЕсли;
		КонецЕсли;
		Если ТипЗнч(Заказ) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			Объект.НомерПоДаннымКлиента = Заказ.НомерПоДаннымКлиента;
		Иначе
			Объект.НомерПоДаннымКлиента = Заказ.Номер; 
		КонецЕсли;    	
		
	КонецЕсли;   
	
КонецФункции

Функция ПолучитьАдресИзПартнера()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПартнерыКонтактнаяИнформация.Представление КАК Представление
		|ИЗ
		|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
		|ГДЕ
		|	ПартнерыКонтактнаяИнформация.Тип = &Тип
		|	И ПартнерыКонтактнаяИнформация.Вид = &Вид
		|	И ПартнерыКонтактнаяИнформация.Ссылка = &Партнер";
	
	Запрос.УстановитьПараметр("Вид", Справочники.ВидыКонтактнойИнформации.АдресПартнера);
	Запрос.УстановитьПараметр("Партнер", Объект.Партнер);
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыКонтактнойИнформации.Адрес);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат "";
	КонецЕсли;  
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.Представление;	
	КонецЦикла;   
	
КонецФункции

&НаКлиенте
Процедура ИнтервалПриИзменении(Элемент)

	ВремяИнтервала = Объект.Интервал;
	ПозицияДвоеточия = СтрНайти(ВремяИнтервала, ":");
	Если Объект.Интервал = "" Тогда
		Возврат;	
	КонецЕсли;
	Объект.ВремяДоставкиС = Дата(Лев(ВремяИнтервала, ПозицияДвоеточия-1)); 
	Объект.ВремяДоставкиПо = Дата(Сред(ВремяИнтервала, ПозицияДвоеточия+1, СтрДлина(ВремяИнтервала)));
	
	Возврат; 
	
КонецПроцедуры

&НаКлиенте
Процедура ТранспортнаяКомпанияПриИзменении(Элемент)
	
	УстановитьВидимостьДоставки();
	УстановитьВидимостьПечати();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьДоставки()
	
	ЭтоСДЭК = Объект.ТранспортнаяКомпания = Перечисления.ТранспортныеКомпании.CDEK;
	Элементы.Доставка.Видимость = ЭтоСДЭК;
	
	ЭтоLPOST = Объект.ТранспортнаяКомпания = Перечисления.ТранспортныеКомпании.LPOST;
	Элементы.ДоставкаЛПост.Видимость = ЭтоLPOST;
	Элементы.ОкруглитьСумму.Видимость = ЭтоLPOST;
	Самовывоз = ЗначениеЗаполнено(Объект.ЛПостПунктВыдачи);
	Элементы.ЛПостПунктВыдачиЗаказа.Видимость = ЗначениеЗаполнено(Объект.ЛПостПунктВыдачи);

	ЭтоДоставкаBABOCHKA = Объект.ТранспортнаяКомпания = Перечисления.ТранспортныеКомпании.BABOCHKA;
	Элементы.Курьер.Видимость = ЭтоДоставкаBABOCHKA;
	Элементы.ГруппаСтатус.Видимость = ЭтоДоставкаBABOCHKA;
	Элементы.ГруппаПолучатель.Видимость = ЭтоДоставкаBABOCHKA;
	
КонецПроцедуры
 
&НаКлиенте
Процедура НаложенныйПлатежПриИзменении(Элемент)
	
	Если Объект.НаложенныйПлатеж Тогда
		Объект.СуммаНаложенногоПлатежа = Объект.Товары.Итог("Сумма");
	Иначе
		Объект.СуммаНаложенногоПлатежа = 0;
	КонецЕсли; 
	
КонецПроцедуры

