	КонецЕсли;
    //--babochka

КонецФункции

&НаКлиенте
Процедура СДЭКТипДоставкиПриИзменении(Элемент)
	СДЭКТипДоставкиПриИзмененииНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьВСДЭК(Команда)
	
	Если Модифицированность Тогда
		ЭтотОбъект.Записать();	
	КонецЕсли; 
	
	Если НЕ Объект.Проведен Тогда
		Сообщить("Проведите сначала документ!");
		Возврат;	
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура();
	ПараметрыОткрытия.Вставить("Заявка", Объект.Ссылка);
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ОтправкаСДЭКЗавершение", ЭтаФорма);
	
	ОткрытьФорму("Документ.ЗаявкаНаДоставку.Форма.ФормаОтправки", ПараметрыОткрытия, ЭтаФорма,,,,
				ОповещениеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Функция ОтправкаСДЭКЗавершение(РезультатЗакрытия, Дополнительныепараметры) Экспорт
	
	Если РезультатЗакрытия <> Неопределено Тогда
		
		Если РезультатЗакрытия.ЭтоОтправкаЗаказа Тогда
			Объект.СДЭКUuid = РезультатЗакрытия.Uuid;
			Объект.СДЭКНомер = РезультатЗакрытия.Номер;
			Объект.СтатусДоставкиТК = РезультатЗакрытия.СтатусДоставки;
		
		Иначе	
			Объект.СДЭКНомер = РезультатЗакрытия.Номер;
